                    <div class="perm-page-header-right">
                        @{
                            var staffRoleObj = permRoles.FirstOrDefault(r => r.RoleName.Equals("staff", StringComparison.OrdinalIgnoreCase));
                            var customerRoleObj = permRoles.FirstOrDefault(r => r.RoleName.Equals("customer", StringComparison.OrdinalIgnoreCase));
                        }
                        <LoadingButton Class="btn-luxury-solid perm-header-save-btn"
                                       IsLoading="@(savingPermRoleId.HasValue)"
                                       LoadingText="Saving..."
                                       OnClick="@(async () => {
                                           if (staffRoleObj != null) await SaveRolePermissions(staffRoleObj.RoleId);
                                           if (customerRoleObj != null) await SaveRolePermissions(customerRoleObj.RoleId);
                                       })">
                            <i class="bi bi-save me-1"></i> Save Changes
                        </LoadingButton>
                    </div>
                </div>

                <!-- Info Banner -->
                <div class="perm-info-banner">
                    <i class="bi bi-info-circle-fill"></i>
                    <span>Manage what permissions are granted to the Staff role. Changes will be applied immediately.</span>
                </div>

                <!-- Feedback messages -->
                @if (!string.IsNullOrEmpty(permSuccessMessage))
                {
                    <div class="alert-banner alert-banner-success">
                        <i class="bi bi-check-circle-fill me-2"></i> @permSuccessMessage
                    </div>
                }
                @if (!string.IsNullOrEmpty(permErrorMessage))
                {
                    <div class="alert-banner alert-banner-error">
                        <i class="bi bi-exclamation-circle-fill me-2"></i> @permErrorMessage
                    </div>
                }

                @if (isLoadingPermissions)
                {
                    <div class="perm-loading-state">
                        <div class="perm-loading-spinner"></div>
                        <p class="text-muted mt-3">Loading permission matrix…</p>
                    </div>
                }
                else if (!permRoles.Any())
                {
                    <div class="luxury-card text-center py-5">
                        <i class="bi bi-shield-exclamation" style="font-size:2rem; color: var(--accent-main);"></i>
                        <p class="text-muted mt-3">No manageable roles found. Ensure the database is seeded.</p>
                    </div>
                }
                else
                {
                    <!-- Role Tab Strip -->
                    <div class="perm-role-tabs">
                        @foreach (var role in permRoles)
                        {
                            <button type="button"
                                    class="perm-role-tab @(activePermRoleId == role.RoleId ? "perm-role-tab-active" : "")"
                                    @onclick="() => SetActivePermTab(role.RoleId)">
                                <span>@(role.RoleName[0].ToString().ToUpper() + role.RoleName.Substring(1)) Role</span>
                            </button>
                        }
                        <button type="button"
                                class="perm-role-tab @(activePermRoleId == 9999 ? "perm-role-tab-active" : "")"
                                @onclick="() => SetActivePermTab(9999)">
                            <span>Role Overview</span>
                        </button>
                    </div>

                    <!-- Permission Matrix Card Table -->
                    <div class="perm-matrix-card luxury-card mt-3">
                        <div class="table-responsive">
                            <table class="table perm-matrix-table align-middle">
                                <thead>
                                    <tr>
                                        <th style="width: 25%;">Permission Name</th>
                                        <th style="width: 35%;">Description</th>
                                        <th style="width: 15%; text-align: center;">Admin (Full Access)</th>
                                        <th style="width: 12.5%; text-align: center;">Staff</th>
                                        <th style="width: 12.5%; text-align: center;">Customer</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!permList.Any())
                                    {
                                        <tr>
                                            <td colspan="5" class="text-center py-4 text-muted">No permissions defined in the database.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var perm in permList)
                                        {
                                            var staffRole = permRoles.FirstOrDefault(r => r.RoleName.Equals("staff", StringComparison.OrdinalIgnoreCase));
                                            var customerRole = permRoles.FirstOrDefault(r => r.RoleName.Equals("customer", StringComparison.OrdinalIgnoreCase));

                                            var staffGranted = staffRole != null && IsPermGranted(staffRole.RoleId, perm.PermissionId);
                                            var customerGranted = customerRole != null && IsPermGranted(customerRole.RoleId, perm.PermissionId);

                                            var staffToggleId = $"toggle-staff-{perm.PermissionId}";
                                            var customerToggleId = $"toggle-customer-{perm.PermissionId}";

                                            // Determine bootstrap icon based on permission name
                                            var iconClass = perm.PermissionName switch
                                            {
                                                "Products.Manage" => "bi-cart-dash",
                                                "Customers.View" => "bi-people",
                                                "Staff.Manage" => "bi-person-badge",
                                                "Reports.Generate" => "bi-bar-chart",
                                                _ => "bi-shield"
                                            };

                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center gap-2">
                                                        <i class="bi @iconClass perm-icon"></i>
                                                        <span class="perm-name">@perm.PermissionName</span>
                                                    </div>
                                                </td>
                                                <td class="text-muted perm-desc">@(perm.Description ?? "No description provided.")</td>
                                                <td style="text-align: center;">
                                                    <span class="perm-badge-always-on">Always On</span>
                                                </td>
                                                <td style="text-align: center;">
                                                    @if (staffRole != null)
                                                    {
                                                        <label class="perm-toggle-switch" for="@staffToggleId">
                                                            <input type="checkbox"
                                                                   id="@staffToggleId"
                                                                   checked="@staffGranted"
                                                                   @onchange="() => TogglePermission(staffRole.RoleId, perm.PermissionId)" />
                                                            <span class="perm-toggle-slider"></span>
                                                        </label>
                                                    }
                                                </td>
                                                <td style="text-align: center;">
                                                    @if (customerRole != null)
                                                    {
                                                        <label class="perm-toggle-switch" for="@customerToggleId">
                                                            <input type="checkbox"
                                                                   id="@customerToggleId"
                                                                   checked="@customerGranted"
                                                                   @onchange="() => TogglePermission(customerRole.RoleId, perm.PermissionId)" />
                                                            <span class="perm-toggle-slider"></span>
                                                        </label>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Legend Section -->
                    <div class="perm-legend-container mt-3">
                        <span class="legend-title">Legend:</span>
                        <div class="legend-item">
                            <span class="perm-toggle-switch-demo checked"></span>
                            <span class="legend-text">Permission Granted</span>
                        </div>
                        <div class="legend-item">
                            <span class="perm-toggle-switch-demo"></span>
                            <span class="legend-text">Permission Denied</span>
                        </div>
                        <div class="legend-item">
                            <span class="perm-badge-always-on">Always On</span>
                            <span class="legend-text">Admin has full access</span>
                        </div>
                    </div>
                }
            </div>
        }

        else if (activeView == "create-order")

        {
            <div class="page-header order-page-header" style="margin-bottom: 1.5rem;">
                <div>
                    <div class="page-sub" style="font-size:.75rem;letter-spacing:.12em;text-transform:uppercase;color:var(--slate);margin-bottom:.25rem;">Operations</div>
                    <h2 class="luxury-text m-0">Create Phone Order</h2>
                </div>
                <div style="display:flex;align-items:center;gap:.6rem;">
                    <span class="badge bg-light text-dark border"><i class="bi bi-telephone"></i> Phone sale</span>
                    <span class="badge bg-secondary">@adminSelectedItemCount item(s)</span>
                </div>
            </div>

            <div class="create-order-workflow">
                <div class="create-order-main">

                    <!-- 01 Caller Details -->
                    <section class="order-panel">
                        <div class="order-panel-head">
                            <div>
                                <div class="order-panel-kicker">Customer</div>
                                <h3>Caller Details</h3>
                            </div>
                            <span class="order-step-badge">01</span>
                        </div>
                        <div class="ob-form-grid two">
                            <div class="field-block">
                                <label class="ob-form-label">Customer Name</label>
                                <input type="text" class="ob-input" placeholder="Thiri San"
                                       @bind="adminGuestCustomerName" @bind:event="oninput" />
                            </div>
                            <div class="field-block">
                                <label class="ob-form-label">Phone Number</label>
                                <input type="tel" class="ob-input" placeholder="09xxxxxxxxx"
                                       @bind="adminGuestPhoneNumber" @bind:event="oninput" />
                            </div>
                        </div>
                    </section>

                    <!-- 02 Product Lines -->
                    <section class="order-panel order-items-panel">
                        <div class="order-panel-head">
                            <div>
                                <div class="order-panel-kicker">Items</div>
                                <h3>Product Lines</h3>
                            </div>
                            <button type="button" class="ob-add-btn compact" @onclick="AdminAddOrderLine">
                                <i class="bi bi-plus-circle"></i> Add Item
                            </button>
                        </div>

                        <div class="staff-search-control">
                            <i class="bi bi-search"></i>
                            <input type="search" placeholder="Search SKU, product, size, color"
                                   @bind="adminProductSearch" @bind:event="oninput" />
                        </div>

                        <div class="ob-items-header">
                            <div>Product</div>
                            <div>Qty</div>
                            <div>Unit</div>
                            <div>Total</div>
                            <div></div>
                        </div>

                        <div class="ob-item-list">
                            @foreach (var line in adminOrderLines)
                            {
                                var selectedVariant = adminInventoryVariants.FirstOrDefault(v => v.VariantId == line.VariantId);
                                var variantOptions = AdminGetSelectableVariants(line).ToList();

                                <div class="ob-item-row">
                                    <div class="ob-product-cell">
                                        <select class="ob-select" value="@line.VariantId"
                                                @onchange="(e) => AdminOnLineVariantChanged(line, e.Value?.ToString())">
                                            <option value="0">Select item</option>
                                            @if (!variantOptions.Any())
                                            {
                                                <option value="0" disabled>No matching stock</option>
                                            }
                                            @foreach (var v in variantOptions)
                                            {
                                                <option value="@v.VariantId">@v.Sku - @v.Product.Name (@v.Size / @v.Color)</option>
                                            }
                                        </select>
                                        @if (selectedVariant != null)
                                        {
                                            <div class="ob-stock-line">
                                                <span>@selectedVariant.StockQuantity left</span>
                                                <span>@selectedVariant.Size / @selectedVariant.Color</span>
                                            </div>
                                        }
                                    </div>

                                    <div class="qty-stepper">
                                        <button type="button" @onclick="() => AdminAdjustLineQty(line, -1)" aria-label="Decrease quantity">
                                            <i class="bi bi-dash"></i>
                                        </button>
                                        <input type="number" min="1" value="@line.Quantity"
                                               @onchange="(e) => AdminOnLineQtyChanged(line, e.Value?.ToString())" />
                                        <button type="button" @onclick="() => AdminAdjustLineQty(line, 1)" aria-label="Increase quantity">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </div>

                                    <div class="money-cell">@AdminGetVariantUnitPrice(line.VariantId).ToString("N0")</div>
                                    <div class="money-cell strong">@AdminGetLineTotal(line).ToString("N0")</div>
                                    <button type="button" class="icon-action danger" @onclick="() => AdminRemoveOrderLine(line)" aria-label="Remove item">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    </section>

                    <!-- 03 Delivery Address -->
                    <section class="order-panel">
                        <div class="order-panel-head">
                            <div>
                                <div class="order-panel-kicker">Delivery</div>
                                <h3>Address</h3>
                            </div>
                            <span class="order-step-badge">03</span>
                        </div>
                        <div class="field-block">
                            <label class="ob-form-label">Shipping / Contact Address</label>
                            <textarea class="ob-textarea" rows="4"
                                      placeholder="No.123, Bo Yar Nyunt Street, Dagon Township, Yangon"
                                      @bind="adminShippingAddress" @bind:event="oninput"></textarea>
                        </div>
                    </section>

                    <!-- 04 Payment -->
                    <section class="order-panel">
                        <div class="order-panel-head">
                            <div>
                                <div class="order-panel-kicker">Payment</div>
                                <h3>Method &amp; Status</h3>
                            </div>
                            <span class="order-step-badge">04</span>
                        </div>
                        <div class="ob-form-grid two">
                            <div class="field-block">
                                <label class="ob-form-label">Payment Method</label>
                                <div class="ob-pill-group">
                                    @foreach (var method in new[] { ("cod", "bi-cash-coin", "COD"), ("kpay", "bi-phone", "KPay"), ("wave_money", "bi-phone-fill", "WavePay") })
                                    {
                                        <button type="button" class="ob-pill @(adminPaymentMethod == method.Item1 ? "ob-pill-active" : "")"
                                                @onclick='() => adminPaymentMethod = method.Item1'>
                                            <i class="bi @method.Item2"></i> @method.Item3
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="field-block">
                                <label class="ob-form-label">Payment Status</label>
                                <div class="ob-pill-group">
                                    <button type="button" class="ob-pill @(adminPaymentStatus == "unpaid" ? "ob-pill-active" : "")"
                                            @onclick='() => adminPaymentStatus = "unpaid"'>
                                        <i class="bi bi-clock-history"></i> Unpaid
                                    </button>
                                    <button type="button" class="ob-pill @(adminPaymentStatus == "paid" ? "ob-pill-active" : "")"
                                            @onclick='() => adminPaymentStatus = "paid"'>
                                        <i class="bi bi-check-circle"></i> Paid
                                    </button>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <!-- Order Summary Sidebar -->
                <aside class="order-summary-panel">
                    <div class="summary-title-row">
                        <div>
                            <div class="order-panel-kicker">Summary</div>
                            <h3>Phone Order</h3>
                        </div>
                        <span class="summary-status @(adminCanSubmitPhoneOrder ? "ready" : "")">
                            @(adminCanSubmitPhoneOrder ? "Ready" : "Draft")
                        </span>
                    </div>

                    <div class="summary-total-block">
                        <div class="summary-label">Order Total</div>
                        <div class="summary-total">@adminOrderLinesTotal.ToString("N0") <span>MMK</span></div>
                    </div>

                    <div class="summary-metrics">
                        <div>
                            <span>@adminSelectedLineCount</span>
                            <label>Lines</label>
                        </div>
                        <div>
                            <span>@adminSelectedItemCount</span>
                            <label>Pieces</label>
                        </div>
                    </div>

                    <div class="summary-checklist">
                        <div class="@AdminCheckClass(!string.IsNullOrWhiteSpace(adminGuestCustomerName) && !string.IsNullOrWhiteSpace(adminGuestPhoneNumber))">
                            <i class="bi @(!string.IsNullOrWhiteSpace(adminGuestCustomerName) && !string.IsNullOrWhiteSpace(adminGuestPhoneNumber) ? "bi-check-circle-fill" : "bi-circle")"></i>
                            <span>Customer</span>
                        </div>
                        <div class="@AdminCheckClass(adminSelectedLineCount > 0)">
                            <i class="bi @(adminSelectedLineCount > 0 ? "bi-check-circle-fill" : "bi-circle")"></i>
                            <span>Items</span>
                        </div>
                        <div class="@AdminCheckClass(!string.IsNullOrWhiteSpace(adminShippingAddress))">
                            <i class="bi @(!string.IsNullOrWhiteSpace(adminShippingAddress) ? "bi-check-circle-fill" : "bi-circle")"></i>
                            <span>Delivery</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(adminCreateOrderError))
                    {
                        <div class="inline-toast error order-error">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span>@adminCreateOrderError</span>
                        </div>
                    }

                    <div class="summary-actions">
                        <LoadingButton Class="@(adminCanSubmitPhoneOrder ? "ob-submit-btn" : "ob-submit-btn disabled")"
                                       Disabled="@(!adminCanSubmitPhoneOrder || adminIsSubmittingPhoneOrder)"
                                       IsLoading="@adminIsSubmittingPhoneOrder"
                                       LoadingText="Confirming..."
                                       OnClick="AdminSubmitPhoneOrder">
                            <i class="bi bi-bag-check-fill"></i> Confirm Order
                        </LoadingButton>
                        <button type="button" class="text-action-btn" @onclick="AdminResetCreateOrderForm">
                            <i class="bi bi-arrow-counterclockwise"></i> Reset
                        </button>
                    </div>
                </aside>
            </div>
        }
    </main>
</div>

@if (showReceiptModal)
{
    <div class="receipt-overlay" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(15, 32, 80, 0.6); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; z-index: 10000;" @onclick="CloseReceipt">
        <div class="receipt-modal" style="background: #fff; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.25); max-width: 620px; width: 90%; max-height: 85vh; display: flex; flex-direction: column; overflow: hidden; border: 1px solid #EDD9D0;" @onclick:stopPropagation="true">
            <div class="receipt-header" style="background: #8B1A1A; color: #fff; padding: 1.25rem 1.5rem; display: flex; justify-content: space-between; align-items: center;">
                <h3 style="margin: 0; font-size: 1.2rem; font-family: 'DM Sans', sans-serif; letter-spacing: 0.05em; color: #fff;">
                    @if (selectedRegularOrder != null)
                    {
                        <span>Order Receipt: ORD-@selectedRegularOrder.OrderId.ToString("D4")</span>
                    }
                    else if (selectedGuestOrder != null)
                    {
                        <span>Order Receipt: GORD-@selectedGuestOrder.GuestOrderId.ToString("D4")</span>
                    }
                </h3>
                <button class="receipt-close-btn" style="background: transparent; border: none; color: #fff; font-size: 1.8rem; cursor: pointer; line-height: 1; opacity: 0.8;" @onclick="CloseReceipt">&times;</button>
            </div>
            <div class="receipt-body" style="padding: 1.5rem; overflow-y: auto; font-size: 0.88rem; line-height: 1.5; color: #3C1F10;">
                @if (selectedRegularOrder != null)
                {
                    <div class="receipt-section-title">Customer Information</div>
                    <div class="receipt-meta-grid">
                        <div class="receipt-meta-item">
                            <label>Customer Name</label>
                            <span>@selectedRegularOrder.User?.FirstName @selectedRegularOrder.User?.LastName</span>
                        </div>
                        <div class="receipt-meta-item">
                            <label>Email Address</label>
                            <span>@selectedRegularOrder.User?.Email</span>
                        </div>
                        <div class="receipt-meta-item">
                            <label>Phone Number</label>
                            <span>@selectedRegularOrder.User?.PhoneNumber</span>
                        </div>
                        <div class="receipt-meta-item">
                            <label>Order Date</label>
                            <span>@(selectedRegularOrder.CreatedAt?.ToString("dd MMM yyyy HH:mm") ?? "N/A")</span>
                        </div>
                    </div>

                    <div class="receipt-meta-item mb-4">
                        <label>Shipping Address</label>
                        <span>@selectedRegularOrder.ShippingAddress</span>
                    </div>

                    <div class="receipt-section-title">Order Items</div>
                    <table class="receipt-table">
                        <thead>
                            <tr>
                                <th>Item Details</th>
                                <th>Qty</th>
                                <th class="money">Price</th>
                                <th class="money">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in selectedRegularOrder.OrderItems)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.Variant?.Product?.Name</strong>
                                        <div class="small text-muted">Size: @item.Variant?.Size | Color: @item.Variant?.Color</div>
                                    </td>
                                    <td>@item.Quantity</td>
                                    <td class="money">@item.PriceAtPurchase.ToString("N0") MMK</td>
                                    <td class="money">@((item.PriceAtPurchase * item.Quantity).ToString("N0")) MMK</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="receipt-total-row">
                        <span class="receipt-total-label">Total Amount</span>
                        <span class="receipt-total-val">@selectedRegularOrder.TotalAmount.ToString("N0") MMK</span>
                    </div>

                    <div class="receipt-section-title mt-4">Payment Details</div>
                    <div class="receipt-meta-grid">
                        <div class="receipt-meta-item">
                            <label>Payment Method</label>
                            <span class="pay-badge">@((selectedRegularOrder.Payments.FirstOrDefault()?.PaymentMethod ?? "COD").ToUpper())</span>
                        </div>
                        <div class="receipt-meta-item">
                            <label>Payment Status</label>
                            <span>@selectedRegularOrder.PaymentStatus</span>
                        </div>
                    </div>

                    var slipUrl = NormalizeSlipImageUrl(selectedRegularOrder.Payments.FirstOrDefault()?.SlipImageUrl);
                    @if (!string.IsNullOrEmpty(slipUrl))
                    {
                        <div class="receipt-slip-container">
                            <label class="small text-muted uppercase d-block">Payment Slip</label>
                            <a href="@slipUrl" target="_blank">
                                <img class="receipt-slip-image" src="@slipUrl" alt="Payment slip" />
                            </a>
                        </div>
                    }
                }
                else if (selectedGuestOrder != null)
                {
                    <div class="receipt-section-title">Guest Details</div>
                    <div class="receipt-meta-grid">
                        <div class="receipt-meta-item">
                            <label>Guest Name</label>
                            <span>@selectedGuestOrder.CustomerName</span>
                        </div>
                        <div class="receipt-meta-item">
                            <label>Phone Number</label>
                            <span>@selectedGuestOrder.PhoneNumber</span>
                        </div>
                        <div class="receipt-meta-item">
                            <label>Order Date</label>
                            <span>@selectedGuestOrder.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                        </div>
                        <div class="receipt-meta-item">
                            <label>Payment Method</label>
                            <span class="pay-badge">@((selectedGuestOrder.PaymentMethod ?? "COD").ToUpper())</span>
                        </div>
                    </div>

                    <div class="receipt-meta-item mb-4">
                        <label>Shipping Address</label>
                        <span>@selectedGuestOrder.ShippingAddress</span>
                    </div>

                    <div class="receipt-section-title">Order Items</div>
                    <table class="receipt-table">
                        <thead>
                            <tr>
                                <th>Item Details</th>
                                <th>Qty</th>
                                <th class="money">Price</th>
                                <th class="money">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in selectedGuestOrder.GuestOrderItems)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.Variant?.Product?.Name</strong>
                                        <div class="small text-muted">Size: @item.Variant?.Size | Color: @item.Variant?.Color</div>
                                    </td>
                                    <td>@item.Quantity</td>
                                    <td class="money">@item.PriceAtPurchase.ToString("N0") MMK</td>
                                    <td class="money">@((item.PriceAtPurchase * item.Quantity).ToString("N0")) MMK</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="receipt-total-row">
                        <span class="receipt-total-label">Total Amount</span>
                        <span class="receipt-total-val">@selectedGuestOrder.TotalAmount.ToString("N0") MMK</span>
                    </div>

                    <div class="receipt-section-title mt-4">Payment Details</div>
                    <div class="receipt-meta-grid">
                        <div class="receipt-meta-item">
                            <label>Payment Status</label>
                            <span>@PaymentBadge(selectedGuestOrder.PaymentStatus)</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
}
