                                <strong>No phone orders found.</strong>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive-wrapper">
                                <table class="table luxury-table">
                                    <thead>
                                        <tr>
                                            <th>Order ID</th>
                                            <th>Customer Name</th>
                                            <th>Phone</th>
                                            <th>Amount</th>
                                            <th>Payment Method</th>
                                            <th>Payment Status</th>
                                            <th>Fulfillment</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var go in PagedGuestOrders)
                                        {
                                            <tr style="cursor: pointer;" @onclick="() => OpenGuestReceipt(go)">
                                                <td @onclick:stopPropagation="true">
                                                    <a class="text-decoration-none fw-bold" style="color: var(--accent-main);" @onclick="() => OpenGuestReceipt(go)">
                                                        GORD-@go.GuestOrderId.ToString("D4")
                                                    </a>
