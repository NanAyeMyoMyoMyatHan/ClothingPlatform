                                                            <option value="Confirm" selected="@(NormalizeStatus(go.OrderStatus) == "Confirm")">Confirm</option>
                                                        </select>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        <Pagination CurrentPage="@guestOrderPage"
                                    TotalPages="@GuestOrderTotalPages"
                                    CurrentPageChanged="@ChangeGuestOrderPage" />
                    </section>
                }
            </div>
