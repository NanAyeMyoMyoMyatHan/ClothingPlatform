                                                <td><strong>@go.CustomerName</strong></td>
                                                <td>@go.PhoneNumber</td>
                                                <td><strong>@go.TotalAmount.ToString("N0") MMK</strong></td>
                                                <td><span class="badge bg-light text-dark border">@((go.PaymentMethod ?? "COD").ToUpper())</span></td>
                                                <td>@PaymentBadge(go.PaymentStatus)</td>
                                                <td @onclick:stopPropagation="true">
                                                    <span class="badge @StatusBadgeClass(go.OrderStatus) px-3 py-2 rounded-pill">@NormalizeStatus(go.OrderStatus)</span>
                                                </td>
                                                <td @onclick:stopPropagation="true">
                                                    @if (IsFinalStatus(go.OrderStatus))
