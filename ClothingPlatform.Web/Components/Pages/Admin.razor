                                <input type="search" class="luxury-input" style="padding-left: 36px; height: 42px;" placeholder="Search phone orders..." @bind="guestOrderSearch" @bind:event="oninput" />
                            </div>
                            <span class="text-muted small">Showing @filteredGuestOrders.Count phone orders</span>
                        </div>

                        @if (!PagedGuestOrders.Any())
