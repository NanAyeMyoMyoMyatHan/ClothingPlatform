@page "/dashboard"
@using ClothingPlatform.Web.Components.Partial
@inject IJSRuntime JSRuntime
@inject HttpClientServices HttpClientServices
@inject HttpClient Http
<style>
    /* -- Logout confirmation modal -- */
    .confirm-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw; /* Force full viewport width */
        height: 100vh; /* Force full viewport height */
        background: rgba(15, 32, 80, .45);
        /* The magic centering trio */
        display: flex;
        align-items: center; /* Centers vertically */
        justify-content: center; /* Centers horizontally */

        z-index: 9999; /* Keeps it on top of sidebars/navbars */
    }

    .confirm-modal {
        background: var(--white);
        border-radius: var(--radius-lg);
        padding: 1.8rem 2rem;
        max-width: 360px;
        width: 90%;
        text-align: center;
        box-shadow: var(--shadow-lg);
    }

    .confirm-icon {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: var(--red-light);
        color: var(--red);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin: 0 auto .9rem;
    }

    .confirm-title {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.25rem;
        color: var(--navy);
        margin-bottom: .4rem;
    }

    .confirm-text {
        font-size: .82rem;
        color: var(--slate);
        margin-bottom: 1.4rem;
        line-height: 1.5;
    }

    .confirm-actions {
        display: flex;
        gap: .7rem;
        justify-content: center;
    }

    .confirm-btn-cancel {
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
        background: var(--off-white);
        color: var(--slate);
        border: 1px solid var(--slate-border);
        border-radius: 8px;
        padding: .55rem 1.3rem;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: background var(--transition);
    }

        .confirm-btn-cancel:hover {
            background: #EDF1F6;
        }

    .confirm-btn-confirm {
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
        background: var(--red);
        color: #000000;
        border: none;
        border-radius: 8px;
        padding: .55rem 1.3rem;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: background var(--transition), transform var(--transition);
    }

        .confirm-btn-confirm:hover {
            background: #B91C1C;
            transform: translateY(-1px);
        }

    

    .btn-primary-rose {
        background: var(--rose);
        color: #F5ECD7;
        border: none;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.2em;
        font-weight: 500;
        text-transform: uppercase;
        padding: 14px 38px;
        cursor: pointer;
        transition: background 0.25s, transform 0.2s;
    }

        .btn-primary-rose:hover {
            background: #6B0F0F;
            transform: translateY(-1px);
        }

</style>

@if (!isPortalReady)
{
    <div class="portal-loading">
        <div class="portal-loading-card">
            <div class="portal-loading-mark">TB</div>
            <div>
                <h1>Loading portal</h1>
                <p>Preparing your shared workspace.</p>
            </div>
        </div>
    </div>
}
else
{
<div class="dashboard-container">
    <!-- ── SIDEBAR NAVIGATION ── -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <h3>Chic Boutique</h3>
            <span>@PortalShellLabel</span>
        </div>
        <ul class="nav-list">
            <li>
                <a class="nav-item-link @(activeView == "dashboard" ? "active" : "")" @onclick='() => SetView("dashboard")'>
                    <i class="bi bi-grid-1x2"></i>
                    Dashboard
                </a>
            </li>

            <li>
                <a class="nav-item-link @(IsProductsView ? "active" : "")" @onclick='() => SetView("products")'>
                    <i class="bi bi-bag"></i>
                    @ProductsNavLabel
                </a>
            </li>

            <li>
                <a class="nav-item-link @(activeView == "orders" ? "active" : "")" @onclick='() => SetView("orders")'>
                    <i class="bi bi-cart"></i>
                    Orders
                </a>
            </li>

            <li>
                <a class="nav-item-link @(activeView == "create-order" ? "active" : "")" @onclick='() => SetView("create-order")'>
                    <i class="bi bi-telephone-plus"></i>
                    Create Order
                </a>
            </li>

            @if (CanViewCustomers)
            {
            <li>
                <a class="nav-item-link @(activeView == "customers" ? "active" : "")" @onclick='() => SetView("customers")'>
                    <i class="bi bi-people"></i>
                    Customers
                </a>
            </li>
            }

            @if (CanManageStaff)
            {
            <li>
                <a class="nav-item-link @(activeView == "staffs" ? "active" : "")" @onclick='() => SetView("staffs")'>
                    <i class="bi bi-person-workspace"></i>
                    Staff Menu
                </a>
            </li>
            }

            @if (CanViewReports)
            {
            <li>
                <a class="nav-item-link @(activeView == "reports" ? "active" : "")" @onclick='() => SetView("reports")'>
                    <i class="bi bi-bar-chart-line"></i>
                    Admin Reports
                </a>
            </li>
            }

            <li>
                <a class="nav-item-link @(activeView == "profile" ? "active" : "")" @onclick='() => SetView("profile")'>
                    <i class="bi bi-person-circle"></i>
                    My Profile
                </a>
            </li>

            @if (Session.IsAdmin)
            {
            <li>
                <a class="nav-item-link @(activeView == "permissions" ? "active" : "")" @onclick='() => SetView("permissions")'>
                    <i class="bi bi-shield-lock"></i>
                    Permissions
                </a>
            </li>
            }

            <li class="mt-5">
                    <a class="nav-item-link text-danger" @onclick="RequestLogout">
                    <i class="bi bi-box-arrow-right text-danger"></i>
                    Sign Out
                </a>
                    @if (showLogoutConfirm)
                    {
                        <div class="confirm-overlay" @onclick="CancelLogout">
                            <div class="confirm-modal" @onclick:stopPropagation="true">
                                <div class="confirm-icon"><i class="bi bi-box-arrow-right"></i></div>
                                <div class="confirm-title">Log Out?</div>
                                <div class="confirm-text">Are you sure you want to leave the shared portal?</div>
                                <div class="confirm-actions">
                                    <button class="confirm-btn-cancel" @onclick="CancelLogout">Cancel</button>
                                    <LoadingButton Class="confirm-btn-confirm"
                                                   IsLoading="@isCustomerLoggingOut"
                                                   LoadingText="Signing Out..."
                                                   OnClick="ConfirmLogout">
                                        Yes, Log Out
                                    </LoadingButton>
                                </div>
                            </div>
                        </div>
                    }
            </li>
        </ul>
    </aside>

    <!-- ── MAIN WORKSPACE ── -->
    <main class="main-workspace">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="luxury-text m-0">@PortalHeadline</h1>
                <p class="text-muted m-0">Today is @DateTime.Now.ToString("dd MMM yyyy")</p>
            </div>
            <div>
                <LoadingButton Class="btn-luxury"
                               IsLoading="@IsAdminActionLoading(LoadDataAction)"
                               LoadingText="Refreshing..."
                               OnClick="@(() => RunAdminAction(LoadDataAction, LoadData))">
                    <i class="bi bi-arrow-clockwise"></i> Refresh
                </LoadingButton>
            </div>
        </div>

        <!-- Alerts -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-banner alert-banner-error">
                <i class="bi bi-exclamation-circle-fill me-2"></i> @errorMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert-banner alert-banner-success">
                <i class="bi bi-check-circle-fill me-2"></i> @successMessage
            </div>
        }

        @if (activeView == "dashboard")
        {
            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <div class="luxury-card luxury-card-clickable" @onclick='() => SetView(CanViewReports ? "reports" : "orders")'>
                        <div class="kpi-title">Revenue</div>
                        <h2 class="kpi-value">@TotalRevenue.ToString("N0") MMK</h2>
                        <div class="kpi-icon-box">
                            <i class="bi bi-cash-stack"></i>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="luxury-card luxury-card-clickable" @onclick='() => SetView("orders")'>
                        <div class="kpi-title">Total Orders</div>
                        <h2 class="kpi-value">@TotalOrders</h2>
                        <div class="kpi-icon-box">
                            <i class="bi bi-bag-check"></i>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="luxury-card luxury-card-clickable" @onclick='() => SetView("orders")'>
                        <div class="kpi-title">Pending Orders</div>
                        <h2 class="kpi-value">@PendingOrders</h2>
                        <div class="kpi-icon-box">
                            <i class="bi bi-clock-history"></i>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="luxury-card luxury-card-clickable" @onclick='() => SetView(CanViewCustomers ? "customers" : "orders")'>
                        <div class="kpi-title">@(CanViewCustomers ? "Customers" : "Phone Orders")</div>
                        <h2 class="kpi-value">@(CanViewCustomers ? TotalCustomers : allGuestOrders.Count)</h2>
                        <div class="kpi-icon-box">
                            <i class="bi @(CanViewCustomers ? "bi-people" : "bi-telephone")"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5 mb-3">
                <h3 class="m-0">Recent Orders Queue</h3>
                <button class="btn-luxury" @onclick='() => SetView("orders")'>View All Orders</button>
            </div>

            <div class="table-responsive-wrapper">
                <table class="table luxury-table">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Address</th>
                            <th>Total Amount</th>
                            <th>Status</th>
                            <th>Date Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Pagedorders.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">No orders found in the boutique queue.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var order in Pagedorders)
                            {
                                <tr>
                                    <td><strong>ORD-@order.OrderId.ToString("D4")</strong></td>
                                    <td>@order.User.FirstName @order.User.LastName</td>
                                    <td>@order.ShippingAddress</td>
                                    <td>@order.TotalAmount.ToString("N0") MMK</td>
                                    <td>
                                        <span class="badge @StatusBadgeClass(order.OrderStatus) px-3 py-2 rounded-pill">@NormalizeStatus(order.OrderStatus)</span>
                                    </td>
                                    <td>@(order.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                <Pagination CurrentPage="@orderPage"
                            TotalPages="@OrderTotalPages"
                            CurrentPageChanged="@ChangeOrderPage" />
            </div>
        }

        
        else if (activeView == "products")
        {
            <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-4">
                <div>
                    <h1 class="mb-1">Catalog Items</h1>
                    <p class="text-muted mb-0">Manage the boutique product list and stock overview.</p>
                </div>

                @if (CanManageProducts)
                {
                    <button type="button" class="btn-luxury-solid" @onclick="StartNewProduct">+ New product</button>
                }
            </div>

            <div class="table-responsive-wrapper">
                <h4>Catalog Items</h4>
                <table class="table luxury-table mt-3">
                    <thead>
                        <tr>
                            <th>Thumbnail</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Base Price</th>
                            <th>Variants</th>
                            <th>Quantity</th>
                            @if (CanManageProducts)
                            {
                                <th>Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (!PagedProducts.Any())
                        {
                            <tr>
                                <td colspan="@(CanManageProducts ? 7 : 6)" class="text-center py-4 text-muted">No products registered. Create one to display.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var prod in PagedProducts)
                            {
                                var raw = prod.ProductImages?
                                .FirstOrDefault(i => i.IsPrimary == true)?.ImageUrl?.Trim() ?? "";

                                var imgSrc = string.IsNullOrWhiteSpace(raw)
                                    ? "/images/products/default.jpg"
                                    : raw.StartsWith("http")
                                        ? raw
                                        : $"/images/products/{raw.Replace("images/products/", "").TrimStart('/')}";
                                <tr>
                                    <td>
                                        <img src="@imgSrc" alt="@prod.Name" style="width:60px;height:60px;object-fit:cover;" />
                                    </td>
                                    <td>
                                        <strong>@prod.Name</strong>
                                        <p class="text-muted small m-0 text-truncate" style="max-width: 200px;">@prod.Description</p>
                                    </td>
                                    <td>@(prod.Category?.Name ?? "No Category")</td>
                                    <td>@prod.BasePrice.ToString("N0") MMK</td>
                                    <td>
                                        <span class="badge bg-secondary">@prod.ProductVariants.Count variants</span>
                                    </td>
                                    <td>
                                        @prod.ProductVariants.Sum(v => v.StockQuantity)
                                    </td>
                                    @if (CanManageProducts)
                                    {
                                        <td>
                                            <LoadingButton Class="btn btn-sm btn-outline-primary me-1"
                                                           IsLoading="@IsAdminActionLoading(EditProductAction(prod.ProductId))"
                                                           OnClick="@(() => RunAdminAction(EditProductAction(prod.ProductId), () => EditProduct(prod)))">
                                                <i class="bi bi-pencil"></i>
                                            </LoadingButton>

                                            <LoadingButton Class="btn btn-sm btn-outline-danger"
                                                           IsLoading="@IsAdminActionLoading(DeleteProductAction(prod.ProductId))"
                                                           OnClick="@(() => HandleDeleteClick(prod.ProductId))">
                                                <i class="bi bi-trash"></i>
                                            </LoadingButton>
                                        </td>
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                <ConfirmModal @ref="confirmModal"
                              Title="Delete Product"
                              Message="@UiMessages.Admin.DeleteProductConfirm"
                              ConfirmText="Delete"
                              CancelText="Cancel" />
                <Pagination CurrentPage="@productPage"
                            TotalPages="@ProductTotalPages"
                            CurrentPageChanged="@OnProductPageChanged" />
            </div>
        }
        else if (activeView == "products-new")
        {
            <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-4">
                <div>
                    <h1 class="mb-1">@(editingProduct == null ? "Add Atelier Product" : "Edit Product")</h1>
                    <p class="text-muted mb-0">Fill in the product details and publish them to the catalog.</p>
                </div>

                <button type="button" class="btn-luxury" @onclick="BackToProducts">Back to products</button>
            </div>

            @if (CanManageProducts)
            {
                <div class="d-grid gap-4" style="max-width: 980px;">
                    <div class="luxury-card">
                        <h4 class="mb-3">Product Details</h4>

                        <div class="mb-3">
                            <label class="form-label text-muted small uppercase fw-bold">Product Name</label>
                            <input type="text" class="luxury-input" @bind="model.Name" placeholder="e.g., Silk Slip Dress" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small uppercase fw-bold">Description</label>
                            <textarea class="luxury-input" @bind="model.Description" rows="3" placeholder="Describe this luxury garment..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small uppercase fw-bold">Base Price (MMK)</label>
                            <input type="text" class="luxury-input" @bind-value="model.BasePrice" placeholder="e.g., 75,000" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small uppercase fw-bold">Category</label>
                            <select class="luxury-select" @bind="newProductCategoryId">
                                <option value="0">-- Select Category --</option>
                                @foreach (var cat in allCategories)
                                {
                                    <option value="@cat.CategoryId">@cat.Name</option>
                                }
                            </select>
                        </div>

                        <div class="mb-0">
                            <label class="form-label text-muted small uppercase fw-bold">Upload Product Image</label>
                            <InputFile OnChange="HandleFileSelected"
                                       class="form-control"
                                       accept=".jpg,.jpeg,.png"
                                       title="Upload Product Image" />

                            @if (!string.IsNullOrEmpty(previewImageUrl))
                            {
                                <img src="@previewImageUrl" style="width:100px; height:100px; object-fit:cover; margin-top:8px;" />
                            }
                        </div>
                    </div>

                    <div class="luxury-card">
                        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
                            <h4 class="mb-0">Variant Details</h4>
                            <span class="badge bg-secondary px-3 py-2">Total quantity: @TotalVariantQuantity</span>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex flex-wrap gap-3">
                                @foreach (var draft in variantDrafts)
                                {
                                    <label class="d-inline-flex align-items-center gap-2 px-3 py-2 border rounded-3">
                                        <input type="checkbox"
                                               class="form-check-input m-0"
                                               checked="@draft.IsSelected"
                                               @onchange="e => ToggleVariantSize(draft, e)" />
                                        <span class="fw-bold">@draft.Size</span>
                                    </label>
                                }
                            </div>
                        </div>

                        @if (!variantDrafts.Any(v => v.IsSelected))
                        {
                            <div class="text-muted">Select a size to add its color variants.</div>
                        }
                        else
                        {
                            <div class="d-grid gap-3">
                                @foreach (var draft in variantDrafts.Where(v => v.IsSelected))
                                {
                                    <div class="border rounded-3 p-3">
                                        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                                            <div class="fw-bold">@draft.Size</div>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => AddVariantEntry(draft))">Add color</button>
                                        </div>

                                        <div class="table-responsive">
                                            <table class="table luxury-table align-middle mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>Color</th>
                                                        <th>Quantity</th>
                                                        <th>Price Modifier</th>
                                                        <th>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var entry in draft.Entries)
                                                    {
                                                        <tr>
                                                            <td>
                                                                <input type="text"
                                                                       class="luxury-input"
                                                                       @bind="entry.Color"
                                                                       placeholder="e.g., Pink" />
                                                            </td>
                                                            <td style="max-width: 150px;">
                                                                <input type="number"
                                                                       class="luxury-input"
                                                                       @bind="entry.StockQuantity"
                                                                       min="0" />
                                                            </td>
                                                            <td style="max-width: 180px;">
                                                                <input type="number"
                                                                       class="luxury-input"
                                                                       @bind="entry.PriceModifier"
                                                                       step="0.01"
                                                                       min="0" />
                                                            </td>
                                                            <td style="width: 90px;">
                                                                <button type="button"
                                                                        class="btn btn-sm btn-outline-danger"
                                                                        @onclick="@(() => RemoveVariantEntry(draft, entry))">
                                                                    Remove
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        <div class="mt-3 d-flex flex-wrap gap-2">
                            <span class="text-muted">Selected sizes: @variantDrafts.Count(v => v.IsSelected)</span>
                            <span class="text-muted">Total quantity will be shown in the product list.</span>
                        </div>
                    </div>

                    <div class="mt-4 d-grid gap-2">
                        @if (editingProduct == null)
                        {
                            <LoadingButton Class="btn-luxury-solid"
                                           IsLoading="@IsAdminActionLoading(CreateProductAction)"
                                           LoadingText="Adding..."
                                           OnClick="@(() => RunAdminAction(CreateProductAction, HandleCreateProduct))">
                                Add Product
                            </LoadingButton>
                        }
                        else
                        {
                            <LoadingButton Class="btn-luxury-solid"
                                           IsLoading="@IsAdminActionLoading(UpdateProductAction)"
                                           LoadingText="Saving..."
                                           OnClick="@(() => RunAdminAction(UpdateProductAction, HandleUpdateProduct))">
                                Save Changes
                            </LoadingButton>
                        }

                        <button type="button" class="btn-luxury" @onclick="BackToProducts">Cancel</button>
                    </div>
                </div>
            }
            else
            {
                <div class="luxury-card">
                    <h4>Inventory Overview</h4>
                    <p class="text-muted mb-0">Staff accounts can review the live catalog and stock counts here. Product creation and catalog edits stay with admin accounts.</p>
                </div>
            }
        }

       
       
        else if (activeView == "orders")
        {
            <div class="ops-workspace">
                <div class="om-tabs" role="tablist" aria-label="Order type">
                    <button type="button" class="om-tab @(ordersTab == "regular" ? "om-tab-active" : "")"
                            @onclick='() => { ordersTab = "regular"; errorMessage = ""; successMessage = ""; }'>
                        <i class="bi bi-bag"></i>
                        <span>Regular Orders</span>
                        <strong>@allOrders.Count</strong>
                    </button>
                    <button type="button" class="om-tab @(ordersTab == "guest" ? "om-tab-active" : "")"
                            @onclick='() => { ordersTab = "guest"; errorMessage = ""; successMessage = ""; }'>
                        <i class="bi bi-telephone"></i>
                        <span>Phone / Guest</span>
                        <strong>@allGuestOrders.Count</strong>
                    </button>
                </div>

                @if (ordersTab == "regular")
                {
                    <section class="ops-section p-0">
                        <div class="ops-filter-row mb-3">
                            <button type="button" class="filter-chip @(string.IsNullOrWhiteSpace(orderFilter) || orderFilter == "All" ? "active" : "")" @onclick='() => FilterOrders("All")'>
                                <strong>@allOrders.Count</strong><span>All</span>
                            </button>
                            <button type="button" class="filter-chip @(orderFilter == "Pending" ? "active" : "")" @onclick='() => FilterOrders("Pending")'>
                                <strong>@allOrders.Count(o => NormalizeStatus(o.OrderStatus) == "Pending")</strong><span>Pending</span>
                            </button>
                            <button type="button" class="filter-chip @(orderFilter == "Processing" ? "active" : "")" @onclick='() => FilterOrders("Processing")'>
                                <strong>@allOrders.Count(o => NormalizeStatus(o.OrderStatus) == "Processing")</strong><span>Processing</span>
                            </button>
                            <button type="button" class="filter-chip @(orderFilter == "Confirm" ? "active" : "")" @onclick='() => FilterOrders("Confirm")'>
                                <strong>@allOrders.Count(o => NormalizeStatus(o.OrderStatus) == "Confirm")</strong><span>Confirm</span>
                            </button>
                        </div>

                        <div class="ops-toolbar d-flex gap-3 mb-3 align-items-center justify-content-between">
                            <div class="staff-search-control flex-grow-1" style="max-width: 480px; position: relative;">
                                <i class="bi bi-search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
