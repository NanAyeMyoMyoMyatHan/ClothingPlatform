@page "/staff/stock-control"
@layout Layout.StaffPortalLayout
@inherits StaffPortalPageBase
@using ClothingPlatform.Web.Components.Partial

<div class="page-header">
                    <div class="page-sub">Operations</div>
                    <h1 class="page-title">Stock Control (Inventory)</h1>
                    <div class="page-divider"></div>
                </div>
                <div class="table-card">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>SKU</th>
                                <th>Product Name</th>
                                <th>Size</th>
                                <th>Color</th>
                                <th>Qty</th>
                                <th>Stock Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!PagedInventoryVariants.Any())
                            {
                                <tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--slate-light)">No inventory items found.</td></tr>
                            }
                            else
                            {
                                @for (int i = 0; i < PagedInventoryVariants.Count; i++)
                                {
                                    var variant = PagedInventoryVariants[i];
                                    bool isLow = variant.StockQuantity < 5;
                                    <tr>
                                        <td>@((inventoryPage - 1) * inventoryPageSize + i + 1)</td>
                                        <td style="font-family:'DM Sans',sans-serif;font-weight:500">@variant.Sku</td>
                                        <td>@variant.Product.Name</td>
                                        <td>@variant.Size</td>
                                        <td>@variant.Color</td>
                                        <td class="qty-display">@variant.StockQuantity</td>
                                        <td>
                                            @if (variant.StockQuantity == 0)
                                            {
                                                <span class="low-stock-badge" style="background:var(--red-light);color:var(--red)">Out of Stock</span>
                                            }
                                            else if (isLow)
                                            {
                                                <span class="low-stock-badge">Low Stock</span>
                                            }
                                            else
                                            {
                                                <span class="in-stock-badge">In Stock</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <Pagination CurrentPage="@inventoryPage" TotalPages="@InventoryTotalPages" CurrentPageChanged="@ChangeInventoryPage" />
