<div class="modal-overlay @(isModalOpen ? "open" : "")">
    @if (modalProduct != null)
    {
        var primaryImg = NormalizeImageUrl(modalProduct.ImageDto);

        <div class="product-modal">
            <button class="modal-close" @onclick="CloseQuickView">
                <i class="bi bi-x-lg"></i>
            </button>

            <div class="modal-img-col">
                <FallbackImage Src="@primaryImg" Alt="@modalProduct.Name" />
            </div>

            <div class="modal-info-col">
                <p class="modal-collection">@modalProduct.CategoryName</p>
                <h2 class="modal-name">@modalProduct.Name</h2>
                <p class="modal-price">
                    @modalProduct.SalePrice.ToString("N0")
                    <span class="currency">MMK</span>
                </p>
                <p class="modal-desc">@modalProduct.Description</p>


                @if(modalProduct.VariantsDto != null)
                {
                    <label class="option-label">Size Chart</label>
                    <div class="size-btns">
                        @foreach (var size in modalProduct.VariantsDto.Select(v => v.Size).Distinct())
                        {
                            <button class="size-btn @(selectedSize == size ? "selected" : "")" @onclick="() => SelectSize(size)">@size</button>
                        }
                    </div>

                    <label class="option-label">Select Color</label>
                    <div class="color-btns">
                        @foreach (var color in modalProduct.VariantsDto.Select(v => v.Color).Distinct())
                        {
                            <button class="size-btn @(selectedColor == color ? "selected" : "")" @onclick="() => SelectColor(color)">@color</button>
                        }
                    </div>
                }
                else
                {
                    <p>There is no size and color</p>
                }

                @if (!string.IsNullOrEmpty(modalErrorMessage))
                {
                    <p class="modal-error">
                        <i class="bi bi-exclamation-triangle"></i> @modalErrorMessage
                    </p>
                }

                <div class="modal-buy-actions">
                    <div class="modal-qty-row">
                        <span class="option-label mb-0">Quantity</span>
                        <div class="cart-qty">
                            <button class="qty-btn" @onclick="() => ChangeSelectedQuantity(-1)">-</button>
                            <span class="qty-num">@selectedQuantity</span>
                            <button class="qty-btn" @onclick="() => ChangeSelectedQuantity(1)">+</button>
                        </div>
                    </div>
                    <LoadingButton Class="btn-add-bag"
                                   IsLoading="@isAddingToBag"
                                   LoadingText="Adding..."
                                   OnClick="AddToBagUnified">
                        Add to Bag
                    </LoadingButton>
                    <ConfirmModal @ref="confirmModal" />
                </div>
            </div>
        </div>
    }
</div>

<!-- --------------- CART DRAWER --------------- -->
<div class="cart-backdrop mt-3 @(isCartOpen ? "open" : "")" @onclick="ToggleCart"></div>
<div class="cart-drawer @(isCartOpen ? "open" : "")">
    <div class="cart-header">
        <span class="cart-title">Shopping Bag</span>
        <button class="cart-close" @onclick="ToggleCart"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="cart-body">
        @if (!cart.Any())
        {
            <div class="cart-empty">
                <i class="bi bi-bag-x" style="font-size:3rem; color:var(--rose-light);"></i>
                <p class="mt-3">Your shopping bag is empty.</p>
            </div>
        }
        else
        {
            @foreach (var item in cart)
            {
                <div class="cart-item">
                    <FallbackImage Src="@item.ImgUrl" Alt="@item.Name" CssClass="cart-item-img" />
                    <div class="cart-item-info">
                        <p class="cart-item-name">@item.Name</p>
                        <p class="cart-item-meta">@item.Size · @item.Color</p>
                        <div class="cart-qty">
                            <LoadingButton Class="qty-btn"
                                                   IsLoading="@IsCartItemBusy(item.CartItemId)"
                                                   Disabled="@IsCartItemBusy(item.CartItemId)"
                                                   OnClick="@(() => UpdateQty(item, -1))">-</LoadingButton>
                            <span class="qty-num">@item.Qty</span>
                            <LoadingButton Class="qty-btn"
                                                   IsLoading="@IsCartItemBusy(item.CartItemId)"
                                                   Disabled="@IsCartItemBusy(item.CartItemId)"
                                                   OnClick="@(() => UpdateQty(item, 1))">+</LoadingButton>
                        </div>
                    </div>
                    <div class="d-flex flex-column align-items-end justify-content-between">
                        <LoadingButton Class="cart-item-remove"
                                               IsLoading="@IsCartItemBusy(item.CartItemId)"
                                               Disabled="@IsCartItemBusy(item.CartItemId)"
                                               OnClick="@(() => RemoveItem(item))">
                            <i class="bi bi-trash"></i>
                        </LoadingButton>
                        <span class="cart-item-price">@((item.Price * item.Qty).ToString("N0")) MMK</span>
                    </div>
                </div>
            }
        }
    </div>
    <div class="cart-footer">
        <div class="cart-subtotal-row">
            <span class="cart-subtotal-label">Subtotal</span>
            <span class="cart-subtotal-val">@CartTotal.ToString("N0") MMK</span>
        </div>
        <p class="cart-note">Fulfillment and shipping calculated at checkout.</p>
        <button class="btn-checkout" @onclick="GoCheckout">Proceed to Checkout</button>
    </div>
</div>

<!-- --------------- SUCCESS OVERLAY --------------- -->
<div class="success-overlay @(isSuccessOpen ? "open" : "")">
    <div class="success-icon"><i class="bi bi-check-lg"></i></div>
    <h2 class="success-title">Order Confirmed!</h2>
    <p class="success-sub">
        Thank you for your purchase. We have received your order.
        @if (selectedPayment == "cod")
        {
            <span>Our shipping coordinator will call you shortly to confirm delivery details.</span>
        }
        else
        {
            <span>Your bank payment screenshot slip has been queued for validation. We will dispatch within 2 hours.</span>
        }
        <br /><br />
        <span style="display:inline-block;background:var(--rose-pale);border:1px solid var(--rose-light);padding:8px 16px;color:var(--charcoal);font-weight:500;font-size:0.8rem;letter-spacing:0.04em;">
            ?IF ORDER CONFIRM, YOU EARNED @pointsEarnedInOrder.ToString("N0") LOYALTY POINTS!
        </span>
    </p>
    <p class="success-order-id">ORDER #@confirmedOrderId</p>
    <LoadingButton Class="btn-continue"
                   IsLoading="@isContinuingAfterOrder"
                   LoadingText="Loading..."
                   OnClick="AfterOrder">
        Continue Shopping
    </LoadingButton>
</div>

<!-- Toast container -->
<div class="toast-wrap">
    @foreach (var toast in toasts)
    {
        <div class="toast-msg">
            <i class="bi bi-check-circle-fill"></i>
            <span>@toast.Text</span>
        </div>
    }
</div>


