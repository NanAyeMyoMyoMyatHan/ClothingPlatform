    <SectionOutlet SectionName="custom-css" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<style>
    .pag {
        display: flex;
        align-items: center;
        justify-content: center; /* add this */
        gap: 4px;
        flex-wrap: wrap;
    }

    .pag-btn {
        min-width: 36px;
        height: 36px;
        padding: 0 10px;
        border: 0.5px solid #e0ddd5;
        background: #fff;
        color: #1a1a1a;
        border-radius: 8px;
        font-size: 14px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s, border-color 0.15s;
        font-family: inherit;
    }

        .pag-btn:hover:not(.disabled):not(.active) {
            background: #f5f4f0;
            border-color: #c0bdb5;
        }

        .pag-btn.active {
            background: #534AB7;
            border-color: #534AB7;
            color: #fff;
            font-weight: 500;
        }

        .pag-btn.disabled {
            color: #aaa;
            cursor: default;
            pointer-events: none;
        }

    .pag-sep {
        min-width: 32px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #aaa;
        font-size: 14px;
    }
</style>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
