@page "/admin"

<style>
  :root {
    --bg-primary: #111111;
    --bg-secondary: #1A1A1A;
    --bg-card: #1F1F1F;
    --bg-sidebar: #141414;
    --gold: #D4AF37;
    --gold-light: #E8C96D;
    --gold-muted: rgba(212,175,55,0.15);
    --rose: #E8B4B4;
    --rose-muted: rgba(232,180,180,0.12);
    --white: #FFFFFF;
    --text-primary: #F0EDE8;
    --text-secondary: #9A9490;
    --text-muted: #5A5856;
    --border: rgba(212,175,55,0.12);
    --border-light: rgba(255,255,255,0.06);
    --danger: #C0392B;
    --success: #2E7D32;
    --warning: #B7770D;
    --sidebar-width: 260px;
    --transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── SIDEBAR ── */
  #sidebar {
    position: fixed;
    top: 0; left: 0;
    width: var(--sidebar-width);
    height: 100vh;
    background: var(--bg-sidebar);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    z-index: 100;
    transition: var(--transition);
  }

  .sidebar-brand {
    padding: 32px 24px 24px;
    border-bottom: 1px solid var(--border);
  }

  .sidebar-brand .brand-mark {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 2px;
    text-transform: uppercase;
    line-height: 1.1;
  }

  .sidebar-brand .brand-sub {
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-top: 4px;
  }

  .sidebar-nav {
    flex: 1;
    padding: 16px 0;
    overflow-y: auto;
  }

  .nav-section-label {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 16px 24px 8px;
  }

  .nav-item-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 24px;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.3px;
    cursor: pointer;
    transition: var(--transition);
    border-left: 2px solid transparent;
    position: relative;
  }

  .nav-item-link:hover {
    color: var(--text-primary);
    background: rgba(255,255,255,0.03);
    border-left-color: var(--border);
  }

  .nav-item-link.active {
    color: var(--gold);
    background: var(--gold-muted);
    border-left-color: var(--gold);
  }

  .nav-item-link .nav-icon {
    width: 16px;
    text-align: center;
    font-size: 13px;
    opacity: 0.8;
  }

  .sidebar-footer {
    padding: 16px 24px 24px;
    border-top: 1px solid var(--border);
  }

  .admin-badge {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .admin-avatar {
    width: 34px; height: 34px;
    background: linear-gradient(135deg, var(--gold), var(--rose));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 14px;
    font-weight: 700;
    color: #111;
    flex-shrink: 0;
  }

  .admin-info .admin-name {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .admin-info .admin-role {
    font-size: 10px;
    color: var(--gold);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* ── MAIN CONTENT ── */
  #main-content {
    margin-left: var(--sidebar-width);
    min-height: 100vh;
    background: var(--bg-primary);
  }

  .topbar {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-light);
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .topbar-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: 0.5px;
  }

  .topbar-subtitle {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.5px;
  }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .topbar-date {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.5px;
  }

  .content-area {
    padding: 32px;
  }

  /* ── KPI CARDS ── */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 36px;
  }

  .kpi-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 24px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: var(--transition);
  }

  .kpi-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), transparent);
    opacity: 0;
    transition: var(--transition);
  }

  .kpi-card:hover {
    border-color: var(--border);
    transform: translateY(-1px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }

  .kpi-card:hover::before { opacity: 1; }

  .kpi-label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .kpi-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 36px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1;
    margin-bottom: 8px;
  }

  .kpi-value.gold { color: var(--gold); }
  .kpi-value.rose { color: var(--rose); }

  .kpi-delta {
    font-size: 11px;
    color: var(--text-muted);
  }

  .kpi-icon {
    position: absolute;
    top: 20px; right: 20px;
    font-size: 28px;
    opacity: 0.07;
    color: var(--gold);
  }

  /* ── SECTION HEADERS ── */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: 0.3px;
  }

  .section-title span {
    color: var(--gold);
  }

  /* ── TABLES ── */
  .luxury-table-wrap {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    overflow: hidden;
  }

  .luxury-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .luxury-table thead {
    background: rgba(212,175,55,0.06);
    border-bottom: 1px solid var(--border);
  }

  .luxury-table thead th {
    padding: 14px 20px;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 500;
    white-space: nowrap;
  }

  .luxury-table tbody tr {
    border-bottom: 1px solid var(--border-light);
    transition: var(--transition);
  }

  .luxury-table tbody tr:last-child { border-bottom: none; }

  .luxury-table tbody tr:hover {
    background: rgba(255,255,255,0.02);
  }

  .luxury-table tbody td {
    padding: 14px 20px;
    color: var(--text-secondary);
    vertical-align: middle;
  }

  .luxury-table tbody td.primary {
    color: var(--text-primary);
    font-weight: 500;
  }

  /* ── BADGES ── */
  .badge-luxury {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 600;
  }

  .badge-gold { background: var(--gold-muted); color: var(--gold); border: 1px solid rgba(212,175,55,0.25); }
  .badge-rose { background: var(--rose-muted); color: var(--rose); border: 1px solid rgba(232,180,180,0.25); }
  .badge-green { background: rgba(46,125,50,0.15); color: #81C784; border: 1px solid rgba(46,125,50,0.3); }
  .badge-blue { background: rgba(30,136,229,0.12); color: #64B5F6; border: 1px solid rgba(30,136,229,0.25); }
  .badge-red { background: rgba(192,57,43,0.12); color: #EF9A9A; border: 1px solid rgba(192,57,43,0.25); }
  .badge-muted { background: rgba(90,88,86,0.3); color: var(--text-muted); border: 1px solid rgba(90,88,86,0.4); }
  .badge-warning { background: rgba(183,119,13,0.15); color: #FFD54F; border: 1px solid rgba(183,119,13,0.3); }

  /* ── BUTTONS ── */
  .btn-luxury {
    background: linear-gradient(135deg, var(--gold), #B8960F);
    color: #111;
    border: none;
    padding: 9px 20px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: var(--transition);
  }

  .btn-luxury:hover {
    background: linear-gradient(135deg, var(--gold-light), var(--gold));
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(212,175,55,0.3);
  }

  .btn-ghost {
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-light);
    padding: 7px 16px;
    border-radius: 4px;
    font-size: 11px;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: var(--transition);
  }

  .btn-ghost:hover {
    color: var(--text-primary);
    border-color: var(--border);
    background: rgba(255,255,255,0.03);
  }

  .btn-danger-ghost {
    background: transparent;
    color: #EF9A9A;
    border: 1px solid rgba(192,57,43,0.25);
    padding: 5px 12px;
    border-radius: 4px;
    font-size: 10px;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: var(--transition);
  }

  .btn-danger-ghost:hover {
    background: rgba(192,57,43,0.1);
    border-color: rgba(192,57,43,0.5);
  }

  .btn-icon {
    background: transparent;
    border: 1px solid var(--border-light);
    color: var(--text-secondary);
    width: 30px; height: 30px;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
    font-size: 11px;
  }

  .btn-icon:hover {
    color: var(--gold);
    border-color: var(--border);
  }

  /* ── FORMS ── */
  .luxury-form-group {
    margin-bottom: 20px;
  }

  .luxury-label {
    display: block;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .luxury-input, .luxury-select {
    width: 100%;
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    color: var(--text-primary);
    padding: 10px 14px;
    border-radius: 4px;
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    transition: var(--transition);
    outline: none;
    appearance: none;
  }

  .luxury-input:focus, .luxury-select:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 2px rgba(212,175,55,0.1);
  }

  .luxury-select option {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  /* ── MODALS ── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(4px);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .modal-overlay.active { display: flex; }

  .modal-box {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
    width: 100%;
    max-width: 520px;
    max-height: 90vh;
    overflow-y: auto;
    padding: 32px;
    position: relative;
    animation: modalIn 0.25s ease;
  }

  @@keyframes modalIn {
    from { opacity: 0; transform: translateY(12px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .modal-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .modal-sub {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.5px;
    margin-bottom: 24px;
  }

  .modal-close {
    position: absolute;
    top: 20px; right: 20px;
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 16px;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 4px;
    transition: var(--transition);
  }

  .modal-close:hover { color: var(--text-primary); background: var(--border-light); }

  /* ── STATUS SELECT ── */
  .status-select {
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    color: var(--text-secondary);
    padding: 5px 10px;
    border-radius: 4px;
    font-size: 11px;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    outline: none;
  }

  .status-select:focus { border-color: var(--gold); }

  /* ── LOW STOCK ROW ── */
  .low-stock-row { background: rgba(183,119,13,0.05) !important; }
  .low-stock-indicator {
    display: inline-block;
    width: 6px; height: 6px;
    background: #FFD54F;
    border-radius: 50%;
    margin-right: 6px;
    animation: pulse 1.5s infinite;
  }

  @@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ── PROFILE PAGE ── */
  .profile-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 36px;
    max-width: 600px;
  }

  .profile-avatar-lg {
    width: 72px; height: 72px;
    background: linear-gradient(135deg, var(--gold), var(--rose));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 700;
    color: #111;
    margin-bottom: 20px;
  }

  .logout-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: 1px solid rgba(192,57,43,0.3);
    color: #EF9A9A;
    padding: 12px 24px;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: var(--transition);
    margin-top: 32px;
    width: 100%;
    justify-content: center;
    letter-spacing: 0.5px;
  }

  .logout-btn:hover {
    background: rgba(192,57,43,0.1);
    border-color: rgba(192,57,43,0.6);
    color: #FFCDD2;
  }

  /* ── LOGOUT SCREEN ── */
  #logout-screen {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--bg-primary);
    z-index: 9999;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }

  #logout-screen.active { display: flex; }

  .logout-icon {
    width: 80px; height: 80px;
    border-radius: 50%;
    background: var(--gold-muted);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    color: var(--gold);
    margin-bottom: 8px;
  }

  .logout-msg {
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px;
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: 1px;
  }

  .logout-sub {
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* ── FULFILLMENT LOG ── */
  .timeline-item {
    display: flex;
    gap: 16px;
    padding-bottom: 20px;
    position: relative;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: 16px; top: 32px;
    bottom: 0;
    width: 1px;
    background: var(--border-light);
  }

  .timeline-item:last-child::before { display: none; }

  .timeline-dot {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: var(--gold-muted);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: var(--gold);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .timeline-body { flex: 1; }

  .timeline-title { font-size: 13px; color: var(--text-primary); font-weight: 500; }
  .timeline-meta { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

  /* ── PAYMENT SLIP MODAL ── */
  .slip-preview {
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-radius: 6px;
    padding: 28px;
    text-align: center;
  }

  .slip-amount {
    font-family: 'Cormorant Garamond', serif;
    font-size: 42px;
    font-weight: 600;
    color: var(--gold);
  }

  .slip-divider {
    border-top: 1px solid var(--border-light);
    margin: 16px 0;
  }

  .slip-row {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    margin-bottom: 8px;
    color: var(--text-secondary);
  }

  .slip-row span:last-child { color: var(--text-primary); }

  /* ── VIEWS ── */
  .view { display: none; }
  .view.active { display: block; }

  /* ── DIVIDER ── */
  .gold-divider {
    width: 40px; height: 1px;
    background: linear-gradient(90deg, var(--gold), transparent);
    margin: 8px 0 16px;
  }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 2px; }

  /* ── TOAST ── */
  #toast {
    position: fixed;
    bottom: 32px; right: 32px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--gold);
    border-radius: 6px;
    padding: 14px 20px;
    font-size: 13px;
    color: var(--text-primary);
    z-index: 9000;
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.3s ease;
    pointer-events: none;
    min-width: 260px;
  }

  #toast.show {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── STATS MINI ── */
  .mini-stat {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: var(--text-muted);
  }

  .mini-stat-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
  }

  @@media (max-width: 1200px) {
    .kpi-grid { grid-template-columns: repeat(2,1fr); }
  }
</style>

<body>

<!-- ═══════════════════════════════════════
     LOGOUT SCREEN
═══════════════════════════════════════ -->
<div id="logout-screen">
  <div class="logout-icon"><i class="fas fa-feather-alt"></i></div>
  <div class="logout-msg">Session Ended</div>
  <div class="logout-sub">Logged Out Successfully</div>
  <p style="font-size:12px;color:var(--text-muted);margin-top:8px;">You have been securely signed out of The Boutique Owner Portal.</p>
</div>

<!-- ═══════════════════════════════════════
     SIDEBAR
═══════════════════════════════════════ -->
<nav id="sidebar">
  <div class="sidebar-brand">
    <div class="brand-mark">The Boutique</div>
    <div class="brand-sub">Owner Portal</div>
  </div>

  <div class="sidebar-nav">
    <div class="nav-section-label">Operations</div>
    <a class="nav-item-link active" data-view="dashboard" onclick="navigate('dashboard')">
      <span class="nav-icon"><i class="fas fa-chart-line"></i></span>
      Business Overview
    </a>
    <a class="nav-item-link" data-view="orders" onclick="navigate('orders')">
      <span class="nav-icon"><i class="fas fa-receipt"></i></span>
      Order Management
    </a>

    <div class="nav-section-label">Store</div>
    <a class="nav-item-link" data-view="products" onclick="navigate('products')">
      <span class="nav-icon"><i class="fas fa-layer-group"></i></span>
      Product Catalog
    </a>
    <a class="nav-item-link" data-view="staff" onclick="navigate('staff')">
      <span class="nav-icon"><i class="fas fa-users"></i></span>
      Staff Members
    </a>
    <a class="nav-item-link" data-view="fulfillment" onclick="navigate('fulfillment')">
      <span class="nav-icon"><i class="fas fa-clock-rotate-left"></i></span>
      Fulfillment Log
    </a>

    <div class="nav-section-label">Account</div>
    <a class="nav-item-link" data-view="profile" onclick="navigate('profile')">
      <span class="nav-icon"><i class="fas fa-user-circle"></i></span>
      My Profile
