@page "/admin"
@inject IJSRuntime JSRuntime
@inject HttpClientServices HttpClientServices

<style>
    :root {
        /* 👇 အရောင်ဒီဇိုင်းသစ်များ - Soft Pink & Rose Gold Theme */
        --bg-primary: #FAFAFA; /* Soft Pearl Off-White */
        --bg-sidebar: #FFFFFF; /* Pure White Sidebar */
        --bg-card: #FFFFFF; /* Pure White Cards */
        --accent-main: #E5A9B4; /* Soft Rose Gold/Pink */
        --accent-hover: #C2707F; /* Deeper Rose Pink for hovers */
        --text-main: #3A3233; /* Elegant Dark Charcoal for text */
        --text-muted: #888888; /* Soft Gray for muted text */
        --border-color: #F0E2E4; /* Delicate Pinkish Gray Border */
        --danger-color: #E25C5C;
        --success-color: #4BB543;
        --warning-color: #F0AD4E;
        --sidebar-active-bg: #FFF0F2; /* Very light pink for active menu */
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: var(--bg-primary);
        color: var(--text-main);
        overflow-x: hidden;
    }

    h1, h2, h3, h4, .luxury-text {
        font-family: 'Playfair Display', serif;
        letter-spacing: 0.5px;
        color: var(--text-main);
    }

    /* Scrollbar styling */
    ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
    }

    ::-webkit-scrollbar-track {
        background: var(--bg-primary);
    }

    ::-webkit-scrollbar-thumb {
        background: var(--border-color);
        border-radius: 3px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--accent-main);
        }

    /* Sidebar Navigation */
    .sidebar {
        width: 260px;
        background-color: var(--bg-sidebar);
        border-right: 1px solid var(--border-color);
        min-height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 100;
        transition: all 0.3s ease;
    }

    .sidebar-brand {
        padding: 2.5rem 1.5rem;
        border-bottom: 1px solid var(--border-color);
        text-align: center;
    }

        .sidebar-brand h3 {
            color: var(--accent-hover); /* Brand Name in Deeper Pink */
            margin: 0;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 1.4rem;
            letter-spacing: 2px;
        }

        .sidebar-brand span {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: var(--text-muted);
            display: block;
            margin-top: 5px;
        }

    .nav-list {
        padding: 1.5rem 0;
        list-style: none;
        margin: 0;
    }

    .nav-item-link {
        display: flex;
        align-items: center;
        padding: 0.9rem 1.5rem;
        color: #615557; /* Darker taupe/gray for menu */
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s ease;
        border-left: 3px solid transparent;
        margin-bottom: 0.25rem;
    }

        .nav-item-link i {
            font-size: 1.1rem;
            margin-right: 1rem;
            transition: color 0.2s ease;
            color: #A09092; /* Muted rose gray for icons */
        }

        .nav-item-link:hover, .nav-item-link.active {
            color: var(--accent-hover);
            background-color: var(--sidebar-active-bg);
            border-left-color: var(--accent-main);
        }

            .nav-item-link:hover i, .nav-item-link.active i {
                color: var(--accent-main);
            }

    /* Main Workspace Content */
    .main-workspace {
        margin-left: 260px;
        padding: 2rem;
        min-height: 100vh;
    }

    /* Custom Cards styling */
    .luxury-card {
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 4px 15px rgba(229, 169, 180, 0.1); /* Soft pinkish shadow */
        position: relative;
        overflow: hidden;
        transition: transform 0.2s, border-color 0.2s;
    }

    .luxury-card-clickable {
        cursor: pointer;
    }

        .luxury-card-clickable:hover {
            transform: translateY(-3px);
            border-color: var(--accent-main);
            box-shadow: 0 8px 25px rgba(229, 169, 180, 0.2);
        }

    .kpi-title {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--text-muted);
        margin-bottom: 0.5rem;
        font-weight: 600;
    }

    .kpi-value {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text-main);
        margin: 0;
    }

    .kpi-icon-box {
        position: absolute;
        right: 1.5rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 2.2rem;
        color: rgba(229, 169, 180, 0.2); /* Soft Rose icon background */
    }

    /* Luxury Tables */
    .table-responsive-wrapper {
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1rem;
        box-shadow: 0 4px 15px rgba(229, 169, 180, 0.05);
    }

    .luxury-table {
        color: var(--text-main);
        margin-bottom: 0;
        vertical-align: middle;
    }

        .luxury-table thead th {
            background-color: var(--sidebar-active-bg); /* Light pink header */
            border-bottom: 1px solid var(--border-color);
            color: #615557;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 1rem;
            font-weight: 600;
        }

        .luxury-table tbody td {
            padding: 1rem;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.9rem;
            background-color: transparent !important;
            color: var(--text-main) !important;
        }

        .luxury-table tbody tr:hover td {
            background-color: #FFFAFB !important; /* Extremely faint pink on hover */
        }

    /* Form Controls */
    .luxury-input, .luxury-select {
        background-color: #FFFFFF !important;
        border: 1px solid var(--border-color) !important;
        color: var(--text-main) !important;
        border-radius: 8px !important;
        padding: 0.6rem 1rem;
    }

        .luxury-input:focus, .luxury-select:focus {
            border-color: var(--accent-main) !important;
            box-shadow: 0 0 0 0.2rem rgba(229, 169, 180, 0.15) !important;
        }

    /* Buttons styling - Rose Gold Gradient */
    .btn-luxury {
        background-color: transparent;
        color: var(--accent-hover);
        border: 1px solid var(--accent-main);
        border-radius: 6px;
        padding: 0.5rem 1.25rem;
        font-size: 0.85rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-luxury:hover {
            background-color: var(--sidebar-active-bg);
            border-color: var(--accent-hover);
            color: var(--accent-hover);
        }

    .btn-luxury-solid {
        background: linear-gradient(135deg, var(--accent-main) 0%, var(--accent-hover) 100%);
        color: white;
        border: none;
        border-radius: 6px;
        padding: 0.5rem 1.25rem;
        font-size: 0.85rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-weight: 700;
        transition: all 0.3s;
        box-shadow: 0 4px 10px rgba(194, 112, 127, 0.2);
    }

        .btn-luxury-solid:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 6px 15px rgba(194, 112, 127, 0.3);
            color: white;
        }

    /* Badges */
    .badge-pending {
        background-color: rgba(240, 173, 78, 0.15);
        color: var(--warning-color);
        border: 1px solid rgba(240, 173, 78, 0.3);
    }

    .badge-processing {
        background-color: rgba(75, 181, 67, 0.1);
        color: #5cb85c;
        border: 1px solid rgba(75, 181, 67, 0.2);
    }

    .badge-delivered {
        background-color: #E2F0D9;
        color: #385723;
        border: 1px solid #C5E0B4;
        padding: 0.5rem 1rem;
        font-weight: bold;
        border-radius: 50px;
    }

    /* Low stock flash animation */
    .badge-low-stock {
        background-color: rgba(226, 92, 92, 0.1);
        color: var(--danger-color);
        border: 1px solid rgba(226, 92, 92, 0.2);
        animation: pulseDanger 2s infinite;
    }
    @@keyframes pulseDanger {
        0% {
            opacity: 0.7;
        }

        50% {
            opacity: 1;
            transform: scale(1.05);
        }

        100% {
            opacity: 0.7;
        }
    }

    /* Modals Styling */
    .modal-content-luxury {
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        color: var(--text-main);
        box-shadow: 0 15px 50px rgba(0,0,0,0.1);
    }

    .modal-header-luxury {
        border-bottom: 1px solid var(--border-color);
        padding: 1.5rem;
        background-color: var(--sidebar-active-bg);
        border-radius: 12px 12px 0 0;
    }

        .modal-header-luxury .modal-title {
            color: var(--accent-hover);
        }

    .modal-footer-luxury {
        border-top: 1px solid var(--border-color);
        padding: 1.2rem;
    }

    .btn-close-white {
        filter: none; /* Reset close button color for light header */
    }

    /* Custom utilities */
    .section-wrapper {
        display: none;
        animation: fadeIn 0.4s ease-in-out forwards;
    }

        .section-wrapper.active-view {
            display: block;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Logout Screen */
    .system-logout-screen {
        display: none;
        min-height: 100vh;
        background-color: var(--bg-primary);
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .logout-box {
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        box-shadow: 0 10px 40px rgba(229, 169, 180, 0.15);
    }
</style>

<div class="dashboard-container">
    <aside class="sidebar">
        <div class="sidebar-brand">Chic Boutique Admin</div>
        <ul class="nav-list">
            <li>
                <a href="#" class="nav-item-link active">
                    <i class="bi bi-grid"></i>
                    Dashboard
                </a>
            </li>

            <li>
                <a href="#" class="nav-item-link">
                    <i class="bi bi-bag"></i>
                    Products
                </a>
            </li>

            <li>
                <a href="#" class="nav-item-link">
                    <i class="bi bi-cart"></i>
                    Orders
                </a>
            </li>

            <li>
                <a href="#" class="nav-item-link">
                    <i class="bi bi-people"></i>
                    Customers
                </a>
            </li>

            <li>
                <a href="#" class="nav-item-link">
                    <i class="bi bi-gear"></i>
                    Settings
                </a>
            </li>
        </ul>
    </aside>

    <main class="main-workspace">
        <div class="header-section">
            <h2>Welcome Back, Admin!</h2>
            <p>Today is: @DateTime.Now.ToString("dd MMM yyyy")</p>
        </div>

        <div class="row g-4 mb-4">

            <div class="col-md-4">
                <div class="luxury-card">
                    <div class="kpi-title">Revenue</div>
                    <h2 class="kpi-value">$12,450</h2>
                    <div class="kpi-icon-box">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="luxury-card">
                    <div class="kpi-title">Orders</div>
                    <h2 class="kpi-value">184</h2>
                    <div class="kpi-icon-box">
                        <i class="bi bi-bag-check"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="luxury-card">
                    <div class="kpi-title">Customers</div>
                    <h2 class="kpi-value">48</h2>
                    <div class="kpi-icon-box">
                        <i class="bi bi-people"></i>
                    </div>
                </div>
            </div>

        </div>

        @* <h3>Recent Orders</h3>

        @* <div class="filter-buttons">
            <button class="btn-luxury-solid me-2"
                    @onclick='() => FilterOrders("All")'>
                All Orders
            </button>

            <button class="btn-luxury me-2"
                    @onclick='() => FilterOrders("Pending")'>
                Pending
            </button>

            <button class="btn-luxury"
                    @onclick='() => FilterOrders("Completed")'>
                Completed
            </button>
        </div> *@
        @* <h2 class="kpi-value">@TotalRevenue.ToString("C")</h2>

        <h2 class="kpi-value">@TotalOrders</h2> *@

       @*@ <h2 class="kpi-value">@PendingOrders</h2> *@

        <div class="table-responsive-wrapper mt-4">
            <table class="table luxury-table">
                
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Address</th>
                        <th>Total Amount</th>
                        <th>Status</th>
                        <th>Created Date</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var order in orders)
                    {
                        <tr>
                            <td>@order.OrderId</td>
                            <td>@order.ShippingAddress</td>
                            <td>@order.TotalPrice.ToString("C")</td>
                            <td>
                                @if (order.OrderStatus == "Completed")
                                {
                                    <span class="badge-delivered">Completed</span>
                                }
                                else
                                {
                                    <span class="badge-pending px-3 py-2 rounded-pill">
                                        @order.OrderStatus
                                    </span>
                                }
                            </td>
                            <td>@order.CreatedAt.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </main>
</div>
