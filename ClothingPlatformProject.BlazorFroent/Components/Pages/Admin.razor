function navigate(view) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-item-link').forEach(a => a.classList.remove('active'));

  const el = document.getElementById('view-' + view);
  if (el) el.classList.add('active');

  const link = document.querySelector(`[data-view="${view}"]`);
  if (link) link.classList.add('active');

  const [title, sub] = viewTitles[view] || ['', ''];
  document.getElementById('topbar-title').textContent = title;
  document.getElementById('topbar-sub').textContent = sub;

  if (view === 'dashboard')   renderDashboard();
  if (view === 'orders')      renderOrders();
  if (view === 'products')    renderProducts();
  if (view === 'staff')       renderStaff();
  if (view === 'fulfillment') renderFulfillment();
  if (view === 'profile')     renderProfile();
}

// ═══════════════════════════════════════════════════
//  RENDERERS
// ═══════════════════════════════════════════════════

function fmtMMK(n) {
  return n.toLocaleString('en-US') + ' MMK';
}

function renderDashboard() {
  const totalRevenue = orders.reduce((sum, o) => sum + o.amount, 0);
  const delivered = orders.filter(o => o.status === 'Delivered').length;
  document.getElementById('kpi-revenue').textContent = totalRevenue.toLocaleString('en-US');
  document.getElementById('kpi-staff').textContent = staffList.length;
  document.getElementById('kpi-products').textContent = products.length;
  document.getElementById('kpi-delivered').textContent = delivered;

  // Recent 5 orders
  const recent = [...orders].slice(-5).reverse();
  const rows = recent.map(o => `
    <tr>
      <td class="primary">${o.id}</td>
      <td>${o.customer}</td>
      <td>${o.items.length > 38 ? o.items.substring(0,38)+'…' : o.items}</td>
      <td style="color:var(--gold);">${o.amount.toLocaleString()} MMK</td>
      <td>${statusBadge(o.status)}</td>
      <td style="font-size:11px;color:var(--text-muted);">${o.date}</td>
    </tr>`).join('');

  document.getElementById('recent-orders-table').innerHTML = `
    <table class="luxury-table">
      <thead><tr>
        <th>Order ID</th><th>Customer</th><th>Items</th>
        <th>Amount</th><th>Status</th><th>Date</th>
      </tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
}

function statusBadge(status) {
  const map = {
    'Delivered': '<span class="badge-luxury badge-green">✓ Delivered</span>',
    'Processing': '<span class="badge-luxury badge-blue">⟳ Processing</span>',
    'Pending': '<span class="badge-luxury badge-warning">⏳ Pending</span>',
  };
  return map[status] || status;
}

function renderOrders() {
  document.getElementById('order-count-label').innerHTML =
    `<div class="mini-stat-dot" style="background:var(--gold)"></div>${orders.length} total orders`;

  const rows = orders.map(o => {
    const locked = o.status === 'Delivered';
    const action = locked
      ? `<span class="badge-luxury badge-green" style="padding:6px 14px;">✓ Delivered — Closed</span>`
      : `<select class="status-select" onchange="updateOrderStatus('${o.id}', this.value)">
           <option ${o.status==='Pending'?'selected':''}>Pending</option>
           <option ${o.status==='Processing'?'selected':''}>Processing</option>
           <option value="Delivered">Mark Delivered</option>
         </select>`;

    return `
      <tr>
        <td class="primary">${o.id}</td>
        <td>${o.customer}</td>
        <td style="max-width:220px;font-size:12px;">${o.items}</td>
        <td style="color:var(--gold);font-weight:500;">${o.amount.toLocaleString()} MMK</td>
        <td>${statusBadge(o.status)}</td>
        <td style="font-size:11px;color:var(--text-muted);">${o.date}</td>
        <td>${action}</td>
        <td>
          <button class="btn-icon" title="View Payment Slip" onclick="viewSlip('${o.id}')">
            <i class="fas fa-receipt"></i>
          </button>
        </td>
      </tr>`;
  }).join('');

  document.getElementById('orders-table').innerHTML = `
    <table class="luxury-table">
      <thead><tr>
        <th>Order ID</th><th>Customer</th><th>Items</th>
        <th>Amount</th><th>Status</th><th>Date</th>
        <th>Action</th><th>Slip</th>
      </tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
}

function updateOrderStatus(orderId, newStatus) {
  const order = orders.find(o => o.id === orderId);
  if (!order) return;
  order.status = newStatus;
  if (newStatus === 'Delivered') {
    fulfillmentLogs.unshift({
      timestamp: new Date().toLocaleString('en-US', {day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}),
      staffId: 1,
      orderId: orderId,
      action: 'Order marked Delivered'
    });
  }
  renderOrders();
  renderDashboard();
  toast(`Order ${orderId} updated to ${newStatus}`);
}

function viewSlip(orderId) {
  const o = orders.find(x => x.id === orderId);
  if (!o) return;
  document.getElementById('slip-order-ref').textContent = `Reference: ${o.id}`;
  document.getElementById('slip-amount').textContent = o.amount.toLocaleString() + ' MMK';
  document.getElementById('slip-customer').textContent = o.customer;
  document.getElementById('slip-txn').textContent = o.txn;
  document.getElementById('slip-wallet').textContent = o.wallet;
  document.getElementById('slip-date').textContent = o.date;
  openModal('modal-payment-slip');
}

function renderProducts() {
  let rows = '';
  products.forEach(p => {
    p.variants.forEach((v, i) => {
      const low = v.stock < 5;
      const stockDisplay = v.stock === 0
        ? `<span class="badge-luxury badge-red">Out of Stock</span>`
        : low
          ? `<span><span class="low-stock-indicator"></span>${v.stock} units</span>`
          : `${v.stock} units`;

      rows += `
        <tr class="${low ? 'low-stock-row' : ''}">
          ${i === 0 ? `<td class="primary" rowspan="${p.variants.length}" style="border-right:1px solid var(--border-light);vertical-align:top;padding-top:16px;">
            <div style="font-weight:500;color:var(--text-primary);">${p.name}</div>
            <div style="font-size:10px;color:var(--gold);margin-top:3px;letter-spacing:0.5px;">${p.category}</div>
            <div style="font-size:10px;color:var(--text-muted);margin-top:2px;">${p.designer}</div>
          </td>` : ''}
          <td style="font-family:monospace;font-size:11px;color:var(--text-muted);">${v.sku}</td>
          <td>${v.size}</td>
          <td>${v.color}</td>
          <td style="color:var(--gold);">${v.price.toLocaleString()} MMK</td>
          <td>${stockDisplay}</td>
        </tr>`;
    });
  });

  document.getElementById('products-table').innerHTML = `
    <table class="luxury-table">
      <thead><tr>
        <th>Product</th><th>SKU</th><th>Size</th>
        <th>Color</th><th>Price</th><th>Stock</th>
      </tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
}

function renderStaff() {
  const rows = staffList.map(s => `
    <tr>
      <td>
        <div style="display:flex;align-items:center;gap:10px;">
          <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--rose));display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#111;flex-shrink:0;">
            ${s.name.split(' ').map(w=>w[0]).slice(0,2).join('')}
          </div>
          <div>
            <div style="color:var(--text-primary);font-weight:500;font-size:13px;">${s.name}</div>
            <div style="font-size:10px;color:var(--text-muted);">${s.email}</div>
          </div>
        </div>
      </td>
      <td style="font-size:12px;">${s.phone}</td>
      <td>
        <span class="badge-luxury ${s.status === 'Active' ? 'badge-green' : 'badge-warning'}">
          ${s.status}
        </span>
      </td>
      <td style="font-size:11px;color:var(--text-muted);">Joined ${s.joined}</td>
      <td>
        <button class="btn-danger-ghost" onclick="revokeStaff(${s.id})">
          <i class="fas fa-user-slash" style="margin-right:4px;"></i>Revoke
        </button>
      </td>
    </tr>`).join('');

  document.getElementById('staff-table').innerHTML = `
    <table class="luxury-table">
      <thead><tr>
        <th>Employee</th><th>Phone</th><th>Status</th><th>Since</th><th>Action</th>
      </tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
}

function revokeStaff(id) {
  staffList = staffList.filter(s => s.id !== id);
  renderStaff();
  renderDashboard();
  toast('Staff access revoked and member removed.');
}

function renderFulfillment() {
  const html = fulfillmentLogs.map(log => {
    const staff = staffList.find(s => s.id === log.staffId);
    const staffName = staff ? staff.name : 'System';
    const initials = staffName.split(' ').map(w=>w[0]).slice(0,2).join('');
    return `
      <div class="timeline-item">
        <div class="timeline-dot">${initials}</div>
        <div class="timeline-body">
          <div class="timeline-title">${log.action} — <span style="color:var(--gold);">${log.orderId}</span></div>
          <div class="timeline-meta">By ${staffName} · ${log.timestamp}</div>
        </div>
      </div>`;
  }).join('');

  document.getElementById('fulfillment-list').innerHTML = html ||
    '<div style="color:var(--text-muted);font-size:13px;padding:24px;">No fulfillment activity recorded.</div>';
}

function renderProfile() {
  document.getElementById('profile-first').value = adminProfile.firstName;
  document.getElementById('profile-last').value = adminProfile.lastName;
  document.getElementById('profile-email').value = adminProfile.email;
  document.getElementById('profile-role').value = adminProfile.role.charAt(0).toUpperCase() + adminProfile.role.slice(1);
  const initials = adminProfile.firstName[0] + adminProfile.lastName[0];
  document.getElementById('profile-avatar-lg').textContent = initials;
  document.getElementById('profile-full-name').textContent = adminProfile.firstName + ' ' + adminProfile.lastName;
}

function saveProfile() {
  adminProfile.firstName = document.getElementById('profile-first').value.trim() || adminProfile.firstName;
  adminProfile.lastName  = document.getElementById('profile-last').value.trim()  || adminProfile.lastName;
  adminProfile.email     = document.getElementById('profile-email').value.trim()  || adminProfile.email;

  const initials = adminProfile.firstName[0] + adminProfile.lastName[0];
  document.getElementById('sidebar-avatar').textContent = initials;
  document.getElementById('sidebar-name').textContent = adminProfile.firstName + ' ' + adminProfile.lastName;
  renderProfile();
  toast('Profile updated successfully.');
}

// ═══════════════════════════════════════════════════
//  FORM ACTIONS
// ═══════════════════════════════════════════════════

function addStaff() {
  const name  = document.getElementById('staff-new-name').value.trim();
  const email = document.getElementById('staff-new-email').value.trim();
  const phone = document.getElementById('staff-new-phone').value.trim();
  const status = document.getElementById('staff-new-status').value;

  if (!name || !email) { toast('Please enter name and email.'); return; }

  const newId = staffList.length > 0 ? Math.max(...staffList.map(s => s.id)) + 1 : 1;
  staffList.push({
    id: newId,
    name, email, phone: phone || '—',
    status,
    joined: new Date().toLocaleDateString('en-US', {month:'short', year:'numeric'})
  });

  document.getElementById('staff-new-name').value = '';
  document.getElementById('staff-new-email').value = '';
  document.getElementById('staff-new-phone').value = '';
  closeModal('modal-add-staff');
  renderStaff();
  renderDashboard();
  toast(`${name} added to the team.`);
}

function addProduct() {
  const name     = document.getElementById('prod-new-name').value.trim();
  const sku      = document.getElementById('prod-new-sku').value.trim();
  const category = document.getElementById('prod-new-category').value;
  const size     = document.getElementById('prod-new-size').value;
  const color    = document.getElementById('prod-new-color').value.trim();
  const stock    = parseInt(document.getElementById('prod-new-stock').value) || 0;
  const price    = parseInt(document.getElementById('prod-new-price').value) || 0;
  const designer = document.getElementById('prod-new-designer').value.trim() || 'House Label';

  if (!name || !sku) { toast('Product name and SKU are required.'); return; }

  // Check if product exists (add variant) or create new
  const existing = products.find(p => p.name.toLowerCase() === name.toLowerCase());
  if (existing) {
    existing.variants.push({ sku, size, color, stock, price });
  } else {
    const newId = products.length > 0 ? Math.max(...products.map(p => p.id)) + 1 : 1;
    products.push({ id: newId, name, category, designer, variants: [{ sku, size, color, stock, price }] });
  }

  ['prod-new-name','prod-new-sku','prod-new-color','prod-new-stock','prod-new-price','prod-new-designer']
    .forEach(id => document.getElementById(id).value = '');

  closeModal('modal-add-product');
  renderProducts();
  renderDashboard();
  toast(`${name} added to catalog.`);
}

// ═══════════════════════════════════════════════════
//  MODAL HELPERS
// ═══════════════════════════════════════════════════

function openModal(id) {
  document.getElementById(id).classList.add('active');
}

function closeModal(id) {
  document.getElementById(id).classList.remove('active');
}

// Close modal on backdrop click
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', e => {
    if (e.target === overlay) overlay.classList.remove('active');
  });
});

// ═══════════════════════════════════════════════════
//  LOGOUT
// ═══════════════════════════════════════════════════

function performLogout() {
  // Wipe session state
  adminProfile = null;
  document.getElementById('logout-screen').classList.add('active');
}

// ═══════════════════════════════════════════════════
//  TOAST
// ═══════════════════════════════════════════════════

let toastTimer;
function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 3000);
}

// ═══════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════

function init() {
  // Set date
  document.getElementById('topbar-date').textContent =
    new Date().toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' });

  // Set sidebar info
  const initials = adminProfile.firstName[0] + adminProfile.lastName[0];
  document.getElementById('sidebar-avatar').textContent = initials;
  document.getElementById('sidebar-name').textContent = adminProfile.firstName + ' ' + adminProfile.lastName;

  // Render initial view
  navigate('dashboard');
}

init();
</script>
</body>