@page "/dashboard"
@using ClothingPlatformProject.BlazorFroent.Components.Partial
@inject IJSRuntime JSRuntime
@inject HttpClientServices HttpClientServices
@inject HttpClient Http

<style>
    :root {
        --bg-primary: #FDF8F6;
        --bg-sidebar: #8B1A1A; /* Blood Red sidebar background */
        --bg-card: #FFFFFF;
        --accent-main: #8B1A1A; /* Blood Red accent */
        --accent-hover: #6B0F0F;
        --text-main: #3C1F10; /* Chocolate Brown — primary text */
        --text-muted: #7A5C50;
        --border-color: #EDD9D0;
        --danger-color: #C0392B;
        --success-color: #4BB543;
        --warning-color: #D4862A;
        --sidebar-active-bg: #8B1A1A; /* Blood Red active menu */
        --sidebar-text: #F5F0E8; /* Cream White for sidebar text */
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background-color: var(--bg-primary);
        color: #3C1F10; /* Chocolate Brown */
        overflow-x: hidden;
    }

    h1, h2, h3, h4, .luxury-text {
        font-family: 'DM Sans', sans-serif;
        letter-spacing: 0.5px;
        color: #3C1F10; /* Chocolate Brown headings */
    }

    /* Scrollbar styling */
    ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
    }

    ::-webkit-scrollbar-track {
        background: var(--bg-primary);
    }

    ::-webkit-scrollbar-thumb {
        background: var(--border-color);
        border-radius: 3px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--accent-main);
        }

    /* ── SIDEBAR ── */
    .sidebar {
        width: 260px;
        background-image: none !important;
        background-color: #8B1A1A !important;
        border-right: 1px solid #6B0F0F !important;
        min-height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 100;
        transition: all 0.3s ease;
    }

    .sidebar-brand {
        padding: 2.5rem 1.5rem;
        border-bottom: 1px solid rgba(245, 240, 232, 0.2);
        text-align: center;
    }

        .sidebar-brand h3 {
            color: #F5F0E8; /* Cream White brand name */
            margin: 0;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 1.4rem;
            letter-spacing: 2px;
        }

        .sidebar-brand span {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: #F5F0E8; /* Cream White subtitle */
            display: block;
            margin-top: 5px;
            opacity: 0.75;
        }

    .nav-list {
        padding: 1.5rem 0;
        list-style: none;
        margin: 0;
    }

    .nav-item-link {
        display: flex;
        align-items: center;
        padding: 0.9rem 1.5rem;
        color: #F5F0E8; /* Cream White nav text */
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s ease;
        border-left: 3px solid transparent;
        margin-bottom: 0.25rem;
        cursor: pointer;
    }

        .nav-item-link i {
            font-size: 1.1rem;
            margin-right: 1rem;
            transition: color 0.2s ease;
            color: #F5F0E8; /* Cream White nav icons */
            opacity: 0.8;
        }

        .nav-item-link:hover,
        .nav-item-link.active {
            color: #F5F0E8;
            background-color: rgba(245, 240, 232, 0.15); /* subtle cream overlay */
            border-left-color: #F5F0E8;
        }

            .nav-item-link:hover i,
            .nav-item-link.active i {
                color: #F5F0E8;
                opacity: 1;
            }

        /* Sign Out link override */
        .nav-item-link.text-danger {
            color: #FFAAAA !important;
        }

            .nav-item-link.text-danger i {
                color: #FFAAAA !important;
            }

    /* ── MAIN WORKSPACE ── */
    .main-workspace {
        margin-left: 260px;
        padding: 2rem;
        min-height: 100vh;
        background-color: var(--bg-primary);
    }

        /* Header text (Hello, Aye Aye / date) */
        .main-workspace h1,
        .main-workspace p.text-muted {
            color: #3C1F10 !important; /* Chocolate Brown */
        }

    /* ── LUXURY CARDS ── */
    .luxury-card {
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 4px 15px rgba(139, 26, 26, 0.08);
        position: relative;
        overflow: hidden;
        transition: transform 0.2s, border-color 0.2s;
    }

    .luxury-card-clickable {
        cursor: pointer;
    }

        .luxury-card-clickable:hover {
            transform: translateY(-3px);
            border-color: var(--accent-main);
            box-shadow: 0 8px 25px rgba(139, 26, 26, 0.15);
        }

    .kpi-title {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #7A5C50;
        margin-bottom: 0.5rem;
        font-weight: 600;
    }

    .kpi-value {
        font-size: 1.75rem;
        font-weight: 700;
        color: #3C1F10; /* Chocolate Brown */
        margin: 0;
    }

    .kpi-icon-box {
        position: absolute;
        right: 1.5rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 2.2rem;
        color: rgba(139, 26, 26, 0.15);
    }

    /* ── TABLES ── */
    .table-responsive-wrapper {
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1rem;
        box-shadow: 0 4px 15px rgba(139, 26, 26, 0.05);
    }

    .luxury-table {
        color: #3C1F10;
        margin-bottom: 0;
        vertical-align: middle;
    }

        .luxury-table thead th {
            background-color: #FFF3EE;
            border-bottom: 1px solid var(--border-color);
            color: #3C1F10; /* Chocolate Brown */
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 1rem;
            font-weight: 600;
        }

        .luxury-table tbody td {
            padding: 1rem;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.9rem;
            background-color: transparent !important;
            color: #3C1F10 !important; /* Chocolate Brown */
        }

        .luxury-table tbody tr:hover td {
            background-color: #FFF5F0 !important;
        }

    /* ── FORM CONTROLS ── */
    .luxury-input, .luxury-select {
        background-color: #FFFFFF !important;
        border: 1px solid var(--border-color) !important;
        color: #3C1F10 !important; /* Chocolate Brown */
        border-radius: 8px !important;
        padding: 0.6rem 1rem;
        width: 100%;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .luxury-input:focus, .luxury-select:focus {
            border-color: var(--accent-main) !important;
            box-shadow: 0 0 0 0.2rem rgba(139, 26, 26, 0.12) !important;
        }

    /* Form labels */
    .form-label {
        color: #3C1F10 !important; /* Chocolate Brown */
    }

    /* ── BUTTONS ── */
    .btn-luxury {
        background-color: transparent;
        color: var(--accent-hover);
        border: 1px solid var(--accent-main);
        border-radius: 6px;
        padding: 0.5rem 1.25rem;
        font-size: 0.85rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-weight: 600;
        transition: all 0.3s;
        cursor: pointer;
    }

        .btn-luxury:hover {
            background-color: #FFF3EE;
            border-color: var(--accent-hover);
            color: var(--accent-hover);
        }

    .btn-luxury-solid {
        background: linear-gradient(135deg, #8B1A1A 0%, #6B0F0F 100%); /* Blood Red */
        color: #F5F0E8 !important; /* Cream White text */
        border: none;
        border-radius: 6px;
        padding: 0.5rem 1.25rem;
        font-size: 0.85rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-weight: 700;
        transition: all 0.3s;
        box-shadow: 0 4px 10px rgba(107, 15, 15, 0.25);
        cursor: pointer;
    }

        .btn-luxury-solid:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 6px 15px rgba(107, 15, 15, 0.35);
            color: #F5F0E8 !important;
        }

    /* ── BADGES ── */
    .badge-pending {
        background-color: rgba(240, 173, 78, 0.15);
        color: var(--warning-color);
        border: 1px solid rgba(240, 173, 78, 0.3);
    }

    .badge-processing {
        background-color: rgba(60, 130, 246, 0.1);
        color: #2563EB;
        border: 1px solid rgba(60, 130, 246, 0.2);
    }

    .badge-confirm {
        background-color: rgba(75, 181, 67, 0.1);
        color: var(--success-color);
        border: 1px solid rgba(75, 181, 67, 0.2);
    }

    /* ── MODALS ── */
    .modal-content-luxury {
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        color: #3C1F10;
        box-shadow: 0 15px 50px rgba(0,0,0,0.1);
    }

    .modal-header-luxury {
        border-bottom: 1px solid var(--border-color);
        padding: 1.5rem;
        background-color: #FFF3EE;
        border-radius: 12px 12px 0 0;
    }

        .modal-header-luxury .modal-title {
            color: #8B1A1A;
        }

    .modal-footer-luxury {
        border-top: 1px solid var(--border-color);
        padding: 1.2rem;
    }

    /* ── ALERTS ── */
    .alert-banner {
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }

    .alert-banner-error {
        background-color: #FDECEA;
        color: #8B1A1A;
        border: 1px solid #E8A0A0;
    }

    .alert-banner-success {
        background-color: #EDFDF5;
        color: #03543F;
        border: 1px solid #BCF0DA;
    }

    /* ── CRUD GRID ── */
    .crud-grid {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 1.5rem;
        align-items: start;
    }

    @@media(max-width: 992px) {
        .crud-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ── MISC TEXT OVERRIDES ── */
    .text-muted {
        color: #7A5C50 !important;
    }

    p, span, td, th, li, label, div {
        color: #3C1F10;
    }

    /* List group for activity logs */
    .list-group-item {
        color: #3C1F10 !important;
        background-color: transparent !important;
        border-color: var(--border-color) !important;
    }

    .report-stat {
        background: #FFFFFF;
        border: 1px solid var(--border-color);
        border-radius: 8px;
    }
</style>


<div class="dashboard-container">
    <!-- ── SIDEBAR NAVIGATION ── -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <h3>Chic Boutique</h3>
            <span>Admin Control</span>
        </div>
        <ul class="nav-list">
            <li>
                <a class="nav-item-link @(activeView == "dashboard" ? "active" : "")" @onclick='() => SetView("dashboard")'>
                    <i class="bi bi-grid-1x2"></i>
                    Dashboard
                </a>
            </li>

            <li>
                <a class="nav-item-link @(activeView == "products" ? "active" : "")" @onclick='() => SetView("products")'>
                    <i class="bi bi-bag"></i>
                    Products
                </a>
            </li>

            <li>
                <a class="nav-item-link @(activeView == "orders" ? "active" : "")" @onclick='() => SetView("orders")'>
                    <i class="bi bi-cart"></i>
                    Orders
                </a>
            </li>

            <li>
                <a class="nav-item-link @(activeView == "customers" ? "active" : "")" @onclick='() => SetView("customers")'>
                    <i class="bi bi-people"></i>
                    Customers
                </a>
            </li>

            <li>
                <a class="nav-item-link @(activeView == "staffs" ? "active" : "")" @onclick='() => SetView("staffs")'>
                    <i class="bi bi-person-workspace"></i>
                    Staff Menu
                </a>
            </li>

            <li>
                <a class="nav-item-link @(activeView == "reports" ? "active" : "")" @onclick='() => SetView("reports")'>
                    <i class="bi bi-bar-chart-line"></i>
                    Admin Reports
                </a>
            </li>

            <li class="mt-5">
                <a class="nav-item-link text-danger" @onclick="Logout">
                    <i class="bi bi-box-arrow-right text-danger"></i>
                    Sign Out
                </a>
            </li>
        </ul>
    </aside>

    <!-- ── MAIN WORKSPACE ── -->
    <main class="main-workspace">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="luxury-text m-0">Atelier Admin Panel</h1>
                <p class="text-muted m-0">Today is @DateTime.Now.ToString("dd MMM yyyy")</p>
            </div>
            <div>
                <button class="btn-luxury" @onclick="LoadData"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
            </div>
        </div>

        <!-- Alerts -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-banner alert-banner-error">
                <i class="bi bi-exclamation-circle-fill me-2"></i> @errorMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert-banner alert-banner-success">
                <i class="bi bi-check-circle-fill me-2"></i> @successMessage
            </div>
        }

        @if (activeView == "dashboard")
        {
            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <div class="luxury-card luxury-card-clickable" @onclick='() => SetView("reports")'>
                        <div class="kpi-title">Revenue</div>
                        <h2 class="kpi-value">@TotalRevenue.ToString("N0") MMK</h2>
                        <div class="kpi-icon-box">
                            <i class="bi bi-cash-stack"></i>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="luxury-card luxury-card-clickable" @onclick='() => SetView("orders")'>
                        <div class="kpi-title">Total Orders</div>
                        <h2 class="kpi-value">@TotalOrders</h2>
                        <div class="kpi-icon-box">
                            <i class="bi bi-bag-check"></i>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="luxury-card luxury-card-clickable" @onclick='() => SetView("orders")'>
                        <div class="kpi-title">Pending Orders</div>
                        <h2 class="kpi-value">@PendingOrders</h2>
                        <div class="kpi-icon-box">
                            <i class="bi bi-clock-history"></i>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="luxury-card luxury-card-clickable" @onclick='() => SetView("customers")'>
                        <div class="kpi-title">Customers</div>
                        <h2 class="kpi-value">@TotalCustomers</h2>
                        <div class="kpi-icon-box">
                            <i class="bi bi-people"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5 mb-3">
                <h3 class="m-0">Recent Orders Queue</h3>
                <button class="btn-luxury" @onclick='() => SetView("orders")'>View All Orders</button>
            </div>

            <div class="table-responsive-wrapper">
                <table class="table luxury-table">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Address</th>
                            <th>Total Amount</th>
                            <th>Status</th>
                            <th>Date Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Pagedorders.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">No orders found in the boutique queue.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var order in Pagedorders)
                            {
                                <tr>
                                    <td><strong>ORD-@order.OrderId.ToString("D4")</strong></td>
                                    <td>@order.User.FirstName @order.User.LastName</td>
                                    <td>@order.ShippingAddress</td>
                                    <td>@order.TotalAmount.ToString("N0") MMK</td>
                                    <td>
                                        <span class="badge @StatusBadgeClass(order.OrderStatus) px-3 py-2 rounded-pill">@NormalizeStatus(order.OrderStatus)</span>
                                    </td>
                                    <td>@(order.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                <Pagination CurrentPage="@orderPage"
                            TotalPages="@OrderTotalPages"
                            CurrentPageChanged="@ChangeOrderPage" />
            </div>
        }

        
        else if (activeView == "products")
        {
            <div class="crud-grid">
                <!-- Product Form (Add / Edit) -->
                <div class="luxury-card">
                    <h4>@(editingProduct == null ? "Add Atelier Product" : "Edit Product")</h4>
                    <hr />

                    <div class="mb-3">
                        <label class="form-label text-muted small uppercase fw-bold">Product Name</label>
                        <input type="text" class="luxury-input" @bind="model.Name" placeholder="e.g., Silk Slip Dress" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small uppercase fw-bold">Description</label>
                        <textarea class="luxury-input" @bind="model.Description" rows="3" placeholder="Describe this luxury garment..."></textarea>
                    </div>

                    <div class="mb-3">

                        <label class="form-label text-muted small uppercase fw-bold">Base Price (MMK)</label>
                        <input type="text" class="luxury-input" @bind-value="model.BasePrice" placeholder="e.g., 75,000" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small uppercase fw-bold">Category</label>
                        <select class="luxury-select" @bind="newProductCategoryId">
                            <option value="0">-- Select Category --</option>
                            @foreach (var cat in allCategories)
                            {
                                <option value="@cat.CategoryId">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                         <label class="form-label text-muted small uppercase fw-bold">Upload Product Image</label>
                        <InputFile OnChange="HandleFileSelected" 
           class="form-control" 
           accept=".jpg,.jpeg,.png"
           title="Upload Product Image" />

@if (!string.IsNullOrEmpty(previewImageUrl))
{
    <img src="@previewImageUrl" style="width:100px; height:100px; object-fit:cover; margin-top:8px;" />
}
                            </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small uppercase fw-bold">Create Sizes (Comma-separated)</label>
                            <input type="text" class="luxury-input" @bind="selectedSizesString" placeholder="XS, S, M, L, XL" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small uppercase fw-bold">Create Colors (Comma-separated)</label>
                            <input type="text" class="luxury-input" @bind="selectedColorsString" placeholder="Blush Pink, Sage Green" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small uppercase fw-bold">Quantity</label>
                            <input type="text" class="luxury-input" @bind="selectedquantity" placeholder="1,2,3" />
                        </div>
                    

                    <div class="mt-4 d-grid gap-2">
                        @if (editingProduct == null)
                        {
                            <button class="btn-luxury-solid" @onclick="HandleCreateProduct">Add Product</button>
                        }
                        else
                        {
                            <button class="btn-luxury-solid" @onclick=" HandleUpdateProduct">Save Changes</button>
                            <button class="btn-luxury" @onclick="ResetProductForm">Cancel</button>
                        }
                    </div>
                </div>

                <!-- Product Catalog List -->
                <div class="table-responsive-wrapper">
                    <h4>Catalog Items</h4>
                    <table class="table luxury-table mt-3">
                        <thead>
                            <tr>
                                <th>Thumbnail</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Base Price</th>
                                <th>Variants</th>
                                <th>Quantity</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!PagedProducts.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No products registered. Create one to display.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var prod in PagedProducts)
                                {
                                    var raw = prod.ProductImages?
                                    .FirstOrDefault(i => i.IsPrimary == true)?.ImageUrl?.Trim() ?? "";

                                    var imgSrc = string.IsNullOrWhiteSpace(raw)
                                        ? "/images/products/default.jpg"
                                        : raw.StartsWith("http")
                                            ? raw
                                            : $"/images/products/{raw.Replace("images/products/", "").TrimStart('/')}";
                                    <tr>
                                        <td>
                                            <img src="@imgSrc" alt="@prod.Name" style="width:60px;height:60px;object-fit:cover;" />
                                        </td>
                                        <td>
                                            <strong>@prod.Name</strong>
                                            <p class="text-muted small m-0 text-truncate" style="max-width: 200px;">@prod.Description</p>
                                        </td>
                                        <td>@(prod.Category?.Name ?? "No Category")</td>
                                        <td>@prod.BasePrice.ToString("N0") MMK</td>
                                        <td>
                                            <span class="badge bg-secondary">@prod.ProductVariants.Count variants</span>
                                        </td>
                                        <td>
                                            @prod.ProductVariants.FirstOrDefault()?.StockQuantity
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditProduct(prod)"><i class="bi bi-pencil"></i></button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProduct(prod.ProductId)"><i class="bi bi-trash"></i></button>
                                            
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <Pagination CurrentPage="@productPage" 
                            TotalPages="@ProductTotalPages" 
                             CurrentPageChanged="@OnProductPageChanged" />
                </div>
            </div>
        }

       
       
        else if (activeView == "orders")
        {
            <div class="mb-3 d-flex justify-content-between align-items-center">
                <div class="filter-buttons">
                    <button class="btn-luxury @(orderFilter == "All" ? "btn-luxury-solid text-white" : "") me-2" @onclick='() => FilterOrders("All")'>All Orders</button>
                    <button class="btn-luxury @(orderFilter == "Pending" ? "btn-luxury-solid text-white" : "") me-2" @onclick='() => FilterOrders("Pending")'>Pending</button>
                    <button class="btn-luxury @(orderFilter == "Processing" ? "btn-luxury-solid text-white" : "") me-2" @onclick='() => FilterOrders("Processing")'>Processing</button>
                    <button class="btn-luxury @(orderFilter == "Confirm" ? "btn-luxury-solid text-white" : "")" @onclick='() => FilterOrders("Confirm")'>Confirm</button>
                </div>
                <span class="text-muted small">Queue Count: @filteredOrders.Count</span>
            </div>

            <div class="table-responsive-wrapper">
                <table class="table luxury-table">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Customer Info</th>
                            <th>Delivery Address</th>
                            <th>Payment Info</th>
                            <th>Total Price</th>
                            <th>Fulfillment Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Pagedorders.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">No orders found matching the filter.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var order in Pagedorders)
                            {
                                var payInfo = order.Payments.FirstOrDefault()?.PaymentMethod ?? "COD";
                                <tr>
                                    <td><strong>ORD-@order.OrderId.ToString("D4")</strong></td>
                                    <td>
                                        <div>@order.User.FirstName @order.User.LastName</div>
                                        <div class="small text-muted">@order.User.Email</div>
                                    </td>
                                    <td>@order.ShippingAddress</td>
                                    <td><span class="badge bg-light text-dark border">@payInfo.ToUpper()</span></td>
                                    <td><strong>@order.TotalAmount.ToString("N0") MMK</strong></td>
                                    <td>
                                        <span class="badge @StatusBadgeClass(order.OrderStatus) px-3 py-2 rounded-pill">@NormalizeStatus(order.OrderStatus)</span>
                                    </td>
                                    <td>
                                        @if (IsFinalStatus(order.OrderStatus))
                                        {
                                            <span class="text-muted small"><i class="bi bi-lock-fill"></i> Locked</span>
                                        }
                                        else
                                        {
                                            <select class="luxury-select py-1 px-2 small d-inline-block" style="width: 140px; font-size: 0.85rem;" @onchange="(e) => UpdateOrderStatus(order, e.Value?.ToString() ?? string.Empty)">
                                                <option value="Pending" selected="@(NormalizeStatus(order.OrderStatus) == "Pending")">Pending</option>
                                                <option value="Processing" selected="@(NormalizeStatus(order.OrderStatus) == "Processing")">Processing</option>
                                                <option value="Confirm" selected="@(NormalizeStatus(order.OrderStatus) == "Confirm")">Confirm</option>
                                            </select>
                                        }
                                        <button class="btn btn-sm btn-outline-danger ms-2" @onclick="() => DeleteOrder(order.OrderId)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                <Pagination CurrentPage="@orderPage"
                            TotalPages="@OrderTotalPages"
                            CurrentPageChanged="@ChangeOrderPage" />
            </div>
        }

       
        else if (activeView == "customers")
        {
            <div class="table-responsive-wrapper">
                <table class="table luxury-table">
                    <thead>
                        <tr>
                            <th>User ID</th>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Email Address</th>
                             <th>Role</th>
                            <th>Default Delivery Address</th>
                            <th>Registration Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!PageCustomer.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">No registered customers.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var cust in PageCustomer)
                            {
                                <tr>
                                    <td><strong>USR-@cust.Id.ToString("D4")</strong></td>
                                    <td>@cust.First_Name</td>
                                    <td>@cust.Last_Name</td>
                                    <td>@cust.Email</td>
                                    <td>@cust.Role</td>
                                    <td>@cust.Address</td>
                                    <td>@(cust.CreatedAt?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                <Pagination CurrentPage="@customerPage"
                            TotalPages="@customerTotalPage"
                            CurrentPageChanged="@ChangeCustomerPage" />
            </div>
        }

        else if (activeView == "staffs")
        {
            <div class="staff-grid">
                <div class="luxury-card">
                    <h4><i class="bi bi-person-plus me-2" style="color: var(--accent-main);"></i>Staff Menu</h4>
                    <p class="text-muted small mb-3">Add portal staff with the <strong>staff</strong> role for boutique operations.</p>
                    <hr />

                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase fw-bold">First Name <span class="text-danger">*</span></label>
                        <input type="text" class="luxury-input" @bind="staffForm.FirstName" placeholder="e.g., Amara" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase fw-bold">Last Name <span class="text-danger">*</span></label>
                        <input type="text" class="luxury-input" @bind="staffForm.LastName" placeholder="e.g., Nguyen" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase fw-bold">Email Address <span class="text-danger">*</span></label>
                        <input type="email" class="luxury-input" @bind="staffForm.Email" placeholder="staff@chicboutique.com" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase fw-bold">Password <span class="text-danger">*</span></label>
                        <input type="password" class="luxury-input" @bind="staffForm.Password" placeholder="Min. 6 characters" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase fw-bold">Phone Number</label>
                        <input type="text" class="luxury-input" @bind="staffForm.Phone" placeholder="+95 9 xxx xxx xxx" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase fw-bold">Address</label>
                        <textarea class="luxury-input" @bind="staffForm.Address" rows="2" placeholder="Staff residential address..."></textarea>
                    </div>

                    <div class="mt-4 d-grid gap-2">
                        <button class="btn-luxury-solid" @onclick="HandleCreateStaff" disabled="@isCreatingStaff">
                            @if (isCreatingStaff)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>Adding Staff...</span>
                            }
                            else
                            {
                                <i class="bi bi-person-check me-1"></i>
                                <span>Add New Staff</span>
                            }
                        </button>
                        <button class="btn-luxury" @onclick="ResetStaffForm">Clear Form</button>
                    </div>
                </div>

                <div class="table-responsive-wrapper">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="m-0">Staff List</h4>
                        <span class="text-muted small">@staffTotalCount portal staff</span>
                    </div>
                    <table class="table luxury-table">
                        <thead>
                            <tr>
                                <th>User ID</th>
                                <th>First Name</th>
                                <th>Last Name</th>
                                <th>Email Address</th>
                                <th>Role</th>
                                <th>Address</th>
                                <th>Registration Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!PageStaff.Any())
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-4 text-muted">No staff accounts found.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var cust in PageStaff)
                                {
                                    <tr>
                                        <td><strong>STF-@cust.Id.ToString("D4")</strong></td>
                                        <td>@cust.First_Name</td>
                                        <td>@cust.Last_Name</td>
                                        <td>@cust.Email</td>
                                        <td>@cust.Role</td>
                                        <td>@cust.Address</td>
                                        <td>@(cust.CreatedAt?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteStaff(cust.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <Pagination CurrentPage="@staffPage"
                                TotalPages="@staffTotalPage"
                                CurrentPageChanged="@ChangeStaffPage" />
                </div>
            </div>
        }
        else if (activeView == "reports")
        {
            <div class="luxury-card mb-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                    <div>
                        <h4 class="m-0">Admin Report</h4>
                        <p class="text-muted small m-0">Admin-only order and payment summary.</p>
                    </div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <input type="date" class="luxury-input" style="width: 160px;" @bind="reportFrom" />
                        <input type="date" class="luxury-input" style="width: 160px;" @bind="reportTo" />
                        <button class="btn-luxury-solid" @onclick="LoadAdminReport">
                            <i class="bi bi-bar-chart-line me-1"></i> Generate
                        </button>
                        <button class="btn-luxury" @onclick="DownloadAdminReportCsv">
                            <i class="bi bi-download me-1"></i> CSV
                        </button>
                    </div>
                </div>

                @if (adminReport is null)
                {
                    <div class="text-muted small">Choose a date range and generate a report.</div>
                }
                else
                {
                    <div class="row g-3 mb-3">
                        <div class="col-md-2">
                            <div class="report-stat p-3">
                                <div class="kpi-title">Orders</div>
                                <div class="kpi-value">@adminReport.TotalOrders</div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="report-stat p-3">
                                <div class="kpi-title">Pending</div>
                                <div class="kpi-value">@adminReport.PendingOrders</div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="report-stat p-3">
                                <div class="kpi-title">Processing</div>
                                <div class="kpi-value">@adminReport.ProcessingOrders</div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="report-stat p-3">
                                <div class="kpi-title">Confirm</div>
                                <div class="kpi-value">@adminReport.ConfirmOrders</div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="report-stat p-3">
                                <div class="kpi-title">Revenue</div>
                                <div class="kpi-value">@adminReport.TotalRevenue.ToString("N0")</div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="report-stat p-3">
                                <div class="kpi-title">Paid</div>
                                <div class="kpi-value">@adminReport.PaidRevenue.ToString("N0")</div>
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive-wrapper">
                        <table class="table table-sm luxury-table">
                            <thead>
                                <tr>
                                    <th>Order</th>
                                    <th>Date</th>
                                    <th>Customer</th>
                                    <th>Status</th>
                                    <th>Payment</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in adminReport.Orders.Take(10))
                                {
                                    <tr>
                                        <td>ORD-@row.OrderId.ToString("D4")</td>
                                        <td>@(row.OrderDate?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                        <td>@row.CustomerName</td>
                                        <td><span class="badge @StatusBadgeClass(row.OrderStatus) px-3 py-1 rounded-pill">@NormalizeStatus(row.OrderStatus)</span></td>
                                        <td>@row.PaymentMethod.ToUpper() / @row.PaymentStatus</td>
                                        <td>@row.TotalAmount.ToString("N0") MMK</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <div class="luxury-card">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="m-0">Daily Revenue Summary</h4>
                            <button class="btn-luxury-solid py-1 px-3" style="font-size: 0.75rem;" @onclick="TriggerDailyReport">Recalculate Today</button>
                        </div>
                        <table class="table table-sm luxury-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Orders Count</th>
                                    <th>Total Sales</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!dailyReportList.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted py-3">No sales reports logged.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var day in dailyReportList)
                                    {
                                        <tr>
                                            <td>@day.Date.ToString("dd MMM yyyy")</td>
                                            <td>@day.OrdersCount</td>
                                            <td><strong>@day.Revenue.ToString("N0") MMK</strong></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="luxury-card">
                        <h4>Staff Activity Logs</h4>
                        <hr />
                        <ul class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                            @if (!activityLogs.Any())
                            {
                                <li class="list-group-item text-center py-3 text-muted">No operational activities logged yet.</li>
                            }
                            else
                            {
                                @foreach (var log in activityLogs)
                                {
                                    <li class="list-group-item px-0 py-3 bg-transparent">
                                        <div class="d-flex justify-content-between">
                                            <strong>@log.Staff.FirstName @log.Staff.LastName</strong>
                                            <span class="small text-muted">@log.CreatedAt?.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <div class="small text-muted mt-1">
                                            <span class="badge bg-light text-dark border me-2">@log.ActionType.ToUpper()</span>
                                            @log.Description
                                        </div>
                                    </li>
                                }
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }
    </main>
</div>
