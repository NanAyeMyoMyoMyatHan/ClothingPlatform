    }
</div>


<!-- ═══════════════ CART DRAWER ═══════════════ -->
<div class="cart-backdrop @(isCartOpen ? "open" : "")" @onclick="ToggleCart"></div>
<div class="cart-drawer @(isCartOpen ? "open" : "")">
    <div class="cart-header">
        <span class="cart-title">Shopping Bag</span>
        <button class="cart-close" @onclick="ToggleCart"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="cart-body">
        @if (!cart.Any())
        {
            <div class="cart-empty">
                <i class="bi bi-bag-x" style="font-size:3rem; color:var(--rose-light);"></i>
                <p class="mt-3">Your shopping bag is empty.</p>
            </div>
        }
        else
        {
            @foreach (var item in cart)
            {
                <div class="cart-item">
                    <img class="cart-item-img" src="@item.ImgUrl" alt="@item.Name" />
                    <div class="cart-item-info">
                        <p class="cart-item-name">@item.Name</p>
                        <p class="cart-item-meta">@item.Size · @item.Color</p>
                        <div class="cart-qty">
                            <button class="qty-btn" @onclick="() => UpdateQty(item, -1)">-</button>
                            <span class="qty-num">@item.Qty</span>
                            <button class="qty-btn" @onclick="() => UpdateQty(item, 1)">+</button>
                        </div>
                    </div>
                    <div class="d-flex flex-column align-items-end justify-content-between">
                        <button class="cart-item-remove" @onclick="() => RemoveItem(item)"><i class="bi bi-trash"></i></button>
                        <span class="cart-item-price">@((item.Price * item.Qty).ToString("N0")) MMK</span>
                    </div>
                </div>
            }
        }
    </div>
    <div class="cart-footer">
        <div class="cart-subtotal-row">
            <span class="cart-subtotal-label">Subtotal</span>
            <span class="cart-subtotal-val">@CartTotal.ToString("N0") MMK</span>
        </div>
        <p class="cart-note">Fulfillment and shipping calculated at checkout.</p>
        <button class="btn-checkout" @onclick="GoCheckout">Proceed to Checkout</button>
    </div>
</div>

<!-- ═══════════════ SUCCESS OVERLAY ═══════════════ -->
<div class="success-overlay @(isSuccessOpen ? "open" : "")">
    <div class="success-icon"><i class="bi bi-check-lg"></i></div>
    <h2 class="success-title">Order Confirmed!</h2>
    <p class="success-sub">
        Thank you for your purchase. We have received your order.
        @if (selectedPayment == "cod")
        {
            <span>Our shipping coordinator will call you shortly to confirm delivery details.</span>
        }
        else
        {
            <span>Your bank payment screenshot slip has been queued for validation. We will dispatch within 2 hours.</span>
        }
        <br /><br />
        <span style="display:inline-block;background:var(--rose-pale);border:1px solid var(--rose-light);padding:8px 16px;color:var(--charcoal);font-weight:500;font-size:0.8rem;letter-spacing:0.04em;">
            ⭐ YOU EARNED @pointsEarnedInOrder.ToString("N0") LOYALTY POINTS!
        </span>
    </p>
    <p class="success-order-id">ORDER #@confirmedOrderId</p>
    <button class="btn-continue" @onclick="AfterOrder">Continue Shopping</button>
</div>

<!-- Toast container -->
<div class="toast-wrap">
    @foreach (var toast in toasts)
    {
        <div class="toast-msg">
            <i class="bi bi-check-circle-fill"></i>
            <span>@toast.Text</span>
        </div>
    }
</div>