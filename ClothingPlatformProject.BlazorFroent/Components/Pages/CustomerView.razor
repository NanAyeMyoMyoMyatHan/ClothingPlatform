            <div class="modal-img-col">
                <img src="@primaryImg" alt="@selectedProducts.Name" />
            </div>
            <div class="modal-info-col">
                <p class="modal-collection">@selectedProducts.CategoryName</p>
                <h2 class="modal-name">@selectedProducts.Name</h2>
                <p class="modal-price">@selectedProducts.BasePrice.ToString("N0") <span class="currency">MMK</span></p>
                <p class="modal-desc">@selectedProducts.Description</p>

                <label class="option-label">Select Size</label>
                <div class="size-btns">
                    @foreach (var size in selectedProducts.VariantsDto.Select(v => v.Size).Distinct())
                    {
                        <button class="size-btn @(selectedSize == size ? "selected" : "")" @onclick="() => SelectSize(size)">@size</button>
                    }
                </div>

                <label class="option-label">Select Color</label>
                <div class="color-btns">
                    @foreach (var color in selectedProducts.VariantsDto.Select(v => v.Color).Distinct())
