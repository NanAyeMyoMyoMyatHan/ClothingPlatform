    @if (selectedProducts != null)
    {
        var primaryImg = !string.IsNullOrEmpty(selectedProducts.ImageDto)
                                     ? selectedProducts.ImageDto
                                     : "https://images.unsplash.com/photo-1594938298603-c8148c4b4a43?w=600&q=80";

