@page "/customer"
@inject IJSRuntime JSRuntime
<style>
  :root {
    --rose: #C9979A;
    --rose-light: #E8CECE;
    --rose-pale: #F5ECEC;
    --charcoal: #2B2B2B;
    --charcoal-soft: #4A4A4A;
    --bg: #FDFBFB;
    --white: #FFFFFF;
    --border: #EDE5E5;
    --shadow: rgba(180,140,140,0.13);
    --gold: #C8A882;
    --success: #7DB99A;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Jost', sans-serif;
    background: var(--bg);
    color: var(--charcoal);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ═══════════════ SCROLLBAR ═══════════════ */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--rose-light); border-radius: 99px; }

  /* ═══════════════ HEADER ═══════════════ */
  #site-header {
    position: sticky; top: 0; z-index: 900;
    background: rgba(253,251,251,0.96);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .header-top {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 40px;
  }

  .logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.7rem; font-weight: 600;
    letter-spacing: 0.22em; color: var(--charcoal);
    text-decoration: none;
  }
  .logo span { color: var(--rose); }

  .logo-tagline {
    font-size: 0.62rem; letter-spacing: 0.3em; color: var(--rose);
    font-weight: 400; display: block; text-align: center; margin-top: -4px;
  }

  .header-actions { display: flex; align-items: center; gap: 20px; }

  .btn-bag {
    position: relative; background: none; border: none;
    font-size: 1.25rem; color: var(--charcoal); cursor: pointer;
    padding: 6px 10px; transition: color 0.2s;
  }
  .btn-bag:hover { color: var(--rose); }

  .bag-badge {
    position: absolute; top: 0; right: 0;
    background: var(--rose); color: #fff;
    font-size: 0.6rem; font-weight: 700;
    width: 17px; height: 17px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.3s cubic-bezier(.34,1.56,.64,1);
  }
  .bag-badge.bump { transform: scale(1.45); }

  /* ═══════════════ NAV TABS ═══════════════ */
  .nav-tabs-bar {
    display: flex; align-items: center; gap: 0;
    padding: 0 40px;
    border-top: 1px solid var(--border);
    overflow-x: auto; scrollbar-width: none;
  }
  .nav-tabs-bar::-webkit-scrollbar { display: none; }

  .nav-tab {
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem; letter-spacing: 0.17em; font-weight: 500;
    color: var(--charcoal-soft); background: none; border: none;
    padding: 14px 22px; cursor: pointer; white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    text-transform: uppercase;
  }
  .nav-tab:hover { color: var(--rose); }
  .nav-tab.active { color: var(--rose); border-bottom-color: var(--rose); }

  /* ═══════════════ VIEWS ═══════════════ */
  .view { display: none; animation: fadeIn 0.35s ease; }
  .view.active { display: block; }

  @@keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══════════════ HERO BANNER ═══════════════ */
  .hero {
    background: linear-gradient(135deg, #f9f0f0 0%, #fdf7f4 50%, #f6edf3 100%);
    padding: 80px 40px;
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; text-align: center;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 60% at 60% 40%, rgba(200,152,130,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-eyebrow {
    font-size: 0.68rem; letter-spacing: 0.35em; color: var(--rose); font-weight: 500;
    text-transform: uppercase; margin-bottom: 18px;
  }
  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.6rem, 6vw, 4.5rem); font-weight: 300;
    line-height: 1.1; color: var(--charcoal); margin-bottom: 20px;
  }
  .hero-title em { font-style: italic; color: var(--rose); }
  .hero-sub {
    font-size: 0.88rem; color: var(--charcoal-soft); font-weight: 300;
    letter-spacing: 0.05em; max-width: 420px; line-height: 1.7;
    margin-bottom: 36px;
  }
  .btn-primary-rose {
    background: var(--rose); color: #fff; border: none;
    font-family: 'Jost', sans-serif; font-size: 0.72rem;
    letter-spacing: 0.2em; font-weight: 500; text-transform: uppercase;
    padding: 14px 38px; cursor: pointer;
    transition: background 0.25s, transform 0.2s;
  }
  .btn-primary-rose:hover { background: #b8848a; transform: translateY(-1px); }

  /* ═══════════════ SECTION HEADER ═══════════════ */
  .section-head {
    padding: 56px 40px 28px;
    display: flex; align-items: flex-end; justify-content: space-between;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.1rem; font-weight: 400; color: var(--charcoal);
  }
  .section-title span { color: var(--rose); font-style: italic; }
  .section-count {
    font-size: 0.7rem; letter-spacing: 0.15em; color: var(--rose); font-weight: 500;
  }

  /* ═══════════════ PRODUCT GRID ═══════════════ */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 28px;
    padding: 0 40px 60px;
  }

  .product-card {
    background: var(--white);
    border: 1px solid var(--border);
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.28s cubic-bezier(.25,.8,.25,1), box-shadow 0.28s;
    position: relative;
  }
  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 18px 48px var(--shadow);
  }

  .card-img-wrap {
    position: relative; overflow: hidden;
    aspect-ratio: 3/4; background: var(--rose-pale);
  }
  .card-img-wrap img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.5s cubic-bezier(.25,.8,.25,1);
  }
  .product-card:hover .card-img-wrap img { transform: scale(1.06); }

  .card-badge {
    position: absolute; top: 14px; left: 14px;
    background: var(--rose); color: #fff;
    font-size: 0.58rem; letter-spacing: 0.18em; font-weight: 600;
    padding: 4px 10px; text-transform: uppercase;
  }

  .card-quick {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: rgba(43,43,43,0.82);
    color: #fff; border: none;
    font-family: 'Jost', sans-serif; font-size: 0.68rem;
    letter-spacing: 0.2em; text-transform: uppercase; font-weight: 500;
    padding: 13px;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(.25,.8,.25,1);
    cursor: pointer; width: 100%;
  }
  .product-card:hover .card-quick { transform: translateY(0); }

  .card-body { padding: 18px 18px 22px; }
  .card-collection {
    font-size: 0.6rem; letter-spacing: 0.2em; color: var(--rose); font-weight: 500;
    text-transform: uppercase; margin-bottom: 6px;
  }
  .card-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-weight: 500; color: var(--charcoal);
    margin-bottom: 8px; line-height: 1.3;
  }
  .card-price {
    font-size: 0.88rem; font-weight: 500; color: var(--charcoal-soft);
    letter-spacing: 0.03em;
  }
  .card-price .currency { font-size: 0.7rem; color: var(--rose); margin-left: 4px; }

  /* ═══════════════ PRODUCT MODAL ═══════════════ */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 1000;
    background: rgba(0,0,0,0.55); backdrop-filter: blur(4px);
    display: none; align-items: center; justify-content: center;
    padding: 20px;
  }
  .modal-overlay.open { display: flex; animation: fadeIn 0.25s ease; }

  .product-modal {
    background: var(--white);
    max-width: 800px; width: 100%;
    max-height: 90vh; overflow-y: auto;
    display: grid; grid-template-columns: 1fr 1fr;
    position: relative;
  }
  @@media (max-width: 600px) { .product-modal { grid-template-columns: 1fr; } }

  .modal-img-col {
    position: relative; aspect-ratio: 3/4;
    background: var(--rose-pale); overflow: hidden;
    min-height: 380px;
  }
  .modal-img-col img { width: 100%; height: 100%; object-fit: cover; }

  .modal-info-col { padding: 36px 32px; overflow-y: auto; }

  .modal-collection {
    font-size: 0.62rem; letter-spacing: 0.25em; color: var(--rose); font-weight: 500;
    text-transform: uppercase; margin-bottom: 10px;
  }
  .modal-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.7rem; font-weight: 400; color: var(--charcoal);
    line-height: 1.2; margin-bottom: 10px;
  }
  .modal-price {
    font-size: 1.1rem; font-weight: 500; color: var(--charcoal);
    margin-bottom: 18px;
  }
  .modal-price .currency { color: var(--rose); font-size: 0.8rem; margin-left: 5px; }
  .modal-desc {
    font-size: 0.84rem; color: var(--charcoal-soft); line-height: 1.75;
    font-weight: 300; margin-bottom: 26px;
    padding-bottom: 22px; border-bottom: 1px solid var(--border);
  }

  .option-label {
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    font-weight: 600; color: var(--charcoal); margin-bottom: 10px; display: block;
  }
  .size-btns, .color-btns { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 22px; }

  .size-btn {
    border: 1px solid var(--border); background: var(--white);
    font-family: 'Jost', sans-serif; font-size: 0.72rem; font-weight: 500;
    padding: 7px 14px; cursor: pointer; letter-spacing: 0.08em;
    transition: all 0.2s; color: var(--charcoal);
  }
  .size-btn:hover, .size-btn.selected {
    border-color: var(--rose); background: var(--rose); color: #fff;
  }

  .color-btn {
    width: 28px; height: 28px; border-radius: 50%;
    border: 2px solid var(--border); cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .color-btn:hover { transform: scale(1.15); }
  .color-btn.selected {
    box-shadow: 0 0 0 3px var(--white), 0 0 0 5px var(--rose);
  }

  .modal-error {
    font-size: 0.75rem; color: #c0392b; margin-bottom: 10px;
    display: none;
  }
  .modal-error.show { display: block; }

  .btn-add-bag {
    width: 100%; background: var(--charcoal); color: var(--white); border: none;
    font-family: 'Jost', sans-serif; font-size: 0.72rem; letter-spacing: 0.22em;
    font-weight: 500; text-transform: uppercase; padding: 16px;
    cursor: pointer; transition: background 0.25s, transform 0.2s;
  }
  .btn-add-bag:hover { background: var(--rose); transform: translateY(-1px); }

  .modal-close {
    position: absolute; top: 14px; right: 14px; z-index: 10;
    background: rgba(255,255,255,0.9); border: 1px solid var(--border);
    width: 34px; height: 34px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem; cursor: pointer; color: var(--charcoal);
    transition: background 0.2s, color 0.2s;
  }
  .modal-close:hover { background: var(--rose); color: #fff; border-color: var(--rose); }

  /* ═══════════════ CART DRAWER ═══════════════ */
  .cart-backdrop {
    position: fixed; inset: 0; z-index: 800;
    background: rgba(0,0,0,0.4); backdrop-filter: blur(3px);
    display: none;
  }
  .cart-backdrop.open { display: block; animation: fadeIn 0.25s; }

  .cart-drawer {
    position: fixed; top: 0; right: 0; bottom: 0; z-index: 850;
    width: min(420px, 100vw);
    background: var(--white);
    transform: translateX(100%);
    transition: transform 0.38s cubic-bezier(.77,0,.175,1);
    display: flex; flex-direction: column;
    box-shadow: -8px 0 48px rgba(0,0,0,0.12);
  }
  .cart-drawer.open { transform: translateX(0); }

  .cart-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 24px 28px;
    border-bottom: 1px solid var(--border);
  }
  .cart-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem; font-weight: 500; color: var(--charcoal);
    letter-spacing: 0.05em;
  }
  .cart-close {
    background: none; border: none; font-size: 1.1rem;
    color: var(--charcoal-soft); cursor: pointer;
  }
  .cart-close:hover { color: var(--rose); }

  .cart-body { flex: 1; overflow-y: auto; padding: 20px 28px; }

  .cart-empty {
    text-align: center; padding: 60px 20px;
  }
  .cart-empty i { font-size: 3rem; color: var(--rose-light); margin-bottom: 16px; display: block; }
  .cart-empty p { font-size: 0.85rem; color: var(--charcoal-soft); letter-spacing: 0.05em; }

  .cart-item {
    display: flex; gap: 14px; padding: 16px 0;
    border-bottom: 1px solid var(--border);
    animation: fadeIn 0.3s ease;
  }
  .cart-item-img {
    width: 72px; height: 90px;
    object-fit: cover; flex-shrink: 0;
    background: var(--rose-pale);
  }
  .cart-item-info { flex: 1; }
  .cart-item-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.98rem; font-weight: 500; color: var(--charcoal);
    margin-bottom: 4px; line-height: 1.3;
  }
  .cart-item-meta {
    font-size: 0.7rem; color: var(--charcoal-soft);
    letter-spacing: 0.06em; margin-bottom: 10px;
  }
  .cart-qty {
    display: flex; align-items: center; gap: 10px;
  }
  .qty-btn {
    width: 24px; height: 24px; border: 1px solid var(--border);
    background: var(--white); color: var(--charcoal);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; font-size: 0.85rem; transition: all 0.15s;
  }
  .qty-btn:hover { background: var(--rose); color: #fff; border-color: var(--rose); }
  .qty-num { font-size: 0.85rem; font-weight: 500; min-width: 20px; text-align: center; }

  .cart-item-price {
    font-size: 0.85rem; font-weight: 500; color: var(--charcoal);
    white-space: nowrap; align-self: center;
  }
  .cart-item-remove {
    background: none; border: none; color: #ccc; cursor: pointer;
    font-size: 0.8rem; align-self: flex-start; margin-top: 2px;
    transition: color 0.2s;
  }
  .cart-item-remove:hover { color: #c0392b; }

  .cart-footer {
    padding: 20px 28px 28px;
    border-top: 1px solid var(--border);
    background: var(--bg);
  }
  .cart-subtotal-row {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 6px;
  }
  .cart-subtotal-label { font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--charcoal-soft); }
  .cart-subtotal-val { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 500; color: var(--charcoal); }
  .cart-note { font-size: 0.68rem; color: var(--charcoal-soft); margin-bottom: 18px; }
  .btn-checkout {
    width: 100%; background: var(--rose); color: #fff; border: none;
    font-family: 'Jost', sans-serif; font-size: 0.72rem;
    letter-spacing: 0.22em; font-weight: 500; text-transform: uppercase;
    padding: 16px; cursor: pointer; transition: background 0.25s;
  }
  .btn-checkout:hover { background: #b8848a; }

  /* ═══════════════ CHECKOUT VIEW ═══════════════ */
  .checkout-view { padding: 50px 40px; max-width: 1100px; margin: 0 auto; }
  .checkout-grid { display: grid; grid-template-columns: 1fr 400px; gap: 40px; }
  @@media (max-width: 900px) { .checkout-grid { grid-template-columns: 1fr; } }

  .checkout-section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; font-weight: 400; color: var(--charcoal);
    margin-bottom: 24px; padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
  }

  .form-group { margin-bottom: 20px; }
  .form-label-custom {
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    font-weight: 600; color: var(--charcoal); margin-bottom: 8px; display: block;
  }
  .form-control-custom {
    width: 100%; border: 1px solid var(--border);
    background: var(--white); font-family: 'Jost', sans-serif;
    font-size: 0.88rem; color: var(--charcoal);
    padding: 12px 16px; outline: none;
    transition: border-color 0.2s;
  }
  .form-control-custom:focus { border-color: var(--rose); }
  .form-control-custom.error { border-color: #e74c3c; }

  /* Payment options */
  .payment-option {
    border: 1px solid var(--border); padding: 16px 20px;
    cursor: pointer; margin-bottom: 12px;
    display: flex; align-items: center; gap: 14px;
    transition: border-color 0.2s, background 0.2s;
  }
  .payment-option:hover { border-color: var(--rose); }
  .payment-option.selected { border-color: var(--rose); background: var(--rose-pale); }
  .payment-option input[type="radio"] { accent-color: var(--rose); }
  .payment-option-name {
    font-size: 0.85rem; font-weight: 500; color: var(--charcoal);
  }
  .payment-option-sub { font-size: 0.72rem; color: var(--charcoal-soft); }

  .qr-block {
    display: none; margin-top: 20px;
    background: var(--rose-pale); padding: 24px;
    text-align: center; border: 1px solid var(--rose-light);
    animation: fadeIn 0.3s ease;
  }
  .qr-block.show { display: block; }
  .qr-img {
    width: 160px; height: 160px; margin: 0 auto 14px;
    display: block; border: 6px solid #fff;
    box-shadow: 0 4px 20px var(--shadow);
  }
  .qr-instruction { font-size: 0.78rem; color: var(--charcoal-soft); line-height: 1.6; }
  .qr-account { font-weight: 600; color: var(--rose); font-size: 0.9rem; }

  /* Slip uploader */
  .slip-upload-zone {
    border: 2px dashed var(--rose-light); padding: 28px;
    text-align: center; cursor: pointer; transition: border-color 0.2s, background 0.2s;
    margin-top: 20px;
    position: relative;
  }
  .slip-upload-zone:hover { border-color: var(--rose); background: var(--rose-pale); }
  .slip-upload-zone input[type="file"] {
    position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
  }
  .slip-upload-icon { font-size: 2rem; color: var(--rose-light); margin-bottom: 10px; display: block; }
  .slip-upload-text { font-size: 0.78rem; color: var(--charcoal-soft); line-height: 1.6; }

  .slip-preview {
    display: none; margin-top: 16px; position: relative;
  }
  .slip-preview.show { display: block; animation: fadeIn 0.3s; }
  .slip-preview img {
    max-width: 100%; max-height: 200px;
    object-fit: contain; border: 1px solid var(--border);
    display: block;
  }
  .slip-preview-name {
    font-size: 0.72rem; color: var(--success); margin-top: 8px;
    display: flex; align-items: center; gap: 6px;
  }

  /* Order summary panel */
  .order-summary-panel {
    background: var(--white); border: 1px solid var(--border); padding: 28px;
  }
  .order-summary-item {
    display: flex; gap: 12px; padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  .order-summary-item:last-of-type { border-bottom: none; }
  .order-summary-img {
    width: 56px; height: 70px; object-fit: cover; background: var(--rose-pale);
    flex-shrink: 0;
  }
  .order-sum-name {
    font-family: 'Cormorant Garamond', serif; font-size: 0.95rem; font-weight: 500;
    color: var(--charcoal); margin-bottom: 3px;
  }
  .order-sum-meta { font-size: 0.68rem; color: var(--charcoal-soft); }
  .order-sum-price { font-size: 0.82rem; font-weight: 500; color: var(--charcoal-soft); margin-top: 4px; }

  .summary-total-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 18px 0 0; margin-top: 8px;
    border-top: 1px solid var(--border);
  }
  .summary-total-label { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--charcoal-soft); }
  .summary-total-val { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 500; color: var(--charcoal); }

  .btn-place-order {
    width: 100%; background: var(--charcoal); color: #fff; border: none;
    font-family: 'Jost', sans-serif; font-size: 0.72rem; letter-spacing: 0.22em;
    font-weight: 500; text-transform: uppercase; padding: 18px; cursor: pointer;
    transition: background 0.25s; margin-top: 20px;
  }
  .btn-place-order:hover { background: var(--rose); }

  /* ═══════════════ SUCCESS OVERLAY ═══════════════ */
  .success-overlay {
    position: fixed; inset: 0; z-index: 2000;
    background: rgba(253,251,251,0.97); backdrop-filter: blur(8px);
    display: none; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; padding: 40px;
    animation: fadeIn 0.4s ease;
  }
  .success-overlay.open { display: flex; }

  .success-icon {
    width: 80px; height: 80px; border-radius: 50%;
    background: linear-gradient(135deg, var(--rose-light), var(--rose));
    display: flex; align-items: center; justify-content: center;
    font-size: 2.2rem; color: #fff; margin-bottom: 28px;
    animation: popIn 0.5s cubic-bezier(.34,1.56,.64,1) 0.2s both;
  }
  @@keyframes popIn {
    from { transform: scale(0.3); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .success-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem; font-weight: 400; color: var(--charcoal);
    margin-bottom: 14px;
  }
  .success-sub {
    font-size: 0.88rem; color: var(--charcoal-soft); line-height: 1.7;
    max-width: 400px; margin-bottom: 10px; font-weight: 300;
  }
  .success-order-id {
    font-size: 0.78rem; color: var(--rose); letter-spacing: 0.2em;
    font-weight: 500; margin-bottom: 36px;
  }
  .btn-continue {
    background: none; border: 1px solid var(--charcoal); color: var(--charcoal);
    font-family: 'Jost', sans-serif; font-size: 0.72rem; letter-spacing: 0.2em;
    font-weight: 500; text-transform: uppercase; padding: 13px 36px;
    cursor: pointer; transition: all 0.25s;
  }
  .btn-continue:hover { background: var(--charcoal); color: #fff; }

  /* ═══════════════ PURCHASE HISTORY ═══════════════ */
  .history-view { padding: 50px 40px; max-width: 900px; margin: 0 auto; }

  .history-card {
    background: var(--white); border: 1px solid var(--border);
    margin-bottom: 24px; overflow: hidden;
    animation: fadeIn 0.35s ease;
  }
  .history-card-header {
    display: flex; flex-wrap: wrap; gap: 16px; align-items: center;
    justify-content: space-between;
    padding: 18px 24px; background: var(--rose-pale);
    border-bottom: 1px solid var(--rose-light);
  }
  .history-order-id {
    font-size: 0.7rem; letter-spacing: 0.18em; font-weight: 600;
    color: var(--charcoal); text-transform: uppercase;
  }
  .history-date { font-size: 0.75rem; color: var(--charcoal-soft); }
  .history-total { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 500; color: var(--charcoal); }

  .badge-delivered {
    background: #d5ede6; color: #2e7d5e; font-size: 0.62rem;
    letter-spacing: 0.15em; font-weight: 600; text-transform: uppercase;
    padding: 4px 12px;
  }
  .badge-processing {
    background: #fef3e4; color: #c07826; font-size: 0.62rem;
    letter-spacing: 0.15em; font-weight: 600; text-transform: uppercase;
    padding: 4px 12px;
  }
  .badge-pending {
    background: #e8eaf6; color: #5c6bc0; font-size: 0.62rem;
    letter-spacing: 0.15em; font-weight: 600; text-transform: uppercase;
    padding: 4px 12px;
  }

  .history-items { padding: 16px 24px; }
  .history-item-row {
    display: flex; gap: 14px; padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  .history-item-row:last-child { border-bottom: none; }
  .history-item-img {
    width: 52px; height: 65px; object-fit: cover;
    background: var(--rose-pale); flex-shrink: 0;
  }
  .history-item-name { font-family: 'Cormorant Garamond', serif; font-size: 0.95rem; font-weight: 500; color: var(--charcoal); }
  .history-item-meta { font-size: 0.7rem; color: var(--charcoal-soft); margin-top: 3px; }
  .history-item-price { font-size: 0.82rem; font-weight: 500; color: var(--charcoal-soft); margin-top: 4px; }

  /* ═══════════════ TOAST ═══════════════ */
  .toast-wrap {
    position: fixed; bottom: 30px; right: 30px; z-index: 3000;
    display: flex; flex-direction: column; gap: 10px;
  }
  .toast-msg {
    background: var(--charcoal); color: #fff;
    padding: 12px 20px; font-size: 0.78rem; letter-spacing: 0.06em;
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
    animation: toastIn 0.35s cubic-bezier(.34,1.56,.64,1);
    display: flex; align-items: center; gap: 10px;
  }
  .toast-msg i { color: var(--rose-light); }
  @@keyframes toastIn {
    from { transform: translateX(120%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  /* ═══════════════ PROFILE VIEW ═══════════════ */
  .profile-view {
    padding: 50px 40px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .profile-grid {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 40px;
  }
  @@media (max-width: 900px) {
    .profile-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }
  .profile-card {
    background: var(--white);
    border: 1px solid var(--border);
    padding: 36px 30px;
    text-align: center;
    position: relative;
    box-shadow: 0 10px 30px var(--shadow);
  }
  .profile-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 6px;
    background: linear-gradient(90deg, var(--rose-light), var(--rose));
  }
  .profile-avatar-wrap {
    position: relative;
    width: 130px;
    height: 130px;
    margin: 0 auto 24px;
    border-radius: 50%;
    border: 3px solid var(--white);
    box-shadow: 0 8px 24px var(--shadow);
    overflow: hidden;
    background: var(--rose-pale);
  }
  .profile-avatar-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .profile-avatar-edit {
    position: absolute;
    inset: 0;
    background: rgba(43,43,43,0.6);
    color: #fff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.25s;
  }
  .profile-avatar-wrap:hover .profile-avatar-edit {
    opacity: 1;
  }
  .profile-avatar-edit i {
    font-size: 1.2rem;
    margin-bottom: 4px;
  }
  .profile-avatar-edit input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }
  .profile-name-display {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--charcoal);
    margin-bottom: 6px;
  }
  .profile-tier-badge {
    display: inline-block;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--white);
    background: var(--rose);
    padding: 5px 14px;
    border-radius: 20px;
    margin-bottom: 20px;
  }
  .profile-joined {
    font-size: 0.72rem;
    color: var(--charcoal-soft);
    margin-bottom: 24px;
  }
  
  /* Loyalty Points display */
  .loyalty-points-box {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 20px;
    margin-bottom: 24px;
    text-align: left;
  }
  .points-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
  .points-label {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--charcoal-soft);
    font-weight: 600;
  }
  .points-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--rose);
  }
  .points-progress-bar {
    height: 5px;
    background: var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .points-progress-fill {
    height: 100%;
    background: var(--rose);
    width: 57%; /* 2850 out of 5000 */
    border-radius: 10px;
    transition: width 0.5s ease;
  }
  .points-next-tier {
    font-size: 0.65rem;
    color: var(--charcoal-soft);
    display: block;
    text-align: right;
  }
  
  /* Member privileges */
  .privileges-list {
    text-align: left;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }
  .privileges-title {
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 12px;
  }
  .privilege-item {
    font-size: 0.78rem;
    color: var(--charcoal-soft);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .privilege-item i {
    color: var(--success);
    font-size: 0.85rem;
  }

  /* Form and inputs on right side */
  .profile-form-panel {
    background: var(--white);
    border: 1px solid var(--border);
    padding: 36px;
    box-shadow: 0 10px 30px var(--shadow);
  }
  .profile-section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--charcoal);
    margin-bottom: 24px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
  }
  .btn-save-profile {
    background: var(--charcoal);
    color: #fff;
    border: none;
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    font-weight: 500;
    text-transform: uppercase;
    padding: 16px 36px;
    cursor: pointer;
    transition: background 0.25s, transform 0.2s;
    margin-top: 10px;
  }
  .btn-save-profile:hover {
    background: var(--rose);
    transform: translateY(-1px);
  }
  
  /* Extra style for profile button in header */
  .btn-profile {
    background: none;
    border: none;
    font-size: 1.25rem;
    color: var(--charcoal);
    cursor: pointer;
    padding: 6px 10px;
    transition: color 0.2s;
  }
  .btn-profile:hover {
    color: var(--rose);
  }

  /* ═══════════════ RESPONSIVE ═══════════════ */
  @@media (max-width: 768px) {
    .header-top { padding: 14px 20px; }
    .nav-tabs-bar { padding: 0 10px; }
    .nav-tab { padding: 12px 14px; }
    .hero { padding: 50px 24px; }
    .section-head, .products-grid { padding-left: 20px; padding-right: 20px; }
    .products-grid { gap: 16px; }
    .checkout-view, .history-view { padding: 30px 20px; }
  }
</style>

<body>

<!-- ═══════════════ HEADER ═══════════════ -->
<header id="site-header">
  <div class="header-top">
    <a class="logo" href="#" onclick="navigate('home'); return false;">
      THE <span>BOUTIQUE</span>
      <span class="logo-tagline">MYANMAR LUXURY FASHION</span>
    </a>
    <div class="header-actions">
      <button class="btn-profile" onclick="navigate('profile')" aria-label="My Profile">
        <i class="far fa-user"></i>
      </button>
      <button class="btn-bag" onclick="toggleCart()" aria-label="Shopping bag">
        <i class="fas fa-shopping-bag"></i>
        <span class="bag-badge" id="bag-badge">0</span>
      </button>
    </div>
  </div>
  <nav class="nav-tabs-bar">
    <button class="nav-tab active" id="tab-home" onclick="navigate('home')">All Collections</button>
    <button class="nav-tab" id="tab-new" onclick="navigate('new')">New Arrivals</button>
    <button class="nav-tab" id="tab-best" onclick="navigate('best')">Best Sellers</button>
    <button class="nav-tab" id="tab-silk" onclick="navigate('silk')">Traditional Silk</button>
    <button class="nav-tab" id="tab-history" onclick="navigate('history')">My Purchases</button>
    <button class="nav-tab" id="tab-profile" onclick="navigate('profile')">My Profile</button>
  </nav>
</header>

<!-- ═══════════════ VIEWS ═══════════════ -->
<main>

  <!-- HOME VIEW -->
  <div class="view active" id="view-home">
    <div class="hero">
      <p class="hero-eyebrow">New Season — Summer 2025</p>
      <h1 class="hero-title">Dress for the<br><em>Woman You Are</em></h1>
      <p class="hero-sub">Curated luxury for the modern Burmese woman — where heritage meets contemporary elegance.</p>
      <button class="btn-primary-rose" onclick="navigate('new')">Explore New Arrivals</button>
    </div>
    <div class="section-head">
      <div>
        <p class="section-count">30 CURATED PIECES</p>
        <h2 class="section-title">All <span>Collections</span></h2>
      </div>
    </div>
    <div class="products-grid" id="grid-home"></div>
  </div>

  <!-- NEW ARRIVALS VIEW -->
  <div class="view" id="view-new">
    <div class="section-head">
      <div>
        <p class="section-count">10 PIECES</p>
        <h2 class="section-title">New <span>Arrivals</span></h2>
      </div>
    </div>
    <div class="products-grid" id="grid-new"></div>
  </div>

  <!-- BEST SELLERS VIEW -->
  <div class="view" id="view-best">
    <div class="section-head">
      <div>
        <p class="section-count">10 PIECES</p>
        <h2 class="section-title">Best <span>Sellers</span></h2>
      </div>
    </div>
    <div class="products-grid" id="grid-best"></div>
  </div>

  <!-- TRADITIONAL SILK VIEW -->
  <div class="view" id="view-silk">
    <div class="section-head">
      <div>
        <p class="section-count">10 PIECES</p>
        <h2 class="section-title">Traditional <span>Silk</span></h2>
      </div>
    </div>
    <div class="products-grid" id="grid-silk"></div>
  </div>

  <!-- CHECKOUT VIEW -->
  <div class="view" id="view-checkout">
    <div class="checkout-view">
      <div class="checkout-grid">
        <!-- LEFT: Delivery + Payment -->
        <div>
          <h2 class="checkout-section-title">Delivery Information</h2>

          <div class="form-group">
            <label class="form-label-custom">Full Name</label>
            <input class="form-control-custom" id="co-name" type="text" placeholder="Your name"/>
          </div>
          <div class="form-group">
            <label class="form-label-custom">Phone Number</label>
            <input class="form-control-custom" id="co-phone" type="tel" placeholder="09xxxxxxxxx"/>
          </div>
          <div class="form-group">
            <label class="form-label-custom">Full Address</label>
            <input class="form-control-custom" id="co-address" type="text" placeholder="Street, Township"/>
          </div>
          <div class="form-group">
            <label class="form-label-custom">City</label>
            <input class="form-control-custom" id="co-city" type="text" placeholder="Yangon / Mandalay / etc."/>
          </div>

          <h2 class="checkout-section-title" style="margin-top:36px;">Payment Method</h2>

          <div class="payment-option" onclick="selectPayment('kbz')" id="pay-kbz">
            <input type="radio" name="payment" value="kbz" id="radio-kbz"/>
            <div>
              <div class="payment-option-name">KBZ Pay</div>
              <div class="payment-option-sub">KBZ Bank Mobile Wallet</div>
            </div>
          </div>
          <div class="payment-option" onclick="selectPayment('wave')" id="pay-wave">
            <input type="radio" name="payment" value="wave" id="radio-wave"/>
            <div>
              <div class="payment-option-name">Wave Money</div>
              <div class="payment-option-sub">Wave Financial Services</div>
            </div>
          </div>
          <div class="payment-option" onclick="selectPayment('cod')" id="pay-cod">
            <input type="radio" name="payment" value="cod" id="radio-cod"/>
            <div>
              <div class="payment-option-name">Cash on Delivery (COD)</div>
              <div class="payment-option-sub">Pay in cash upon delivery of your items</div>
            </div>
          </div>

          <!-- QR Blocks -->
          <div class="qr-block" id="qr-kbz">
            <img src="https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=KBZPay%3A09977665544%3ATheBoutique&color=C9979A&bgcolor=F5ECEC" alt="KBZ Pay QR" class="qr-img"/>
            <p class="qr-instruction">Scan with your <strong>KBZ Pay</strong> app<br/>or transfer to:<br/><span class="qr-account">09 977 665 544</span><br/>(Account Name: The Boutique Co., Ltd.)<br/><br/>Reference: Your phone number</p>
          </div>
          <div class="qr-block" id="qr-wave">
            <img src="https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=WaveMoney%3A09944332211%3ATheBoutique&color=C9979A&bgcolor=F5ECEC" alt="Wave Money QR" class="qr-img"/>
            <p class="qr-instruction">Scan with your <strong>Wave Money</strong> app<br/>or transfer to:<br/><span class="qr-account">09 944 332 211</span><br/>(Account Name: The Boutique Co., Ltd.)<br/><br/>Reference: Your phone number</p>
          </div>

          <!-- Slip Upload -->
          <div class="slip-upload-zone" id="slip-zone">
            <input type="file" id="slip-input" accept="image/*" onchange="handleSlipUpload(event)"/>
            <i class="fas fa-cloud-upload-alt slip-upload-icon"></i>
            <p class="slip-upload-text"><strong>Upload Payment Screenshot</strong><br/>Click or drag & drop your transfer slip here<br/><span style="font-size:0.68rem;color:var(--rose-light)">JPG, PNG, WEBP accepted</span></p>
          </div>
          <div class="slip-preview" id="slip-preview">
            <img id="slip-preview-img" src="" alt="Payment slip"/>
            <p class="slip-preview-name"><i class="fas fa-check-circle" style="color:var(--success)"></i> <span id="slip-file-name">slip.jpg</span> — uploaded successfully</p>
          </div>
        </div>

        <!-- RIGHT: Order Summary -->
        <div>
          <h2 class="checkout-section-title">Order Summary</h2>
          <div class="order-summary-panel">
            <div id="order-summary-items"></div>
            <div class="summary-total-row">
              <span class="summary-total-label">Total</span>
              <span class="summary-total-val" id="order-summary-total">0 MMK</span>
            </div>
            <button class="btn-place-order" onclick="placeOrder()">Submit Payment &amp; Place Order</button>
            <p style="font-size:0.68rem;color:var(--charcoal-soft);margin-top:12px;text-align:center;line-height:1.6;">By placing your order you agree to our terms. Payment slip will be sent to our staff for verification.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- HISTORY VIEW -->
  <div class="view" id="view-history">
    <div class="history-view">
      <div class="section-head" style="padding:0 0 28px;">
        <div>
          <p class="section-count" id="history-client-name">EMILY WATSON</p>
          <h2 class="section-title">Purchase <span>History</span></h2>
        </div>
      </div>
      <div id="history-list"></div>
    </div>
  </div>

  <!-- PROFILE VIEW -->
  <div class="view" id="view-profile">
    <div class="profile-view">
      <div class="profile-grid">
        <!-- LEFT COLUMN: Avatar & Loyalty Status -->
        <div class="profile-card">
          <div class="profile-avatar-wrap">
            <img id="profile-avatar-img" src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=300&q=80" alt="Avatar"/>
            <div class="profile-avatar-edit">
              <i class="fas fa-camera"></i>
              <span>Change</span>
              <input type="file" id="profile-avatar-input" accept="image/*" onchange="handleAvatarUpload(event)"/>
            </div>
          </div>
          <h2 class="profile-name-display" id="profile-name-display">Emily Watson</h2>
          <span class="profile-tier-badge" id="profile-tier-badge">Elite VIP Member</span>
          <p class="profile-joined">Member since: <span id="profile-joined-date">12 January 2024</span></p>
          
          <div class="loyalty-points-box">
            <div class="points-header">
              <span class="points-label">Loyalty Points</span>
              <span class="points-value" id="profile-points-display">2,850 pts</span>
            </div>
            <div class="points-progress-bar">
              <div class="points-progress-fill" id="profile-points-progress" style="width: 57%;"></div>
            </div>
            <span class="points-next-tier" id="profile-next-tier-text">2,150 pts to Royal Circle</span>
          </div>

          <div class="privileges-list">
            <h3 class="privileges-title">Atelier Privileges</h3>
            <div class="privilege-item">
              <i class="fas fa-check-circle"></i>
              <span>10% Discount on all collections</span>
            </div>
            <div class="privilege-item">
              <i class="fas fa-check-circle"></i>
              <span>Free express delivery within Yangon</span>
            </div>
            <div class="privilege-item">
              <i class="fas fa-check-circle"></i>
              <span>Priority previews of new arrivals</span>
            </div>
            <div class="privilege-item">
              <i class="fas fa-check-circle"></i>
              <span>Dedicated styling consultant</span>
            </div>
          </div>
        </div>

        <!-- RIGHT COLUMN: Editable Form -->
        <div class="profile-form-panel">
          <h2 class="profile-section-title">Personal Details</h2>
          
          <div class="form-group">
            <label class="form-label-custom">Full Name</label>
            <input class="form-control-custom" id="prof-name" type="text" placeholder="Your name"/>
          </div>
          
          <div class="form-group">
            <label class="form-label-custom">Email Address</label>
            <input class="form-control-custom" id="prof-email" type="email" placeholder="you@example.com"/>
          </div>
          
          <div class="form-group">
            <label class="form-label-custom">Phone Number</label>
            <input class="form-control-custom" id="prof-phone" type="tel" placeholder="09xxxxxxxxx"/>
          </div>

          <h2 class="profile-section-title" style="margin-top:36px;">Shipping Address</h2>
          
          <div class="form-group">
            <label class="form-label-custom">Delivery Address</label>
            <input class="form-control-custom" id="prof-address" type="text" placeholder="Street, Apartment, Township"/>
          </div>
          
          <div class="form-group">
            <label class="form-label-custom">City</label>
            <input class="form-control-custom" id="prof-city" type="text" placeholder="Yangon / Mandalay / etc."/>
          </div>

          <button class="btn-save-profile" onclick="saveProfile()">Save Changes</button>
        </div>
      </div>
    </div>
  </div>

</main>

<!-- ═══════════════ PRODUCT MODAL ═══════════════ -->
<div class="modal-overlay" id="product-modal">
  <div class="product-modal">
    <button class="modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>
    <div class="modal-img-col">
      <img id="modal-img" src="" alt=""/>
    </div>
    <div class="modal-info-col">
      <p class="modal-collection" id="modal-collection"></p>
      <h2 class="modal-name" id="modal-name"></h2>
      <p class="modal-price" id="modal-price"></p>
      <p class="modal-desc" id="modal-desc"></p>

      <label class="option-label">Select Size</label>
      <div class="size-btns" id="modal-sizes"></div>

      <label class="option-label">Select Color</label>
      <div class="color-btns" id="modal-colors"></div>

      <p class="modal-error" id="modal-error">Please select a size and color before adding to bag.</p>
      <button class="btn-add-bag" onclick="addToBag()">Add to Bag</button>
    </div>
