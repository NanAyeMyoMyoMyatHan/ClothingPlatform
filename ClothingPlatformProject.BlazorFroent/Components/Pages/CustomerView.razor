/* ====================================================
   NAVIGATION
==================================================== */
function navigate(view) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));

  const viewEl = document.getElementById('view-' + view);
  const tabEl  = document.getElementById('tab-' + view);
  if (viewEl) viewEl.classList.add('active');
  if (tabEl)  tabEl.classList.add('active');

  if (view === 'history') renderHistory();
  if (view === 'checkout') {
    autofillCheckoutFromProfile();
    renderOrderSummary();
  }
  if (view === 'profile') renderProfile();

  window.scrollTo({ top: 0, behavior: 'smooth' });
}

/* ====================================================
   PRODUCT RENDERING
==================================================== */
function formatPrice(n) {
  return n.toLocaleString('en-US') + ' <span class="currency">MMK</span>';
}

function buildCard(p) {
  return `
    <div class="product-card" onclick="openModal('${p.id}')">
      <div class="card-img-wrap">
        <img src="${p.img}" alt="${p.name}" loading="lazy"/>
        <span class="card-badge">${p.badge}</span>
        <button class="card-quick">Quick View &amp; Buy</button>
      </div>
      <div class="card-body">
        <p class="card-collection">${p.collection}</p>
        <h3 class="card-name">${p.name}</h3>
        <p class="card-price">${formatPrice(p.price)}</p>
      </div>
    </div>`;
}

function renderGrid(gridId, products) {
  document.getElementById(gridId).innerHTML = products.map(buildCard).join('');
}

function initGrids() {
  renderGrid('grid-home', PRODUCTS);
  renderGrid('grid-new',  PRODUCTS.filter(p => p.collection === 'New Arrivals'));
  renderGrid('grid-best', PRODUCTS.filter(p => p.collection === 'Best Sellers'));
  renderGrid('grid-silk', PRODUCTS.filter(p => p.collection === 'Traditional Silk'));
}

/* ====================================================
   PRODUCT MODAL
==================================================== */
function openModal(id) {
  const p = PRODUCTS.find(x => x.id === id);
  if (!p) return;
  currentProduct = p;
  selectedSize = null;
  selectedColor = null;

  document.getElementById('modal-img').src        = p.img;
  document.getElementById('modal-collection').textContent = p.collection;
  document.getElementById('modal-name').textContent       = p.name;
  document.getElementById('modal-price').innerHTML        = formatPrice(p.price);
  document.getElementById('modal-desc').textContent       = p.desc;
  document.getElementById('modal-error').classList.remove('show');

  // Sizes
  document.getElementById('modal-sizes').innerHTML = p.sizes.map(s =>
    `<button class="size-btn" onclick="selectSize(this,'${s}')">${s}</button>`
  ).join('');

  // Colors
  document.getElementById('modal-colors').innerHTML = p.colors.map(c =>
    `<button class="color-btn" title="${c}" style="background:${colorMap[c] || '#ccc'}" onclick="selectColor(this,'${c}')"></button>`
  ).join('');

  document.getElementById('product-modal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('product-modal').classList.remove('open');
  document.body.style.overflow = '';
}

function selectSize(btn, size) {
  document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  selectedSize = size;
}

function selectColor(btn, color) {
  document.querySelectorAll('.color-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  selectedColor = color;
}

function addToBag() {
  if (!selectedSize || !selectedColor) {
    document.getElementById('modal-error').classList.add('show');
    return;
  }

  const existing = cart.find(i =>
    i.id === currentProduct.id && i.size === selectedSize && i.color === selectedColor
  );

  if (existing) {
    existing.qty++;
  } else {
    cart.push({
      id: currentProduct.id,
      name: currentProduct.name,
      price: currentProduct.price,
      img: currentProduct.img,
      collection: currentProduct.collection,
      size: selectedSize,
      color: selectedColor,
      qty: 1,
    });
  }

  updateBadge();
  closeModal();
  renderCart();
  showToast(`"${currentProduct.name}" added to bag`);
}

/* ====================================================
   CART
==================================================== */
function toggleCart() {
  const drawer = document.getElementById('cart-drawer');
  const back   = document.getElementById('cart-backdrop');
  const open   = drawer.classList.contains('open');
  drawer.classList.toggle('open', !open);
  back.classList.toggle('open', !open);
  document.body.style.overflow = open ? '' : 'hidden';
  if (!open) renderCart();
}

function updateBadge() {
  const total = cart.reduce((s, i) => s + i.qty, 0);
  const badge = document.getElementById('bag-badge');
  badge.textContent = total;
  badge.classList.add('bump');
  setTimeout(() => badge.classList.remove('bump'), 350);
}

function cartTotal() {
  return cart.reduce((s, i) => s + i.price * i.qty, 0);
}

function renderCart() {
  const body = document.getElementById('cart-body');
  const totalEl = document.getElementById('cart-total');
  totalEl.innerHTML = formatPrice(cartTotal());

  if (cart.length === 0) {
    body.innerHTML = `
      <div class="cart-empty">
        <i class="far fa-heart"></i>
        <p>Your bag is empty.<br/>Discover our collections.</p>
      </div>`;
    return;
  }

  body.innerHTML = cart.map((item, idx) => `
    <div class="cart-item">
      <img class="cart-item-img" src="${item.img}" alt="${item.name}"/>
      <div class="cart-item-info">
        <p class="cart-item-name">${item.name}</p>
        <p class="cart-item-meta">${item.size} · ${item.color}</p>
        <div class="cart-qty">
          <button class="qty-btn" onclick="changeQty(${idx},-1)">−</button>
          <span class="qty-num">${item.qty}</span>
          <button class="qty-btn" onclick="changeQty(${idx},1)">+</button>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;justify-content:space-between;">
        <button class="cart-item-remove" onclick="removeItem(${idx})"><i class="fas fa-times"></i></button>
        <span class="cart-item-price">${(item.price * item.qty).toLocaleString()} MMK</span>
      </div>
    </div>`
  ).join('');
}

function changeQty(idx, delta) {
  cart[idx].qty += delta;
  if (cart[idx].qty <= 0) cart.splice(idx, 1);
  updateBadge();
  renderCart();
}

function removeItem(idx) {
  cart.splice(idx, 1);
  updateBadge();
  renderCart();
}

function goCheckout() {
  if (cart.length === 0) { showToast('Your bag is empty!'); return; }
  toggleCart();
  navigate('checkout');
}

/* ====================================================
   CHECKOUT
==================================================== */
function selectPayment(method) {
  selectedPayment = method;
  document.getElementById('radio-kbz').checked = method === 'kbz';
  document.getElementById('radio-wave').checked = method === 'wave';
  document.getElementById('radio-cod').checked = method === 'cod';
  
  document.getElementById('pay-kbz').classList.toggle('selected', method === 'kbz');
  document.getElementById('pay-wave').classList.toggle('selected', method === 'wave');
  document.getElementById('pay-cod').classList.toggle('selected', method === 'cod');
  
  document.getElementById('qr-kbz').classList.toggle('show', method === 'kbz');
  document.getElementById('qr-wave').classList.toggle('show', method === 'wave');

  // Slip upload requirements
  const slipZone = document.getElementById('slip-zone');
  const slipPreview = document.getElementById('slip-preview');
  if (method === 'cod') {
    slipZone.style.display = 'none';
    slipPreview.classList.remove('show');
    slipUploaded = true;
  } else {
    slipZone.style.display = 'block';
    const slipImg = document.getElementById('slip-preview-img');
    if (slipImg && slipImg.src && slipImg.src.startsWith('data:')) {
      slipPreview.classList.add('show');
      slipUploaded = true;
    } else {
      slipPreview.classList.remove('show');
      slipUploaded = false;
    }
  }
}

function handleSlipUpload(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    document.getElementById('slip-preview-img').src = ev.target.result;
    document.getElementById('slip-file-name').textContent = file.name;
    document.getElementById('slip-preview').classList.add('show');
    slipUploaded = true;
  };
  reader.readAsDataURL(file);
}

function renderOrderSummary() {
  const itemsEl = document.getElementById('order-summary-items');
  const totalEl = document.getElementById('order-summary-total');
  totalEl.innerHTML = formatPrice(cartTotal());

  if (cart.length === 0) {
    itemsEl.innerHTML = '<p style="font-size:0.8rem;color:var(--charcoal-soft);text-align:center;padding:20px 0">No items in bag</p>';
    return;
  }

  itemsEl.innerHTML = cart.map(item => `
    <div class="order-summary-item">
      <img class="order-summary-img" src="${item.img}" alt="${item.name}"/>
      <div>
        <p class="order-sum-name">${item.name}</p>
        <p class="order-sum-meta">${item.size} · ${item.color} · Qty ${item.qty}</p>
        <p class="order-sum-price">${(item.price * item.qty).toLocaleString()} MMK</p>
      </div>
    </div>`
  ).join('');
}

function placeOrder() {
  const name    = document.getElementById('co-name').value.trim();
  const phone   = document.getElementById('co-phone').value.trim();
  const address = document.getElementById('co-address').value.trim();
  const city    = document.getElementById('co-city').value.trim();

  let valid = true;
  ['co-name','co-phone','co-address','co-city'].forEach(id => {
    const el = document.getElementById(id);
    if (!el.value.trim()) { el.classList.add('error'); valid = false; }
    else el.classList.remove('error');
  });

  if (!valid) { showToast('Please fill in all delivery details'); return; }
  if (!selectedPayment) { showToast('Please select a payment method'); return; }
  if (!slipUploaded) { showToast('Please upload your payment screenshot'); return; }
  if (cart.length === 0) { showToast('Your bag is empty'); return; }

  const orderId = 'TB-' + Date.now().toString().slice(-6);
  const now = new Date();
  const dateStr = now.getDate() + ' ' + now.toLocaleString('en-US',{month:'long'}) + ' ' + now.getFullYear();

  const orderTotal = cartTotal();

  const newOrder = {
    orderId,
    date: dateStr,
    status: 'Processing',
    total: orderTotal,
    items: cart.map(i => ({
      name: i.name, size: i.size, color: i.color, qty: i.qty, price: i.price, img: i.img
    }))
  };

  purchaseHistory.unshift(newOrder);

  // Earn loyalty points (1 point per 100 MMK spent)
  const earnedPoints = Math.floor(orderTotal / 100);
  customerProfile.points += earnedPoints;

  // Show points in success overlay
  const successSub = document.querySelector('.success-overlay .success-sub');
  if (successSub) {
    let orderMsg = '';
    if (selectedPayment === 'cod') {
      orderMsg = `Thank you for your purchase. Your order has been placed successfully via Cash on Delivery. We will call you shortly to confirm delivery details.`;
    } else {
      orderMsg = `Thank you for your purchase. Your payment slip has been sent to our staff verification queue. We'll confirm your order within 2 hours.`;
    }
    successSub.innerHTML = `${orderMsg}<br/><br/><span style="display:inline-block;background:var(--rose-pale);border:1px solid var(--rose-light);padding:8px 16px;color:var(--charcoal);font-weight:500;margin-top:6px;font-size:0.8rem;letter-spacing:0.04em;">⭐ YOU EARNED ${earnedPoints.toLocaleString()} LOYALTY POINTS!</span>`;
  }

  document.getElementById('success-order-id').textContent = 'ORDER #' + orderId;
  document.getElementById('success-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function afterOrder() {
  document.getElementById('success-overlay').classList.remove('open');
  document.body.style.overflow = '';

  // Reset
  cart = [];
  selectedPayment = null;
  slipUploaded = false;
  ['co-name','co-phone','co-address','co-city'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('slip-preview').classList.remove('show');
  document.getElementById('slip-preview-img').src = '';
  document.getElementById('qr-kbz').classList.remove('show');
  document.getElementById('qr-wave').classList.remove('show');
  document.getElementById('pay-kbz').classList.remove('selected');
  document.getElementById('pay-wave').classList.remove('selected');
  document.getElementById('pay-cod').classList.remove('selected');
  document.getElementById('radio-kbz').checked = false;
  document.getElementById('radio-wave').checked = false;
  document.getElementById('radio-cod').checked = false;
  document.getElementById('slip-zone').style.display = 'block';

  updateBadge();
  navigate('history');
}

/* ====================================================
   CUSTOMER PROFILE
==================================================== */
function renderProfile() {
  // Populate text fields
  document.getElementById('prof-name').value = customerProfile.name;
  document.getElementById('prof-email').value = customerProfile.email;
  document.getElementById('prof-phone').value = customerProfile.phone;
  document.getElementById('prof-address').value = customerProfile.address;
  document.getElementById('prof-city').value = customerProfile.city;

  // Populate card display
  document.getElementById('profile-name-display').textContent = customerProfile.name;
  document.getElementById('profile-tier-badge').textContent = customerProfile.tier;
  document.getElementById('profile-joined-date').textContent = customerProfile.joined;
  document.getElementById('profile-avatar-img').src = customerProfile.avatar;
  
  // Loyalty details
  document.getElementById('profile-points-display').textContent = customerProfile.points.toLocaleString() + ' pts';
  
  // Calculate progress to next tier
  let nextTierPoints = 5000;
  let pointsNeeded = nextTierPoints - customerProfile.points;
  let pct = (customerProfile.points / nextTierPoints) * 100;
  if (pct > 100) pct = 100;
  
  document.getElementById('profile-points-progress').style.width = pct + '%';
  const nextTierText = document.getElementById('profile-next-tier-text');
  if (pointsNeeded > 0) {
    nextTierText.textContent = pointsNeeded.toLocaleString() + ' pts to Royal Circle';
  } else {
    nextTierText.textContent = 'Maximum Tier Achieved';
  }
}

function saveProfile() {
  const name = document.getElementById('prof-name').value.trim();
  const email = document.getElementById('prof-email').value.trim();
  const phone = document.getElementById('prof-phone').value.trim();
  const address = document.getElementById('prof-address').value.trim();
  const city = document.getElementById('prof-city').value.trim();

  let valid = true;
  ['prof-name', 'prof-email', 'prof-phone', 'prof-address', 'prof-city'].forEach(id => {
    const el = document.getElementById(id);
    if (!el.value.trim()) {
      el.classList.add('error');
      valid = false;
    } else {
      el.classList.remove('error');
    }
  });

  if (!valid) {
    showToast('Please fill in all profile details');
    return;
  }

  // Update customerProfile object
  customerProfile.name = name;
  customerProfile.email = email;
  customerProfile.phone = phone;
  customerProfile.address = address;
  customerProfile.city = city;

  // Refresh display
  renderProfile();
  
  // Sync history header name
  const nameEl = document.getElementById('history-client-name');
  if (nameEl) nameEl.textContent = customerProfile.name.toUpperCase();
  
  // Also update pre-filled values in Checkout inputs directly
  const coName = document.getElementById('co-name');
  const coPhone = document.getElementById('co-phone');
  const coAddress = document.getElementById('co-address');
  const coCity = document.getElementById('co-city');
  if (coName) coName.value = name;
  if (coPhone) coPhone.value = phone;
  if (coAddress) coAddress.value = address;
  if (coCity) coCity.value = city;

  showToast('Profile updated successfully');
}

function handleAvatarUpload(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    customerProfile.avatar = ev.target.result;
    document.getElementById('profile-avatar-img').src = ev.target.result;
    showToast('Avatar updated successfully');
  };
  reader.readAsDataURL(file);
}

function autofillCheckoutFromProfile() {
  const nameInput = document.getElementById('co-name');
  const phoneInput = document.getElementById('co-phone');
  const addressInput = document.getElementById('co-address');
  const cityInput = document.getElementById('co-city');
  
  if (nameInput) nameInput.value = nameInput.value.trim() || customerProfile.name;
  if (phoneInput) phoneInput.value = phoneInput.value.trim() || customerProfile.phone;
  if (addressInput) addressInput.value = addressInput.value.trim() || customerProfile.address;
  if (cityInput) cityInput.value = cityInput.value.trim() || customerProfile.city;
}

/* ====================================================
   PURCHASE HISTORY
==================================================== */
function renderHistory() {
  const nameEl = document.getElementById('history-client-name');
  if (nameEl) nameEl.textContent = customerProfile.name.toUpperCase();

  const list = document.getElementById('history-list');
  if (purchaseHistory.length === 0) {
    list.innerHTML = '<p style="color:var(--charcoal-soft);font-size:0.85rem;text-align:center;padding:40px 0">No orders yet. Start shopping!</p>';
    return;
  }

  list.innerHTML = purchaseHistory.map(order => `
    <div class="history-card">
      <div class="history-card-header">
        <div>
          <p class="history-order-id">Order #${order.orderId}</p>
          <p class="history-date">${order.date}</p>
        </div>
        <span class="${order.status === 'Delivered' ? 'badge-delivered' : order.status === 'Processing' ? 'badge-processing' : 'badge-pending'}">${order.status}</span>
        <span class="history-total">${order.total.toLocaleString()} MMK</span>
      </div>
      <div class="history-items">
        ${order.items.map(item => `
          <div class="history-item-row">
            <img class="history-item-img" src="${item.img}" alt="${item.name}"/>
            <div>
              <p class="history-item-name">${item.name}</p>
              <p class="history-item-meta">Size: ${item.size} · Color: ${item.color} · Qty: ${item.qty}</p>
              <p class="history-item-price">${(item.price * item.qty).toLocaleString()} MMK</p>
            </div>
          </div>`).join('')}
      </div>
    </div>`
  ).join('');
}

/* ====================================================
   TOAST
==================================================== */
function showToast(msg) {
  const wrap = document.getElementById('toast-wrap');
  const el = document.createElement('div');
  el.className = 'toast-msg';
  el.innerHTML = `<i class="fas fa-check-circle"></i>${msg}`;
  wrap.appendChild(el);
  setTimeout(() => {
    el.style.transition = 'opacity 0.4s, transform 0.4s';
    el.style.opacity = '0';
    el.style.transform = 'translateX(120%)';
    setTimeout(() => el.remove(), 450);
  }, 2800);
}

/* ====================================================
   KEYBOARD: close modal on ESC
==================================================== */
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    closeModal();
    if (document.getElementById('cart-drawer').classList.contains('open')) toggleCart();
  }
});

/* ====================================================
   INIT
==================================================== */
document.addEventListener('DOMContentLoaded', () => {
  initGrids();
  renderCart();
});
</script>

