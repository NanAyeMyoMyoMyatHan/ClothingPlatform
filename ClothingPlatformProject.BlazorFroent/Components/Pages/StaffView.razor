@page "/staff"
@using ClothingPlatformProject.BlazorFroent.Components.Partial
<PageTitle>The Boutique — Staff Portal</PageTitle>
<style>
    :root {
        --navy: #8B1A1A;
        --navy-dark: #6B0F0F;
        --navy-xdark: #4A0A0A;
        --slate: #7A5C50;
        --slate-light: #A0826D;
        --slate-border: #EDD9D0;
        --white: #FFFFFF;
        --off-white: #FDF8F6;
        --rose: #C8837A;
        --rose-light: #F2D8D5;
        --rose-dark: #A8615A;
        --amber: #F59E0B;
        --amber-light: #FEF3C7;
        --green: #16A34A;
        --green-light: #DCFCE7;
        --red: #DC2626;
        --red-light: #FEE2E2;
        --sidebar-w: 240px;
        --topbar-h: 60px;
        --radius: 10px;
        --shadow-sm: 0 1px 4px rgba(139,26,26,.07);
        --shadow-md: 0 4px 20px rgba(139,26,26,.10);
        --shadow-lg: 0 8px 32px rgba(139,26,26,.14);
        --transition: 0.22s cubic-bezier(.4,0,.2,1);
    }

    body {
        font-family: 'DM Sans', system-ui, sans-serif;
        background: var(--off-white);
        color: #3C1F10;
        font-size: .9rem;
        line-height: 1.55;
    }

    #appShell {
        display: flex;
        height: 100vh;
        overflow: hidden;
    }

    /* ───── SIDEBAR ───── */
    #sidebar {
        width: var(--sidebar-w);
        flex-shrink: 0;
        background: linear-gradient(180deg, #4A0A0A 0%, #6B0F0F 60%, #8B1A1A 100%);
        display: flex;
        flex-direction: column;
        border-right: 1px solid rgba(255,255,255,.06);
        position: relative;
        z-index: 10;
    }

    .sidebar-brand {
        padding: 1.4rem 1.2rem 1rem;
        border-bottom: 1px solid rgba(255,255,255,.08);
    }

    .brand-monogram {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1.5px solid #F5F0E8;
        background: rgba(245,240,232,.12);
        font-family: 'Cormorant Garamond', serif;
        font-size: 1rem;
        color: #F5F0E8;
        margin-bottom: .5rem;
    }

    .brand-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.15rem;
        color: #F5F0E8;
        font-weight: 400;
        letter-spacing: .06em;
    }

    .brand-sub {
        font-size: .62rem;
        letter-spacing: .22em;
        text-transform: uppercase;
        color: rgba(245,240,232,.5);
    }

    .sidebar-nav {
        flex: 1;
        padding: .75rem 0;
        overflow-y: auto;
    }

    .nav-section-label {
        font-size: .6rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: rgba(245,240,232,.4);
        padding: .9rem 1.2rem .3rem;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: .65rem;
        padding: .6rem 1.2rem;
        margin: 0 .5rem .15rem;
        border-radius: 8px;
        cursor: pointer;
        color: rgba(245,240,232,.75);
        font-size: .82rem;
        font-weight: 400;
        transition: background var(--transition), color var(--transition);
    }

        .nav-item i {
            font-size: 1rem;
            flex-shrink: 0;
            width: 1.1rem;
            text-align: center;
        }

        .nav-item:hover {
            background: rgba(245,240,232,.12);
            color: #F5F0E8;
        }

        .nav-item.active {
            background: rgba(245,240,232,.2);
            color: #F5F0E8;
            font-weight: 500;
            border-left: 3px solid #F5F0E8;
        }

            .nav-item.active i {
                color: #F5F0E8;
            }

    .sidebar-footer {
        padding: .9rem 1.2rem;
        border-top: 1px solid rgba(255,255,255,.08);
    }

    .staff-chip {
        display: flex;
        align-items: center;
        gap: .65rem;
    }

    .staff-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        flex-shrink: 0;
        background: linear-gradient(135deg, #F5F0E8, #EDD9D0);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Cormorant Garamond', serif;
        font-size: .95rem;
        color: #8B1A1A;
        font-weight: 600;
    }

    .staff-name {
        font-size: .78rem;
        color: #F5F0E8;
        font-weight: 500;
        line-height: 1.2;
    }

    .staff-role {
        font-size: .65rem;
        color: rgba(245,240,232,.5);
        letter-spacing: .05em;
    }

    /* ───── MAIN AREA ───── */
    #mainArea {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    /* TOP BAR */
    #topbar {
        height: var(--topbar-h);
        background: var(--white);
        border-bottom: 1px solid var(--slate-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1.8rem;
        flex-shrink: 0;
        box-shadow: var(--shadow-sm);
    }

    .topbar-greeting {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.25rem;
        color: #3C1F10;
        font-weight: 400;
    }

        .topbar-greeting span {
            color: #8B1A1A;
            font-style: italic;
        }

    .topbar-right {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .topbar-badge {
        font-size: .68rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        background: #8B1A1A;
        color: #F5F0E8;
        padding: .25rem .65rem;
        border-radius: 20px;
        font-weight: 500;
    }

    .topbar-date {
        font-size: .75rem;
        color: #3C1F10;
    }

    /* CONTENT */
    #content {
        flex: 1;
        overflow-y: auto;
        padding: 1.8rem;
    }

    /* ───── VIEW SECTIONS ───── */
    .view-section {
        display: none;
    }

        .view-section.active {
            display: block;
        }

    /* ───── PAGE HEADER ───── */
    .page-header {
        margin-bottom: 1.6rem;
    }

    .page-title {
        font-size: 1.6rem;
        color: #3C1F10;
        font-weight: 400;
        line-height: 1.1;
    }

    .page-sub {
        font-size: .78rem;
        color: var(--slate-light);
        letter-spacing: .06em;
        text-transform: uppercase;
        margin-top: .1rem;
    }

    .page-divider {
        height: 2px;
        background: linear-gradient(90deg, #8B1A1A, transparent);
        width: 48px;
        margin-top: .5rem;
        border-radius: 2px;
    }

    /* ───── KPI CARDS ───── */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 1.6rem;
    }

    .kpi-card {
        background: var(--white);
        border-radius: var(--radius);
        padding: 1.3rem 1.4rem;
        border: 1px solid var(--slate-border);
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
        box-shadow: var(--shadow-sm);
    }

        .kpi-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            border-radius: var(--radius) var(--radius) 0 0;
        }

        .kpi-card.kpi-pending::before {
            background: linear-gradient(90deg, #F59E0B, #FBBF24);
        }

        .kpi-card.kpi-processing::before {
            background: linear-gradient(90deg, #3B82F6, #60A5FA);
        }

        .kpi-card.kpi-delivered::before {
            background: linear-gradient(90deg, #16A34A, #4ADE80);
        }

        .kpi-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
        }

        .kpi-card.kpi-active {
            border-color: #8B1A1A;
            box-shadow: 0 0 0 2px rgba(139,26,26,.18);
        }

    .kpi-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        margin-bottom: .8rem;
    }

    .kpi-pending .kpi-icon {
        background: var(--amber-light);
        color: var(--amber);
    }

    .kpi-processing .kpi-icon {
        background: #DBEAFE;
        color: #2563EB;
    }

    .kpi-delivered .kpi-icon {
        background: var(--green-light);
        color: var(--green);
    }

    .kpi-count {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.2rem;
        color: #3C1F10;
        line-height: 1;
        margin-bottom: .2rem;
    }

    .kpi-label {
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: var(--slate-light);
        font-weight: 500;
    }

    .kpi-hint {
        font-size: .68rem;
        color: var(--slate-light);
        margin-top: .35rem;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    /* FILTER BAR */
    .filter-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .9rem;
    }

    .filter-label {
        font-size: .75rem;
        color: #3C1F10;
        font-weight: 500;
    }

    #resetFilterBtn {
        font-size: .72rem;
        padding: .3rem .8rem;
        border-radius: 20px;
        border: 1px solid var(--slate-border);
        background: var(--white);
        color: #3C1F10;
        cursor: pointer;
        transition: all var(--transition);
        font-family: 'DM Sans', sans-serif;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
    }

    /* ── Logout confirmation modal ── */
    .confirm-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15,32,80,.45);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    .confirm-modal {
        background: var(--white);
        border-radius: var(--radius-lg);
        padding: 1.8rem 2rem;
        max-width: 360px;
        width: 90%;
        text-align: center;
        box-shadow: var(--shadow-lg);
    }

    .confirm-icon {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: var(--red-light);
        color: var(--red);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin: 0 auto .9rem;
    }

    .confirm-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.25rem;
        color: var(--navy);
        margin-bottom: .4rem;
    }

    .confirm-text {
        font-size: .82rem;
        color: var(--slate);
        margin-bottom: 1.4rem;
        line-height: 1.5;
    }

    .confirm-actions {
        display: flex;
        gap: .7rem;
        justify-content: center;
    }

    .confirm-btn-cancel {
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
        background: var(--off-white);
        color: var(--slate);
        border: 1px solid var(--slate-border);
        border-radius: 8px;
        padding: .55rem 1.3rem;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: background var(--transition);
    }

        .confirm-btn-cancel:hover {
            background: #EDF1F6;
        }

    .confirm-btn-confirm {
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
        background: var(--red);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: .55rem 1.3rem;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: background var(--transition), transform var(--transition);
    }

        .confirm-btn-confirm:hover {
            background: #B91C1C;
            transform: translateY(-1px);
        }

    /* ───── TABLE ───── */
    .table-card {
        background: var(--white);
        border-radius: var(--radius);
        border: 1px solid var(--slate-border);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

        .table-card .table {
            margin: 0;
            font-size: .82rem;
        }

            .table-card .table thead th {
                background: #FFF3EE;
                color: #3C1F10;
                font-weight: 600;
                font-size: .68rem;
                letter-spacing: .1em;
                text-transform: uppercase;
                border-bottom: 1px solid var(--slate-border);
                padding: .85rem 1rem;
                white-space: nowrap;
            }

            .table-card .table tbody td {
                padding: .8rem 1rem;
                vertical-align: middle;
                border-color: #F1F5F9;
                color: #3C1F10;
            }

            .table-card .table tbody tr:hover {
                background: #FFF5F0;
            }

    /* Status badges */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .68rem;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
        padding: .28rem .7rem;
        border-radius: 20px;
    }

    .badge-pending {
        background: var(--amber-light);
        color: #92400E;
    }

    .badge-processing {
        background: #DBEAFE;
        color: #1D4ED8;
    }

    .badge-delivered {
        background: var(--green-light);
        color: #15803D;
    }

    .badge-locked {
        background: #E2E8F0;
        color: #475569;
        cursor: not-allowed;
    }

    .status-select {
        font-size: .76rem;
        font-family: 'DM Sans', sans-serif;
        border: 1px solid var(--slate-border);
        border-radius: 7px;
        padding: .3rem .6rem;
        background: var(--white);
        color: #3C1F10;
        cursor: pointer;
        transition: border-color var(--transition);
    }

        .status-select:focus {
            outline: none;
            border-color: #8B1A1A;
            box-shadow: 0 0 0 2px rgba(139,26,26,.15);
        }

    .pay-badge {
        font-size: .7rem;
        color: #3C1F10;
        background: #FDF8F6;
        padding: .2rem .55rem;
        border-radius: 5px;
    }

    /* ───── DASHBOARD ───── */
    .dash-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 1.6rem;
    }

    .dash-stat {
        background: var(--white);
        border-radius: var(--radius);
        padding: 1.2rem 1.3rem;
        border: 1px solid var(--slate-border);
        box-shadow: var(--shadow-sm);
    }

    .dash-stat-val {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2rem;
        color: #3C1F10;
        line-height: 1;
    }

    .dash-stat-label {
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: var(--slate-light);
        margin-top: .25rem;
    }

    /* WELCOME BANNER */
    .welcome-banner {
        background: linear-gradient(135deg, #4A0A0A 0%, #8B1A1A 60%, rgba(200,131,122,.4) 100%);
        border-radius: var(--radius);
        padding: 1.6rem 2rem;
        margin-bottom: 1.4rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        overflow: hidden;
        position: relative;
    }

        .welcome-banner::after {
            content: 'TB';
            position: absolute;
            right: 2rem;
            font-family: 'Cormorant Garamond', serif;
            font-size: 7rem;
            color: rgba(255,255,255,.06);
            line-height: 1;
            font-weight: 300;
            pointer-events: none;
        }

    .wb-greeting {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.55rem;
        color: #F5F0E8;
        font-weight: 300;
    }

        .wb-greeting strong {
            font-weight: 500;
            color: #F5F0E8;
        }

    .wb-sub {
        font-size: .75rem;
        color: rgba(245,240,232,.7);
        margin-top: .2rem;
        letter-spacing: .04em;
    }

    .wb-badge {
        background: #F5F0E8;
        border: 1px solid #EDD9D0;
        color: #8B1A1A;
        font-size: .7rem;
        padding: .35rem .85rem;
        border-radius: 20px;
        letter-spacing: .1em;
        text-transform: uppercase;
        font-weight: 600;
    }

    .section-title {
        font-size: 1.2rem;
        color: #3C1F10;
        font-weight: 500;
        margin-bottom: .9rem;
        font-family: 'Cormorant Garamond', serif;
    }

    /* ───── INVENTORY ───── */
    .inv-controls {
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .qty-btn {
        width: 28px;
        height: 28px;
        border: 1px solid var(--slate-border);
        border-radius: 6px;
        background: var(--white);
        color: #3C1F10;
        font-size: .9rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background var(--transition), color var(--transition);
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
    }

        .qty-btn:hover {
            background: #8B1A1A;
            color: #F5F0E8;
            border-color: #8B1A1A;
        }

    .qty-display {
        min-width: 38px;
        text-align: center;
        font-weight: 600;
        font-size: .85rem;
        color: #3C1F10;
    }

    .low-stock-badge {
        background: var(--amber-light);
        color: #92400E;
        font-size: .65rem;
        font-weight: 700;
        padding: .2rem .55rem;
        border-radius: 4px;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .in-stock-badge {
        background: var(--green-light);
        color: #15803D;
        font-size: .65rem;
        font-weight: 700;
        padding: .2rem .55rem;
        border-radius: 4px;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    /* ───── PROFILE ───── */
    .profile-card {
        background: var(--white);
        border-radius: var(--radius);
        border: 1px solid var(--slate-border);
        padding: 2rem;
        box-shadow: var(--shadow-sm);
        max-width: 560px;
    }

    .profile-avatar-lg {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: linear-gradient(135deg, #8B1A1A, #6B0F0F);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Cormorant Garamond', serif;
        font-size: 2rem;
        color: #F5F0E8;
        margin-bottom: 1.2rem;
        box-shadow: 0 4px 16px rgba(139,26,26,.35);
    }

    .profile-form .form-label {
        font-size: .7rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: #3C1F10;
        font-weight: 500;
        margin-bottom: .35rem;
    }

    .profile-form .form-control {
        font-family: 'DM Sans', sans-serif;
        font-size: .85rem;
        border: 1px solid var(--slate-border);
        border-radius: 8px;
        padding: .6rem .9rem;
        color: #3C1F10;
        transition: border-color var(--transition), box-shadow var(--transition);
    }

        .profile-form .form-control:focus {
            border-color: #8B1A1A;
            box-shadow: 0 0 0 3px rgba(139,26,26,.14);
            outline: none;
        }

    .btn-save {
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        background: #8B1A1A;
        color: #F5F0E8;
        border: none;
        border-radius: 8px;
        padding: .65rem 1.6rem;
        cursor: pointer;
        transition: background var(--transition), transform var(--transition);
        font-family: 'DM Sans', sans-serif;
    }

        .btn-save:hover {
            background: #6B0F0F;
            transform: translateY(-1px);
        }

    .btn-logout {
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        background: transparent;
        color: var(--red);
        border: 1.5px solid var(--red);
        border-radius: 8px;
        padding: .6rem 1.4rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        transition: background var(--transition), color var(--transition);
        font-family: 'DM Sans', sans-serif;
    }

        .btn-logout:hover {
            background: var(--red);
            color: #fff;
        }

    .profile-divider {
        height: 1px;
        background: var(--slate-border);
        margin: 1.5rem 0;
    }

    .profile-section-title {
        font-size: .7rem;
        letter-spacing: .15em;
        text-transform: uppercase;
        color: var(--slate-light);
        margin-bottom: .75rem;
    }

    .inline-toast {
        font-size: .8rem;
        padding: .6rem 1rem;
        border-radius: 8px;
        display: none;
        align-items: center;
        gap: .45rem;
        margin-top: .8rem;
    }

        .inline-toast.success {
            background: var(--green-light);
            color: #15803D;
            display: flex;
        }

        .inline-toast.error {
            background: var(--red-light);
            color: var(--red);
            display: flex;
        }

    /* ───── TOAST ───── */
    #toastContainer {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 8888;
        display: flex;
        flex-direction: column;
        gap: .5rem;
    }

    .app-toast {
        background: var(--white);
        border-radius: 10px;
        padding: .9rem 1.2rem;
        box-shadow: var(--shadow-lg);
        display: flex;
        align-items: center;
        gap: .65rem;
        min-width: 260px;
        border-left: 3px solid var(--green);
        font-size: .82rem;
        opacity: 1;
    }

        .app-toast.toast-error {
            border-color: var(--red);
        }

    .toast-ico {
        font-size: 1.1rem;
    }

    .toast-msg {
        flex: 1;
        color: #3C1F10;
        font-weight: 500;
    }
</style>


<!-- ═══════════ TOAST CONTAINER ═══════════ -->
<div id="toastContainer">
    @foreach (var toast in activeToasts)
    {
        <div class="app-toast @(toast.IsError ? "toast-error" : "")">
            <i class="bi @(toast.IsError ? "bi-x-circle text-danger" : "bi-check-circle text-success")" style="font-size:1.1rem"></i>
            <div class="toast-msg">@HtmlRaw(toast.Message)</div>
        </div>
    }
</div>

<!-- ═══════════ LOGOUT CONFIRM MODAL ═══════════ -->
@if (showLogoutConfirm)
{
    <div class="confirm-overlay" @onclick="CancelLogout">
        <div class="confirm-modal" @onclick:stopPropagation="true">
            <div class="confirm-icon"><i class="bi bi-box-arrow-right"></i></div>
            <div class="confirm-title">Log Out?</div>
            <div class="confirm-text">Are you sure you want to log out of the Staff Portal?</div>
            <div class="confirm-actions">
                <button class="confirm-btn-cancel" @onclick="CancelLogout">Cancel</button>
                <button class="confirm-btn-confirm" @onclick="ConfirmLogout">Yes, Log Out</button>
            </div>
        </div>
    </div>
}

<!-- ═══════════ APP SHELL ═══════════ -->
<div id="appShell">
    <!-- ── SIDEBAR ── -->
    <aside id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-monogram">TB</div>
            <div class="brand-title">The Boutique</div>
            <div class="brand-sub">Staff Portal</div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section-label">Main</div>
            <div class="nav-item @(activeView == "dashboard" ? "active" : "")" @onclick='() => NavigateTo("dashboard")'>
                <i class="bi bi-grid-1x2"></i> Dashboard
            </div>
            <div class="nav-section-label">Operations</div>
            <div class="nav-item @(activeView == "createorder" ? "active" : "")" @onclick='() => NavigateTo("createorder")'>
                <i class="bi bi-telephone-plus"></i> Create Order (Phone)
            </div>
            <div class="nav-item @(activeView == "orders" ? "active" : "")" @onclick='() => NavigateTo("orders")'>
                <i class="bi bi-bag-check"></i> Order Management
            </div>
            <div class="nav-item @(activeView == "inventory" ? "active" : "")" @onclick='() => NavigateTo("inventory")'>
                <i class="bi bi-archive"></i> Stock Control
            </div>
            <div class="nav-item @(activeView == "salesreport" ? "active" : "")" @onclick='async () => await NavigateTo("salesreport")'>
                <i class="bi bi-graph-up-arrow"></i> Daily Sales Report
            </div>
            <div class="nav-section-label">Account</div>
            <div class="nav-item @(activeView == "profile" ? "active" : "")" @onclick='() => NavigateTo("profile")'>
                <i class="bi bi-person-circle"></i> My Profile
            </div>
        </nav>
        <div class="sidebar-footer">
            <div class="staff-chip">
                <div class="staff-avatar">@staffInitials</div>
                <div>
                    <div class="staff-name">@staffFirstName @staffLastName</div>
                    <div class="staff-role">@staffRole</div>
                </div>
            </div>
        </div>
    </aside>

    <!-- ── MAIN AREA ── -->
    <div id="mainArea">
        <div id="topbar">
            <div class="topbar-greeting">Hello, <span>@staffFirstName @staffLastName</span></div>
            <div class="topbar-right">
                <span class="topbar-date">@currentDateString</span>
                <span class="topbar-badge">@staffRole</span>
                <button class="topbar-logout-btn" @onclick="RequestLogout" title="Logout">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </button>
            </div>
        </div>

        <div id="content">

            <!-- ──────────── DASHBOARD VIEW ──────────── -->
            <section class="view-section @(activeView == "dashboard" ? "active" : "")">
                <div class="welcome-banner">
                    <div>
                        <div class="wb-greeting">Good day, <strong>@staffFirstName @staffLastName</strong></div>
                        <div class="wb-sub">Here's an overview of today's boutique activity.</div>
                    </div>
                    <div class="wb-badge">@staffRole</div>
                </div>
                <div class="dash-grid">
                    <div class="dash-stat">
                        <div class="dash-stat-val">@totalOrdersCount</div>
                        <div class="dash-stat-label">Total Orders</div>
                    </div>
                    <div class="dash-stat">
                        <div class="dash-stat-val">@totalRevenue.ToString("N0")</div>
                        <div class="dash-stat-label">Total Revenue (MMK)</div>
                    </div>
                    <div class="dash-stat">
                        <div class="dash-stat-val">@totalSkusCount</div>
                        <div class="dash-stat-label">Active SKUs</div>
                    </div>
                    <div class="dash-stat">
                        <div class="dash-stat-val text-warning">@lowStockCount</div>
                        <div class="dash-stat-label">Low Stock Items</div>
                    </div>
                </div>
                <div class="section-title">Recent Orders</div>
                <div class="table-card">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Amount (MMK)</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!PagedRecentOrders.Any())
                            {
                                <tr><td colspan="4" style="text-align:center;padding:2rem;color:var(--slate-light)"><i class="bi bi-inbox" style="font-size:1.6rem;display:block;margin-bottom:.4rem"></i>No orders yet.</td></tr>
                            }
                            else
                            {
                                @foreach (var ord in PagedRecentOrders)
                                {
                                    <tr>
                                        <td style="font-family:monospace;font-weight:600;color:var(--navy)">#ORD-@ord.OrderId.ToString("D4")</td>
                                        <td>@ord.User.FirstName @ord.User.LastName</td>
                                        <td>@ord.TotalAmount.ToString("N0")</td>
                                        <td>@StatusBadge(ord.OrderStatus)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <Pagination CurrentPage="@recentOrderPage" TotalPages="@RecentOrderTotalPages" CurrentPageChanged="@ChangeRecentOrderPage" />
            </section>

            <!-- ──────────── CREATE ORDER (PHONE) VIEW ──────────── -->
            <section class="view-section @(activeView == "createorder" ? "active" : "")">
                <div class="page-header">
                    <div class="page-sub">Operations</div>
                    <h1 class="page-title">Create Order — Phone Customer</h1>
                    <div class="page-divider"></div>
                </div>

                <div class="ob-wrapper">

                    <!-- ① Guest Customer -->
                    <div class="ob-card">
                        <div class="ob-card-header">
                            <div class="ob-step-dot dot-customer">1</div>
                            <div>
                                <div class="ob-card-title">Guest Customer</div>
                                <div class="ob-card-subtitle">Enter caller's name and phone number</div>
                            </div>
                        </div>
                        <div class="ob-card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="ob-form-label">Customer Name</label>
                                    <input type="text" class="ob-input" placeholder="e.g. Thiri San" @bind="guestCustomerName" />
                                </div>
                                <div class="col-md-6">
                                    <label class="ob-form-label">Phone Number</label>
                                    <input type="tel" class="ob-input" placeholder="09xxxxxxxxx" @bind="guestPhoneNumber" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ② Items -->
                    <div class="ob-card">
                        <div class="ob-card-header">
                            <div class="ob-step-dot dot-items">2</div>
                            <div>
                                <div class="ob-card-title">Order Items</div>
                                <div class="ob-card-subtitle">Select products and quantities</div>
                            </div>
                        </div>
                        <div class="ob-card-body">

                            <div class="ob-items-header">
                                <div>Product / SKU</div>
                                <div style="text-align:center">Qty</div>
                                <div style="text-align:right">Unit Price</div>
                                <div style="text-align:right">Subtotal</div>
                                <div></div>
                            </div>

                            @foreach (var line in orderLines)
                            {
                                <div class="ob-item-row">
                                    <select class="ob-select" value="@line.VariantId"
                                            @onchange="(e) => OnLineVariantChanged(line, e.Value?.ToString())">
                                        <option value="0">— Select item —</option>
                                        @foreach (var v in inventoryVariants.Where(x => x.StockQuantity > 0 || x.VariantId == line.VariantId))
                                        {
                                            <option value="@v.VariantId">@v.Sku — @v.Product.Name (@v.Size / @v.Color) · @v.StockQuantity left</option>
                                        }
                                    </select>
                                    <input type="number" min="1" class="ob-qty-input" value="@line.Quantity"
                                           @onchange="(e) => OnLineQtyChanged(line, e.Value?.ToString())" />
                                    <div class="ob-price-cell" style="text-align:right">@GetVariantUnitPrice(line.VariantId).ToString("N0")</div>
                                    <div class="ob-total-cell" style="text-align:right">@GetLineTotal(line).ToString("N0")</div>
                                    <button class="ob-remove-btn" @onclick="() => RemoveOrderLine(line)">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            }

                            <button class="ob-add-btn" @onclick="AddOrderLine">
                                <i class="bi bi-plus-circle"></i> Add Another Item
                            </button>

                            <div class="ob-summary-bar" style="margin-top:1rem">
                                <div>
                                    <div class="ob-summary-label">Order Total</div>
                                    <div class="ob-summary-amount">@OrderLinesTotal.ToString("N0") <span style="font-size:.9rem;opacity:.7">MMK</span></div>
                                </div>
                                <div style="text-align:right">
                                    <div class="ob-summary-label">Items</div>
                                    <div class="ob-summary-items">@orderLines.Where(l => l.VariantId > 0).Sum(l => l.Quantity) pcs</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ③ Delivery -->
                    <div class="ob-card">
                        <div class="ob-card-header">
                            <div class="ob-step-dot dot-delivery">3</div>
                            <div>
                                <div class="ob-card-title">Delivery Address</div>
                                <div class="ob-card-subtitle">Where should this order be shipped?</div>
                            </div>
                        </div>
                        <div class="ob-card-body">
                            <label class="ob-form-label">Shipping / Contact Address</label>
                            <textarea class="ob-textarea" rows="3"
                                      placeholder="No.123, Bo Yar Nyunt Street, Dagon Township, Yangon"
                                      @bind="newOrderShippingAddress"></textarea>
                        </div>
                    </div>

                    <!-- ④ Payment -->
                    <div class="ob-card">
                        <div class="ob-card-header">
                            <div class="ob-step-dot dot-payment">4</div>
                            <div>
                                <div class="ob-card-title">Payment Details</div>
                                <div class="ob-card-subtitle">Select method and confirm payment status</div>
                            </div>
                        </div>
                        <div class="ob-card-body">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label class="ob-form-label">Payment Method</label>
                                    <div class="ob-pill-group" style="margin-top:.35rem">
                                        @foreach (var m in new[] { ("COD", "bi-cash-coin", "Cash on Delivery"), ("KBZ Pay", "bi-phone", "KBZ Pay"), ("Wave Pay", "bi-phone-fill", "Wave Pay"), ("Bank Transfer", "bi-bank", "Bank Transfer") })
                                        {
                                            <button class="ob-pill @(guestPaymentMethod == m.Item1 ? "ob-pill-active" : "")"
                                                    @onclick='() => guestPaymentMethod = m.Item1'>
                                                <i class="bi @m.Item2"></i> @m.Item3
                                            </button>
                                        }
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="ob-form-label">Payment Status</label>
                                    <div class="ob-pill-group" style="margin-top:.35rem">
                                        <button class="ob-pill @(guestPaymentStatus == "unpaid" ? "ob-pill-active" : "")"
                                                @onclick='() => guestPaymentStatus = "unpaid"'>
                                            <i class="bi bi-clock-history"></i> Unpaid
                                        </button>
                                        <button class="ob-pill @(guestPaymentStatus == "paid" ? "ob-pill-active" : "")"
                                                @onclick='() => guestPaymentStatus = "paid"'>
                                            <i class="bi bi-check-circle"></i> Paid
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Error + Submit -->
                    @if (!string.IsNullOrEmpty(createOrderError))
                    {
                        <div class="inline-toast error" style="display:flex">
                            <i class="bi bi-exclamation-triangle-fill"></i>&nbsp;@createOrderError
                        </div>
                    }

                    <div style="display:flex;align-items:center;gap:1rem">
                        <button class="ob-submit-btn" @onclick="SubmitPhoneOrder">
                            <i class="bi bi-bag-check-fill"></i> Confirm &amp; Create Order
                        </button>
                        <button style="font-size:.76rem;color:var(--slate);background:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif" @onclick="ResetCreateOrderForm">
                            <i class="bi bi-arrow-counterclockwise"></i> Reset Form
                        </button>
                    </div>

                </div>
            </section>

            <!-- ──────────── ORDER MANAGEMENT VIEW ──────────── -->
            <section class="view-section @(activeView == "orders" ? "active" : "")">
                <div class="page-header">
                    <div class="page-sub">Operations</div>
                    <h1 class="page-title">Order Management</h1>
                    <div class="page-divider"></div>
                </div>

                <!-- Tab switcher: Regular / Guest -->
                <div class="om-tabs">
                    <button class="om-tab @(ordersTab == "regular" ? "om-tab-active" : "")" @onclick='() => ordersTab = "regular"'>
                        <i class="bi bi-bag"></i> Regular Orders (@allOrders.Count)
                    </button>
                    <button class="om-tab @(ordersTab == "guest" ? "om-tab-active" : "")" @onclick='() => ordersTab = "guest"'>
                        <i class="bi bi-telephone"></i> Phone / Guest Orders (@allGuestOrders.Count)
                    </button>
                </div>

                <!-- ── REGULAR ORDERS TAB ── -->
                @if (ordersTab == "regular")
                {
                    <div class="kpi-grid">
                        <div class="kpi-card kpi-pending @(currentFilter == "pending" ? "kpi-active" : "")" @onclick='() => FilterOrders("pending")'>
                            <div class="kpi-icon"><i class="bi bi-hourglass-split"></i></div>
                            <div class="kpi-count">@pendingCount</div>
                            <div class="kpi-label">Pending Orders</div>
                            <div class="kpi-hint"><i class="bi bi-hand-index"></i> Click to filter</div>
                        </div>
                        <div class="kpi-card kpi-processing @(currentFilter == "processing" ? "kpi-active" : "")" @onclick='() => FilterOrders("processing")'>
                            <div class="kpi-icon"><i class="bi bi-arrow-repeat"></i></div>
                            <div class="kpi-count">@processingCount</div>
                            <div class="kpi-label">Processing Orders</div>
                            <div class="kpi-hint"><i class="bi bi-hand-index"></i> Click to filter</div>
                        </div>
                        <div class="kpi-card kpi-delivered @(currentFilter == "delivered" ? "kpi-active" : "")" @onclick='() => FilterOrders("delivered")'>
                            <div class="kpi-icon"><i class="bi bi-check-circle"></i></div>
                            <div class="kpi-count">@deliveredCount</div>
                            <div class="kpi-label">Delivered Orders</div>
                            <div class="kpi-hint"><i class="bi bi-hand-index"></i> Click to filter</div>
                        </div>
                    </div>
                    <div class="filter-bar">
                        <div class="filter-label">
                            Showing: <strong>@(string.IsNullOrEmpty(currentFilter) ? "All Orders" : char.ToUpper(currentFilter[0]) + currentFilter.Substring(1) + " Orders")</strong>
                        </div>
                        @if (!string.IsNullOrEmpty(currentFilter))
                        {
                            <button id="resetFilterBtn" @onclick='() => FilterOrders("")'>
                                <i class="bi bi-x-circle"></i> Show All
                            </button>
                        }
                    </div>
                    <div class="table-card">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer</th>
                                    <th>Amount (MMK)</th>
                                    <th>Payment</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!filteredOrders.Any())
                                {
                                    <tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--slate-light)"><i class="bi bi-inbox" style="font-size:1.6rem;display:block;margin-bottom:.4rem"></i>No orders found.</td></tr>
                                }
                                else
                                {
                                    @foreach (var ord in Pagedorders)
                                    {
                                        var payMethod = ord.Payments.FirstOrDefault()?.PaymentMethod ?? "COD";
                                        <tr>
                                            <td style="font-family:monospace;font-weight:600;color:var(--navy);font-size:.8rem">#ORD-@ord.OrderId.ToString("D4")</td>
                                            <td>@ord.User.FirstName @ord.User.LastName</td>
                                            <td style="font-weight:500">@ord.TotalAmount.ToString("N0")</td>
                                            <td><span class="pay-badge">@payMethod.ToUpper()</span></td>
                                            <td>@StatusBadge(ord.OrderStatus)</td>
                                            <td>
                                                @if (ord.OrderStatus.ToLower() == "delivered")
                                                {
                                                    <span class="status-badge badge-locked"><i class="bi bi-lock-fill"></i> Locked</span>
                                                }
                                                else
                                                {
                                                    <select class="status-select" value="@ord.OrderStatus" @onchange="(e) => UpdateOrderStatus(ord, e.Value?.ToString())">
                                                        <option value="pending">Pending</option>
                                                        <option value="processing">Processing</option>
                                                        <option value="delivered">Delivered</option>
                                                    </select>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <Pagination CurrentPage="@orderPage" TotalPages="@OrderTotalPages" CurrentPageChanged="@ChangeOrderPage" />
                }

                <!-- ── GUEST / PHONE ORDERS TAB ── -->
                @if (ordersTab == "guest")
                {
                    <div class="filter-bar">
                        <div class="filter-label">
                            Showing: <strong>All Phone / Guest Orders</strong>
                            <span class="guest-tag" style="margin-left:.5rem">Guest</span>
                        </div>
                    </div>
                    <div class="table-card">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer Name</th>
                                    <th>Phone</th>
                                    <th>Amount (MMK)</th>
                                    <th>Payment Method</th>
                                    <th>Payment Status</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!allGuestOrders.Any())
                                {
                                    <tr><td colspan="8" style="text-align:center;padding:2rem;color:var(--slate-light)"><i class="bi bi-telephone-x" style="font-size:1.6rem;display:block;margin-bottom:.4rem"></i>No phone orders yet.</td></tr>
                                }
                                else
                                {
                                    @foreach (var go in PagedGuestOrders)
                                    {
                                        <tr>
                                            <td style="font-family:monospace;font-weight:600;color:var(--purple);font-size:.8rem">#GORD-@go.GuestOrderId.ToString("D4")</td>
                                            <td>@go.CustomerName</td>
                                            <td style="font-size:.78rem;color:var(--slate)">@go.PhoneNumber</td>
                                            <td style="font-weight:500">@go.TotalAmount.ToString("N0")</td>
                                            <td><span class="pay-badge">@(go.PaymentMethod ?? "COD")</span></td>
                                            <td>
                                                @{
                                                    var ps = (go.PaymentStatus ?? "unpaid").ToLower();
                                                    if (ps == "paid")
                                                    {
                                                        <span class="status-badge badge-paid"><i class="bi bi-check-circle"></i> Paid</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="status-badge badge-unpaid"><i class="bi bi-clock-history"></i> Unpaid</span>
                                                    }
                                                }
                                            </td>
                                            <td>@StatusBadge(go.OrderStatus ?? "pending")</td>
                                            <td>
                                                @if ((go.OrderStatus ?? "").ToLower() == "delivered")
                                                {
                                                    <span class="status-badge badge-locked"><i class="bi bi-lock-fill"></i> Locked</span>
                                                }
                                                else
                                                {
                                                    <select class="status-select" value="@go.OrderStatus" @onchange="(e) => UpdateGuestOrderStatus(go, e.Value?.ToString())">
                                                        <option value="pending">Pending</option>
                                                        <option value="processing">Processing</option>
                                                        <option value="delivered">Delivered</option>
                                                    </select>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <Pagination CurrentPage="@guestOrderPage" TotalPages="@GuestOrderTotalPages" CurrentPageChanged="@ChangeGuestOrderPage" />
                }
            </section>

            <!-- ──────────── INVENTORY VIEW ──────────── -->
            <section class="view-section @(activeView == "inventory" ? "active" : "")">
                <div class="page-header">
                    <div class="page-sub">Operations</div>
                    <h1 class="page-title">Stock Control (Inventory)</h1>
                    <div class="page-divider"></div>
                </div>
                <div class="table-card">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>SKU</th>
                                <th>Product Name</th>
                                <th>Size</th>
                                <th>Color</th>
                                <th>Qty</th>
                                <th>Stock Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!PagedInventoryVariants.Any())
                            {
                                <tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--slate-light)">No inventory items found.</td></tr>
                            }
                            else
                            {
                                @for (int i = 0; i < PagedInventoryVariants.Count; i++)
                                {
                                    var variant = PagedInventoryVariants[i];
                                    bool isLow = variant.StockQuantity < 5;
                                    <tr>
                                        <td>@((inventoryPage - 1) * inventoryPageSize + i + 1)</td>
                                        <td style="font-family:monospace;font-weight:500">@variant.Sku</td>
                                        <td>@variant.Product.Name</td>
                                        <td>@variant.Size</td>
                                        <td>@variant.Color</td>
                                        <td class="qty-display">@variant.StockQuantity</td>
                                        <td>
                                            @if (variant.StockQuantity == 0)
                                            {
                                                <span class="low-stock-badge" style="background:var(--red-light);color:var(--red)">Out of Stock</span>
                                            }
                                            else if (isLow)
                                            {
                                                <span class="low-stock-badge">Low Stock</span>
                                            }
                                            else
                                            {
                                                <span class="in-stock-badge">In Stock</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <Pagination CurrentPage="@inventoryPage" TotalPages="@InventoryTotalPages" CurrentPageChanged="@ChangeInventoryPage" />
            </section>

            <!-- ──────────── SALES REPORT VIEW ──────────── -->
            <section class="view-section @(activeView == "salesreport" ? "active" : "")">
                <div class="page-header">
                    <div class="page-sub">Reports</div>
                    <h1 class="page-title">Staff Daily Sales Report</h1>
                    <div class="page-divider"></div>
                </div>
                <div class="table-card">
                    <div class="report-meta">
                        <div class="filter-bar" style="margin-bottom:.3rem">
                            <div class="filter-label">
                                <strong>Report Date:</strong>
                                <input type="date" class="report-date-input"
                                       value="@selectedReportDate.ToString("yyyy-MM-dd")"
                                       max="@DateTime.Today.ToString("yyyy-MM-dd")"
                                       @onchange="OnReportDateChanged" />
                                @if (selectedReportDate.Date == DateTime.Today)
                                {
                                    <span class="topbar-badge" style="margin-left:.5rem">Today</span>
                                }
                            </div>
                            @if (selectedReportDate.Date != DateTime.Today)
                            {
                                <button id="resetFilterBtn" @onclick="ResetReportToToday">
                                    <i class="bi bi-arrow-counterclockwise"></i> Back to Today
                                </button>
                            }
                        </div>
                        <p style="margin-bottom:.2rem"><strong>Staff Name:</strong> @staffName</p>
                        <div class="scope-note">
                            <i class="bi bi-shield-lock"></i> Showing only orders you personally processed — other staff members' work is not shown here.
                        </div>
                    </div>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer Name</th>
                                <th>Items</th>
                                <th>Total Amount</th>
                                <th>Payment Method</th>
                                <th>Type</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!reportOrders.Any() && !reportGuestOrders.Any())
                            {
                                <tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--slate-light)"><i class="bi bi-inbox" style="font-size:1.6rem;display:block;margin-bottom:.4rem"></i>No orders found for @selectedReportDate.ToString("MMMM dd, yyyy").</td></tr>
                            }
                            else
                            {
                                @foreach (var ord in reportOrders)
                                {
                                    <tr>
                                        <td style="font-family:monospace;font-weight:600;color:var(--navy);font-size:.8rem">#ORD-@ord.OrderId.ToString("D4")</td>
                                        <td>@ord.User.FirstName @ord.User.LastName</td>
                                        <td>@ord.OrderItems.Count</td>
                                        <td>@ord.TotalAmount.ToString("N0") MMK</td>
                                        <td>@(ord.Payments.FirstOrDefault()?.PaymentMethod ?? "Cash")</td>
                                        <td><span class="pay-badge">Regular</span></td>
                                    </tr>
                                }
                                @foreach (var go in reportGuestOrders)
                                {
                                    <tr>
                                        <td style="font-family:monospace;font-weight:600;color:var(--purple);font-size:.8rem">#GORD-@go.GuestOrderId.ToString("D4")</td>
                                        <td>@go.CustomerName</td>
                                        <td>@go.TotalQuantity</td>
                                        <td>@go.TotalAmount.ToString("N0") MMK</td>
                                        <td>@(go.PaymentMethod ?? "COD")</td>
                                        <td><span class="guest-tag" style="margin-left:0">Guest</span></td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="2">Total Orders: @reportOrderCount</th>
                                <th colspan="4">Total Sales: @reportRevenue.ToString("N0") MMK</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </section>

            <!-- ──────────── PROFILE VIEW ──────────── -->
            <section class="view-section @(activeView == "profile" ? "active" : "")">
                <div class="page-header">
                    <div class="page-sub">Account</div>
                    <h1 class="page-title">My Profile</h1>
                    <div class="page-divider"></div>
                </div>
                <div class="profile-card">
                    <div class="profile-avatar-lg">@staffInitials</div>
                    <div class="profile-section-title">Personal Information</div>
                    <div class="profile-form">
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label">First Name</label>
                                <input type="text" class="form-control" @bind="staffFirstName" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Last Name</label>
                                <input type="text" class="form-control" @bind="staffLastName" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Email Address</label>
                                <input type="email" class="form-control" @bind="staffEmail" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Phone Number</label>
                                <input type="tel" class="form-control" @bind="staffPhone" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Role</label>
                                <input type="text" class="form-control" value="@staffRole" disabled style="background:#f8fafc;color:var(--slate)" />
                            </div>
                        </div>
                        @if (profileSaved)
                        {
                            <div class="inline-toast success">
                                <i class="bi bi-check-circle"></i> Profile changes saved successfully.
                            </div>
                        }
                        <div style="margin-top:1.4rem">
                            <button class="btn-save" @onclick="SaveProfile">
                                <i class="bi bi-floppy" style="margin-right:.35rem"></i>Save Changes
                            </button>
                        </div>
                    </div>
                </div>
            </section>

        </div><!-- /content -->
    </div><!-- /mainArea -->
</div><!-- /appShell -->