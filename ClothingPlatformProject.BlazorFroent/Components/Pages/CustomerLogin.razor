@page "/customer-login"
@using ClothingPlatformProject.Models.Auth
@inject HttpClientServices HttpServices
@inject CustomerSessionState CustomerSession
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<PageTitle>Chic Boutique - Customer Login</PageTitle>

<div class="customer-auth-page">
    <section class="customer-auth-panel">
        <div class="auth-brand">Chic Boutique</div>
        <div class="auth-tabs">
            <button class="@(mode == "login" ? "active" : "")" @onclick='() => SetMode("login")'>Sign In</button>
            <button class="@(mode == "register" ? "active" : "")" @onclick='() => SetMode("register")'>Create Account</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="auth-message @(isError ? "error" : "success")">@message</div>
        }

        @if (mode == "login")
        {
            <label>Email</label>
            <input type="email" @bind="loginEmail" />
            <label>Password</label>
            <input type="password" @bind="loginPassword" />
            <button class="auth-primary" @onclick="HandleLogin">Sign In</button>
        }
        else
        {
            <div class="auth-name-grid">
                <div>
                    <label>First Name</label>
                    <input type="text" @bind="firstName" />
                </div>
                <div>
                    <label>Last Name</label>
                    <input type="text" @bind="lastName" />
                </div>
            </div>
            <label>Email</label>
            <input type="email" @bind="registerEmail" />
            <label>Phone Number</label>
            <input type="tel" @bind="phoneNumber" />
            <label>Address</label>
            <input type="text" @bind="address" />
            <label>Password</label>
            <input type="password" @bind="registerPassword" />
            <button class="auth-primary" @onclick="HandleRegister">Create Account</button>
        }
    </section>
</div>

@code {
    private string mode = "login";
    private string message = "";
    private bool isError;

    private string loginEmail = "";
    private string loginPassword = "";

    private string firstName = "";
    private string lastName = "";
    private string registerEmail = "";
    private string phoneNumber = "";
    private string address = "";
    private string registerPassword = "";

    private void SetMode(string value)
    {
        mode = value;
        message = "";
    }

    private async Task HandleLogin()
    {
        message = "";
        if (string.IsNullOrWhiteSpace(loginEmail) || string.IsNullOrWhiteSpace(loginPassword))
        {
            ShowMessage("Please enter your email and password.", true);
            return;
        }

        try
        {
            var result = await HttpServices.ExecuteAsync<CustomerAuthResponse>(
                "api/customer-auth/login",
                new CustomerLoginRequest { Email = loginEmail, Password = loginPassword },
                EnumHttpMethod.Post);

            if (result == null)
            {
                ShowMessage("Email or password is incorrect.", true);
                return;
            }

            await CompleteLogin(result);
        }
        catch (Exception ex)
        {
            ShowMessage(ex.Message, true);
        }
    }

    private async Task HandleRegister()
    {
        message = "";
        if (string.IsNullOrWhiteSpace(firstName) ||
            string.IsNullOrWhiteSpace(lastName) ||
            string.IsNullOrWhiteSpace(registerEmail) ||
            string.IsNullOrWhiteSpace(address) ||
            string.IsNullOrWhiteSpace(registerPassword))
        {
            ShowMessage("Please fill in all required fields.", true);
            return;
        }

        try
        {
            var result = await HttpServices.ExecuteAsync<CustomerAuthResponse>(
                "api/customer-auth/register",
                new CustomerRegisterRequest
                {
                    FirstName = firstName,
                    LastName = lastName,
                    Email = registerEmail,
                    PhoneNumber = phoneNumber,
                    Address = address,
                    Password = registerPassword
                },
                EnumHttpMethod.Post);

            if (result != null)
            {
                await CompleteLogin(result);
            }
        }
        catch (Exception ex)
        {
            ShowMessage(ex.Message, true);
        }
    }

    private async Task CompleteLogin(CustomerAuthResponse result)
    {
        CustomerSession.Login(new User
        {
            UserId = result.UserId,
            FirstName = result.FirstName,
            LastName = result.LastName,
            Email = result.Email,
            PhoneNumber = result.PhoneNumber,
            Address = result.Address,
            Role = result.Role,
            PasswordHash = string.Empty
        });

        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "customerId", result.UserId.ToString());
        Nav.NavigateTo("/customer");
    }

    private void ShowMessage(string value, bool error)
    {
        message = value;
        isError = error;
    }
}
