
@page "/login"

<PageTitle>Chic Boutique — Atelier Access</PageTitle>
<style>
    :root {
        --bg-start: #FDF8F6;
        --bg-end: #FDF8F6;
        --blood-red: #8B1A1A;
        --blood-red-dark: #6B0F0F;
        --blood-red-light: rgba(139,26,26,0.1);
        --charcoal: #3C1F10;
        --charcoal-soft: #7A5C50;
        --muted: #7A5C50;
        --white: #FDF8F6;
        --card-bg: #FFFFFF;
        --border-light: rgba(139,26,26,0.18);
        --shadow: 0 24px 64px rgba(139,26,26,0.1), 0 4px 16px rgba(139,26,26,0.05);
        --radius: 20px;
        --transition: 0.38s cubic-bezier(0.4,0,0.2,1);
        --font-display: 'Cormorant Garamond', Georgia, serif;
        --font-body: 'DM Sans', system-ui, sans-serif;
    }

    body {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-start);
        font-family: var(--font-body);
        color: var(--charcoal);
        padding: 2rem 1rem;
    }

        body::before, body::after {
            content: '';
            position: fixed;
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
        }

        body::before {
            width: 520px;
            height: 520px;
            background: radial-gradient(circle, rgba(139,26,26,0.08) 0%, transparent 70%);
            top: -180px;
            right: -160px;
        }

        body::after {
            width: 380px;
            height: 380px;
            background: radial-gradient(circle, rgba(237,217,208,0.4) 0%, transparent 70%);
            bottom: -120px;
            left: -100px;
        }

    .brand-lockup {
        text-align: center;
        margin-bottom: 2rem;
        position: relative;
    }

    .brand-monogram {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        border: 1.5px solid var(--blood-red);
        background: rgba(255,255,255,0.5);
        margin-bottom: 0.75rem;
    }

        .brand-monogram span {
            font-family: var(--font-display);
            font-size: 1.35rem;
            font-weight: 400;
            color: var(--blood-red);
            letter-spacing: 0.04em;
        }

    .brand-name {
        font-family: var(--font-display);
        font-size: 1.05rem;
        font-weight: 300;
        letter-spacing: 0.42em;
        text-transform: uppercase;
        color: var(--charcoal);
    }

    .brand-tagline {
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--charcoal-soft);
        margin-top: 0.2rem;
    }

    .auth-card {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 460px;
        background: var(--card-bg);
        backdrop-filter: blur(18px) saturate(1.4);
        -webkit-backdrop-filter: blur(18px) saturate(1.4);
        border: 1px solid var(--border-light);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 2.6rem 2.4rem 2.2rem;
        overflow: hidden;
    }

        .auth-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 10%;
            right: 10%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--blood-red), transparent);
            border-radius: 0 0 2px 2px;
        }

    .form-panel {
        transition: opacity var(--transition), transform var(--transition);
    }

    .form-heading {
        font-family: var(--font-display);
        font-size: 2rem;
        font-weight: 400;
        color: var(--charcoal);
        line-height: 1.15;
        margin-bottom: 0.3rem;
    }

        .form-heading em {
            color: var(--blood-red);
            font-style: italic;
        }

    .form-subheading {
        font-size: 0.78rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--blood-red);
        font-weight: 500;
        margin-bottom: 1.6rem;
    }

    .divider {
        width: 36px;
        height: 1px;
        background: var(--blood-red);
        margin: 0.4rem 0 1.5rem;
        opacity: 0.4;
    }

    .form-label {
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-weight: 500;
        color: var(--charcoal-soft);
        margin-bottom: 0.42rem;
        display: block;
    }

    .form-control {
        font-family: var(--font-body);
        font-size: 0.9rem;
        font-weight: 300;
        color: var(--charcoal);
        background: #FDFAF8;
        border: 1px solid var(--border-light);
        border-radius: 10px;
        padding: 0.68rem 1rem;
        transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
        letter-spacing: 0.02em;
        width: 100%;
    }

        .form-control:focus {
            background: #FFFFFF;
            border-color: var(--blood-red);
            box-shadow: 0 0 0 3px rgba(139,26,26,0.12);
            outline: none;
            color: var(--charcoal);
        }

        .form-control::placeholder {
            color: #C4A99A;
            font-weight: 300;
        }

        .form-control.is-invalid {
            border-color: var(--blood-red-dark);
            box-shadow: 0 0 0 3px rgba(139,26,26,0.1);
        }

    .invalid-feedback {
        font-size: 0.74rem;
        color: var(--blood-red-dark);
        letter-spacing: 0.02em;
        display: block;
        margin-top: 0.3rem;
    }

    .pw-wrapper {
        position: relative;
    }

        .pw-wrapper .form-control {
            padding-right: 2.8rem;
        }

    .pw-toggle {
        position: absolute;
        right: 0.85rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: var(--charcoal-soft);
        font-size: 1rem;
        cursor: pointer;
        padding: 0;
        line-height: 1;
        transition: color 0.2s;
    }

        .pw-toggle:hover {
            color: var(--blood-red);
        }

    .form-check-input:checked {
        background-color: var(--blood-red);
        border-color: var(--blood-red);
    }

    .form-check-input:focus {
        box-shadow: 0 0 0 3px rgba(139,26,26,0.18);
    }

    .form-check-label {
        font-size: 0.8rem;
        color: var(--charcoal-soft);
    }

    .btn-boutique {
        width: 100%;
        font-family: var(--font-body);
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #F5F0E8;
        background: linear-gradient(135deg, var(--blood-red) 0%, var(--blood-red-dark) 100%);
        border: none;
        border-radius: 10px;
        padding: 0.82rem 1.5rem;
        cursor: pointer;
        transition: transform 0.22s, box-shadow 0.22s, filter 0.22s;
        box-shadow: 0 4px 18px rgba(139,26,26,0.3);
        margin-top: 0.5rem;
    }

        .btn-boutique:hover {
            transform: translateY(-2px) scale(1.012);
            box-shadow: 0 8px 28px rgba(139,26,26,0.38);
            filter: brightness(1.06);
        }

        .btn-boutique:active {
            transform: translateY(0) scale(0.995);
            box-shadow: 0 3px 10px rgba(139,26,26,0.25);
        }

    .switch-text {
        font-size: 0.78rem;
        color: var(--charcoal-soft);
        text-align: center;
        margin-top: 1.4rem;
    }

    .switch-link {
        color: var(--blood-red);
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s, color 0.2s;
        letter-spacing: 0.02em;
    }

        .switch-link:hover {
            color: var(--blood-red-dark);
            border-bottom-color: var(--blood-red);
        }

    .alert-boutique {
        font-size: 0.82rem;
        border-radius: 10px;
        border: none;
        padding: 0.75rem 1rem;
        margin-bottom: 1.2rem;
        letter-spacing: 0.02em;
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }

        .alert-boutique.alert-success {
            background: rgba(180,220,185,0.28);
            color: #2D6A38;
            border-left: 3px solid #5BAB6A;
        }

        .alert-boutique.alert-danger {
            background: rgba(139,26,26,0.08);
            color: var(--blood-red-dark);
            border-left: 3px solid var(--blood-red);
        }

        .alert-boutique i {
            font-size: 1rem;
            flex-shrink: 0;
            margin-top: 1px;
        }

    .toast-container-custom {
        position: fixed;
        top: 1.5rem;
        right: 1.5rem;
        z-index: 9999;
    }

    .toast-boutique {
        min-width: 290px;
        background: var(--charcoal);
        border-radius: 14px;
        border: 1px solid rgba(139,26,26,0.28);
        box-shadow: 0 8px 32px rgba(28,28,30,0.15);
        padding: 1rem 1.2rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        transform: translateX(130%);
        opacity: 0;
        transition: transform 0.45s cubic-bezier(0.34,1.56,0.64,1), opacity 0.35s ease;
    }

        .toast-boutique.show {
            transform: translateX(0);
            opacity: 1;
        }

    .toast-icon {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #8DC88F, #5BAB6A);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .toast-icon i {
            color: #fff;
            font-size: 1rem;
        }

    .toast-body-text strong {
        display: block;
        font-size: 0.82rem;
        font-weight: 500;
        color: #F5F0E8;
        letter-spacing: 0.03em;
    }

    .toast-body-text span {
        font-size: 0.75rem;
        color: rgba(245,240,232,0.7);
    }

    .name-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
    }

    .mb-field {
        margin-bottom: 1.1rem;
    }

    .card-footer-note {
        text-align: center;
        margin-top: 2rem;
        font-size: 0.68rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--charcoal-soft);
        opacity: 0.6;
    }

    @@media (max-width: 520px) {
        .auth-card {
            padding: 2rem 1.4rem 1.8rem;
            border-radius: 16px;
        }

        .form-heading {
            font-size: 1.65rem;
        }

        .name-row {
            grid-template-columns: 1fr;
            gap: 0;
        }

        .toast-container-custom {
            top: 1rem;
            right: 1rem;
            left: 1rem;
        }

        .toast-boutique {
            min-width: unset;
            width: 100%;
        }
    }

    .alert-boutique-danger {
        background-color: #FDF8F6;
        border: 1px solid var(--border-light);
        border-radius: 8px;
        box-shadow: 0 4px 25px rgba(139,26,26,0.1);
    }

        .alert-boutique-danger .alert-icon {
            color: var(--blood-red);
        }

    .alert-actions {
        display: flex;
        gap: 12px;
    }

    .btn-alert-danger {
        background-color: var(--blood-red);
        color: #F5F0E8;
        border: none;
        padding: 6px 16px;
        border-radius: 4px;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-alert-danger:hover {
            background-color: var(--blood-red-dark);
        }

    .btn-alert-secondary {
        background: none;
        border: 1px solid var(--border-light);
        color: var(--charcoal-soft);
        padding: 6px 16px;
        border-radius: 4px;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-alert-secondary:hover {
            background-color: var(--bg-start);
            color: var(--charcoal);
        }
</style>
<!-- ── TOAST ──────────────────────────────── -->
<div class="toast-container-custom">
    <div class="toast-boutique @(showToast ? "show" : "")">
        <div class="toast-icon"><i class="bi bi-check-lg"></i></div>
        <div class="toast-body-text">
            <strong>Authentication Successful</strong>
            <span>Redirecting to Style Hub…</span>
        </div>
    </div>
</div>
<!-- ── MAIN WRAPPER ────────────────────────── -->
<div style="position:relative;z-index:1;width:100%;max-width:460px;">
    <!-- Brand Lockup -->
    <div class="brand-lockup">
        <div class="brand-monogram"><span>TB</span></div>
        <div class="brand-name">Chic Boutique</div>
        <div class="brand-tagline">Atelier Membership</div>
    </div>
    <!-- Auth Card -->
    <div class="auth-card">
        @if (currentPanel == "login")
        {
            <!-- ── LOGIN PANEL ───────────────────── -->
            <div class="form-panel">
                @if (!string.IsNullOrEmpty(loginErrorMessage))
                {
                    <div class="alert-boutique alert-danger">
                        <i class="bi bi-x-circle"></i>
                        <span>@loginErrorMessage</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(loginSuccessMessage))
                {
                    <div class="alert-boutique alert-success">
                        <i class="bi bi-check-circle"></i>
                        <span>@HtmlRaw(loginSuccessMessage)</span>
                    </div>
                }
                <div class="form-subheading">Welcome back</div>
                <h1 class="form-heading">Sign in to<br><em>your atelier</em></h1>
                <div class="divider"></div>
                <div class="mb-field">
                    <label class="form-label">Email address</label>
                    <input type="email" class="form-control @(emailInvalid ? "is-invalid" : "")" @bind="loginEmail" @bind:event="oninput" placeholder="you@example.com" />
                    @if (emailInvalid)
                    {
                        <div class="invalid-feedback">@emailErrorMsg</div>
                    }
                </div>
                <div class="mb-field">
                    <label class="form-label">Password</label>
                    <div class="pw-wrapper">
                        <input type="@(showLoginPw ? "text" : "password")" class="form-control @(pwInvalid ? "is-invalid" : "")" @bind="loginPassword" @bind:event="oninput" placeholder="••••••••" />
                        <button type="button" class="pw-toggle" @onclick="() => showLoginPw = !showLoginPw" tabindex="-1">
                            <i class="bi @(showLoginPw ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    @if (pwInvalid)
                    {
                        <div class="invalid-feedback">@pwErrorMsg</div>
                    }
                </div>
                <div class="d-flex align-items-center mb-3" style="margin-top:-0.2rem;">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="rememberMe" />
                        <label class="form-check-label" for="rememberMe">Remember me</label>
                    </div>
                </div>
                <button class="btn-boutique" @onclick="HandleLogin">
                    <i class="bi bi-arrow-right-short" style="font-size:1rem;vertical-align:-2px;margin-right:4px;"></i>
                    Enter the Boutique
                </button>
                <p class="switch-text">
                    New to The Boutique?
                    <a class="switch-link" @onclick='() => SwitchTo("signup")'>Create your account &rarr;</a>
                </p>
            </div>
        }
        else
        {
            <!-- ── SIGN-UP PANEL ─────────────────── -->
            <div class="form-panel">
                @if (!string.IsNullOrEmpty(signupErrorMessage))
                {
                    <div class="alert-boutique alert-danger">
                        <i class="bi bi-x-circle"></i>
                        <span>@signupErrorMessage</span>
                    </div>
                }
                <div class="form-subheading">Join the atelier</div>
                <h1 class="form-heading">Create your<br><em>membership</em></h1>
                <div class="divider"></div>
                <!-- Name Row -->
                <div class="name-row mb-field">
                    <div>
                        <label class="form-label">First name</label>
                        <input type="text" class="form-control @(regFirstNameInvalid ? "is-invalid" : "")" @bind="regFirstName" @bind:event="oninput" placeholder="Emily" />
                        @if (regFirstNameInvalid)
                        {
                            <div class="invalid-feedback">First name is required.</div>
                        }
                    </div>
                    <div>
                        <label class="form-label">Last name</label>
                        <input type="text" class="form-control @(regLastNameInvalid ? "is-invalid" : "")" @bind="regLastName" @bind:event="oninput" placeholder="Watson" />
                        @if (regLastNameInvalid)
                        {
                            <div class="invalid-feedback">Last name is required.</div>
                        }
                    </div>
                </div>
                <div class="mb-field">
                    <label class="form-label">Email address</label>
                    <input type="email" class="form-control @(regEmailInvalid ? "is-invalid" : "")" @bind="regEmail" @bind:event="oninput" placeholder="you@example.com" />
                    @if (regEmailInvalid)
                    {
                        <div class="invalid-feedback">@regEmailErrorMsg</div>
                    }
                </div>

                <div class="mb-field">
                    <label class="form-label" for="regAddress">Address</label>
                    <input type="text"
                           id="regAddress"
                           class="form-control @(regAddressInvalid ? "is-invalid" : "")"
                           @bind="regAddress"
                           @bind:event="oninput"
                           placeholder="Yangon" />

                    @if (regAddressInvalid)
                    {
                        <div class="invalid-feedback d-block">@regAddressErrorMsg</div>
                    }
                </div>

                <div class="mb-field">
                    <label class="form-label">Phone number</label>
                    <input type="tel" class="form-control @(regPhoneInvalid ? "is-invalid" : "")" @bind="regPhone" @bind:event="oninput" placeholder="09xxxxxxxxx" />
                    @if (regPhoneInvalid)
                    {
                        <div class="invalid-feedback">Phone number is required.</div>
                    }
                </div>
                <div class="mb-field">
                    <label class="form-label">Password</label>
                    <div class="pw-wrapper">
                        <input type="@(showRegPw ? "text" : "password")" class="form-control @(regPwInvalid ? "is-invalid" : "")" @bind="regPassword" @bind:event="oninput" placeholder="Min. 8 characters" />
                        <button type="button" class="pw-toggle" @onclick="() => showRegPw = !showRegPw" tabindex="-1">
                            <i class="bi @(showRegPw ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    @if (regPwInvalid)
                    {
                        <div class="invalid-feedback">@regPwErrorMsg</div>
                    }
                </div>
                <div class="mb-field">
                    <label class="form-label">Confirm password</label>
                    <div class="pw-wrapper">
                        <input type="@(showRegConfirmPw ? "text" : "password")" class="form-control @(regConfirmPwInvalid ? "is-invalid" : "")" @bind="regConfirmPassword" @bind:event="oninput" placeholder="Repeat password" />
                        <button type="button" class="pw-toggle" @onclick="() => showRegConfirmPw = !showRegConfirmPw" tabindex="-1">
                            <i class="bi @(showRegConfirmPw ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    @if (regConfirmPwInvalid)
                    {
                        <div class="invalid-feedback">@regConfirmPwErrorMsg</div>
                    }
                </div>
                <button class="btn-boutique" @onclick="HandleSignup">
                    <i class="bi bi-person-plus" style="font-size:0.95rem;vertical-align:-1px;margin-right:5px;"></i>
                    Create Membership
                </button>
                <p class="switch-text">
                    Already a member?
                    <a class="switch-link" @onclick='() => SwitchTo("login")'>&larr; Sign in here</a>
                </p>
            </div>
        }
    </div><!-- /auth-card -->
    <div class="card-footer-note">Secure · Encrypted · Private</div>
</div><!-- /wrapper -->


